    lines=$(wc -l < "$f" 2>/dev/null || echo 0)
    size=$(wc -c < "$f" 2>/dev/null || echo 0)
    total_lines=$(( total_lines + lines ))

    base=${rel##*/}
    ext="(none)"
    if [[ "$base" == *.* && "$base" != .* ]]; then
      ext=${base##*.}
    elif [[ "$base" == .* && "$base" == *.*.* ]]; then
      ext=${base##*.}
    fi
    ext=${ext,,}
    EXT_COUNTS["$ext"]=$(( ${EXT_COUNTS[$ext]:-0} + 1 ))
    EXT_LINES["$ext"]=$(( ${EXT_LINES[$ext]:-0} + lines ))

    top_dir="."
