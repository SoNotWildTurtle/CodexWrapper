task_has_target() {
  local target=$1
  local file
  local escaped
  escaped=$(printf '%s' "$target" | sed 's/[][(){}.^$*+?|\\-]/\\&/g')
  for file in Taskfile.yml Taskfile.yaml taskfile.yml taskfile.yaml; do
    [[ -f $file ]] || continue
    if grep -E "^[[:space:]]{0,4}${escaped}:" "$file" >/dev/null 2>&1; then
      return 0
    fi
  done
  return 1
}

run_python_install() {
  local manager=$1
  case "$manager" in
    poetry)
      poetry install
      ;;
    pipenv)
      pipenv install --dev
      ;;
    pip)
      local -a pip_args=()
      if [[ -z "${VIRTUAL_ENV:-}" ]]; then
        local current_uid=${EUID:-$(id -u)}
        if [[ $current_uid -ne 0 ]]; then
          pip_args+=(--user)
        fi
      fi
      local rc=0
      local ran=false
      local req
      for req in requirements.txt requirements-dev.txt dev-requirements.txt; do
        if [[ -f $req ]]; then
          ran=true
          if ! python3 -m pip install "${pip_args[@]}" -r "$req"; then
            rc=1
          fi
        fi
      done
      if ! $ran; then
        if [[ -f pyproject.toml || -f setup.py || -f setup.cfg ]]; then
          ran=true
          if ! python3 -m pip install "${pip_args[@]}" -e .; then
            rc=1
          fi
        fi
      fi
      if ! $ran; then
        echo ">>> No Python requirements found to install" >&2
      fi
      return $rc
      ;;
    *)
      echo "Unknown Python dependency manager: $manager" >&2
      return 1
      ;;
  esac
}

