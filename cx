just_has_recipe() {
  local recipe=$1
  local file
  local escaped
  escaped=$(printf '%s' "$recipe" | sed 's/[][(){}.^$*+?|\\-]/\\&/g')
  for file in Justfile justfile; do
    [[ -f $file ]] || continue
    if grep -E "^${escaped}(:|\\s)" "$file" >/dev/null 2>&1; then
      return 0
    fi
  done
  return 1
}

