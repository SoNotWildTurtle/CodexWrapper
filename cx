def create_file(path: Path, content: str):
    if path.exists():
        return False
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(content, encoding='utf-8')
    actions.append(path.relative_to(root).as_posix())
    return True

def slugify(value: str, default: str = 'module') -> str:
    slug = value.replace('/', '_').replace('-', '_').replace('.', '_')
    slug = slug.strip('_')
    return slug or default

def go_package_name(component: str) -> str:
    sample = go_examples.get(component)
    if not sample:
        return slugify(component or project, project or 'main')
    try:
        for line in sample.read_text(encoding='utf-8', errors='ignore').splitlines():
            line = line.strip()
            if line.startswith('package '):
                return line.split()[1]
    except Exception:
        pass
    return slugify(component or project, project or 'main')

