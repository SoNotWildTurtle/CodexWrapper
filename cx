    conflict_output=$(grep -RInE '^[[:space:]]*<<<<<<< ' . 2>/dev/null || true)
    debug_output=$(grep -RInE 'console\\.log|debugger;|pdb\\.set_trace|ipdb\\.set_trace' . --include='*.js' --include='*.jsx' --include='*.ts' --include='*.tsx' --include='*.mjs' --include='*.cjs' --include='*.py' 2>/dev/null || true)
  fi

  todo_output=$(printf '%s\n' "$todo_output" | sed '/^$/d')
  todo_count=$(printf '%s\n' "$todo_output" | sed '/^$/d' | wc -l | tr -d ' ')

  conflict_output=$(printf '%s\n' "$conflict_output" | sed '/^$/d')
  conflict_count=$(printf '%s\n' "$conflict_output" | sed '/^$/d' | wc -l | tr -d ' ')

  debug_output=$(printf '%s\n' "$debug_output" | sed '/^$/d')
  debug_count=$(printf '%s\n' "$debug_output" | sed '/^$/d' | wc -l | tr -d ' ')

  {
    echo "# Repository inspection ($timestamp UTC)"
    echo "Total tracked files: $total_files"
    echo "Total lines of code: $total_lines"
    echo
    echo "## Files by extension (top 10 by file count)"
    if (( ${#ext_summary[@]} )); then
      format_count_lines "${ext_summary[@]}"
    else
