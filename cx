    fi
  fi

  if [[ $summary_written == false ]]; then
    if ! grep -q '^## Auto-generated Summaries' "$rec_file" 2>/dev/null; then
      printf '\n## Auto-generated Summaries\n\n' >>"$rec_file"
    fi
    if grep -q 'auto summaries will be appended here' "$rec_file" 2>/dev/null; then
      local tmp
      tmp=$(mktemp)
      sed '/auto summaries will be appended here/d' "$rec_file" >"$tmp"
      cat "$tmp" >"$rec_file"
      rm -f "$tmp"
    fi
    printf '%s\n' "$summary" >>"$rec_file"
