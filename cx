    fi
  } | tee "$file"
  echo "Backlog report written to $file" >&2
}

run_backlog_suite() {
  local status=0
  echo "Starting backlog automation for $project" >&2
  if ! run_baseline_suite; then
    status=1
  fi
  generate_backlog_report "$status"
  if (( status == 0 )); then
    echo "Backlog automation complete. Review $BACKLOG_REPORT_PATH for prioritized actions." >&2
  else
    echo "Backlog automation completed with issues. Review $BACKLOG_REPORT_PATH alongside the baseline output above." >&2
  fi
  return $status
}

