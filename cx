#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE' >&2
Usage: cx role=VALUE goal=VALUE [cons=VAL] [reason=VAL] [out=VAL] [raw=VAL] [topic=VAL] [model=VAL] [temp=VAL] [--estimate] [--dry] [--offline] [--replay] [--dict] [--metrics] [--grid] [--relations] [--topics] [--audit] [--inspect] [--hotspots] [--stale] [--lint] [--fix] [--baseline]
USAGE
}

run_baseline_step() {
  local label=$1
  shift
  echo >&2
  echo ">>> $label" >&2
  if "$@"; then
    echo ">>> $label completed" >&2
    return 0
  else
    local rc=$?
    echo ">>> $label failed (exit $rc)" >&2
    return $rc
  fi
}

run_baseline_suite() {
  local status=0
  echo "Starting baseline repository automation for $project" >&2
  local -a lint_cmd=("$0" "--lint")
  if $FIX; then
    lint_cmd+=("--fix")
  fi
  run_baseline_step "Lint checks" "${lint_cmd[@]}" || status=1
  run_baseline_step "Repository audit" "$0" "--audit" || status=1
  run_baseline_step "Repository inspection" "$0" "--inspect" || status=1
  if command -v git >/dev/null 2>&1 && git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    run_baseline_step "Hotspot analysis" "$0" "--hotspots" || status=1
    run_baseline_step "Stale file scan" "$0" "--stale" || status=1
  else
    echo ">>> Skipping git-based analyses (repository not detected)" >&2
  fi
  if (( status == 0 )); then
    echo "Baseline automation complete. Review the logs under ~/.cx for details." >&2
  else
    echo "Baseline automation finished with issues. Review the output above." >&2
  fi
  return $status
}

ESTIMATE=false
DRY=false
OFFLINE=false
REPLAY=false
SHOW_DICT=false
SHOW_METRICS=false
SHOW_GRID=false
SHOW_REL=false
SHOW_TOPICS=false
SHOW_AUDIT=false
SHOW_INSPECT=false
SHOW_HOTSPOTS=false
SHOW_STALE=false
SHOW_LINT=false
FIX=false
RUN_BASELINE=false
ARGS=()

for arg in "$@"; do
  case "$arg" in
    --estimate)
      ESTIMATE=true
      ;;
    --dry)
      DRY=true
      ;;
    --offline)
      OFFLINE=true
      ;;
    --replay)
      REPLAY=true
      ;;
    --dict)
      SHOW_DICT=true
      ;;
    --metrics)
      SHOW_METRICS=true
      ;;
    --grid)
      SHOW_GRID=true
      ;;
    --relations)
      SHOW_REL=true
      ;;
    --topics)
      SHOW_TOPICS=true
      ;;
    --audit)
      SHOW_AUDIT=true
      ;;
    --inspect)
      SHOW_INSPECT=true
      ;;
    --hotspots)
      SHOW_HOTSPOTS=true
      ;;
    --stale)
      SHOW_STALE=true
      ;;
    --lint)
      SHOW_LINT=true
      ;;
    --fix)
      SHOW_LINT=true
      FIX=true
      ;;
    --baseline)
      RUN_BASELINE=true
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      ARGS+=("$arg")
      ;;
  esac
done

ROLE=""
GOAL=""
CONS=""
REASON=""
OUT=""
RAW=""
TOPICS=""
MODEL="${CX_MODEL:-gpt-3.5-turbo}"
TEMP="${CX_TEMP:-0.7}"
project=$(basename "$(pwd)")

for pair in "${ARGS[@]}"; do
  key="${pair%%=*}"
  value="${pair#*=}"
  case "$key" in
    role) ROLE="$value" ;;
    goal) GOAL="$value" ;;
    cons|constraints) CONS="$value" ;;
    reason|reasons) REASON="$value" ;;
    out|output) OUT="$value" ;;
    raw|R) RAW="$value" ;;
    topic|topics) TOPICS="$value" ;;
    model) MODEL="$value" ;;
    temp|temperature) TEMP="$value" ;;
    *) echo "Unknown arg: $key" >&2 ;;
  esac
done

if $RUN_BASELINE; then
  run_baseline_suite
  exit $?
fi

if $SHOW_TOPICS; then
  dir="$HOME/.cx/topics"
  shopt -s nullglob
  files=("$dir"/*.log)
  if (( ${#files[@]} == 0 )); then
    echo "No topics logged" >&2
  else
    for f in "${files[@]}"; do
      topic=$(basename "$f" .log)
      count=$(wc -l < "$f")
      echo "$topic $count"
    done
  fi
  exit 0
fi

if $REPLAY; then
  dir="$HOME/.cx/offline"
  shopt -s nullglob globstar
  files=("$dir"/**/*.txt)
  if (( ${#files[@]} == 0 )); then
    echo "No offline prompts to replay" >&2
    exit 0
  fi
  if [[ -z "${OPENAI_API_KEY:-}" ]]; then
    read -s -p "Enter OpenAI API key: " OPENAI_API_KEY
    echo
    if [[ -z "$OPENAI_API_KEY" ]]; then
      echo "API key required for replay" >&2
      exit 1
    fi
    export OPENAI_API_KEY
  fi
  for f in "${files[@]}"; do
    prompt=$(cat "$f")
    if response=$(OPENAI_PROMPT="$prompt" MODEL="$MODEL" TEMP="$TEMP" python3 - <<'PY'
