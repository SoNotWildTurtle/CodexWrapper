summarize_git_state() {
  if ! command -v git >/dev/null 2>&1; then
    echo ">>> Git is not available; skipping git summary" >&2
    return 0
  fi
  if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    echo ">>> Not inside a git repository; skipping git summary" >&2
    return 0
  fi

  echo ">>> Git status summary" >&2
  git status --short --branch >&2 || true
  echo ">>> Git diff --stat" >&2
  git diff --stat >&2 || true
}

log_improve_run() {
  local status=$1
  local dir="$CX_HOME/improve"
  mkdir -p "$dir"
  local file="$dir/$project.log"
  {
    printf '[%s] status=%s\n' "$(date -u +'%Y-%m-%dT%H:%M:%SZ')" "$status"
    if command -v git >/dev/null 2>&1 && git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
      echo '--- git status --short --branch ---'
      git status --short --branch 2>&1 || true
      echo '--- git diff --stat ---'
      git diff --stat 2>&1 || true
    else
      echo 'git=unavailable'
    fi
    echo
  } >>"$file"
}

append_recommendation_summary() {
  local status=$1
  local rec_file=""
  local candidate
  for candidate in "$PROJECT_ROOT/recommendations.md" "$CX_HOME/recommendations.md"; do
    if [[ -f $candidate ]]; then
      rec_file=$candidate
      break
    fi
