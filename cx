    status=1
  fi

  if path=$(command -v curl 2>/dev/null); then
    results+=("- [OK] curl located at $path")
  else
    results+=("- [ERROR] curl not found. Install curl so cx can reach the OpenAI API.")
    overall="ERROR"
    status=1
  fi

  if path=$(command -v git 2>/dev/null); then
    results+=("- [OK] git located at $path")
  else
    results+=("- [WARN] git not found. Repository automation will be limited until git is installed.")
    if [[ "$overall" == "OK" ]]; then
      overall="WARN"
    fi
  fi

  if mkdir -p "$CX_HOME" >/dev/null 2>&1; then
    if [[ -w "$CX_HOME" ]]; then
      results+=("- [OK] CX_HOME is writable at $CX_HOME")
    else
      results+=("- [ERROR] CX_HOME ($CX_HOME) is not writable. Adjust permissions so automation logs can be saved.")
      overall="ERROR"
      status=1
    fi
  else
    results+=("- [ERROR] Unable to create CX_HOME at $CX_HOME. Check permissions and disk space.")
    overall="ERROR"
    status=1
  fi

  if command -v python3 >/dev/null 2>&1; then
    if python3 -m pip --version >/dev/null 2>&1; then
      results+=("- [OK] python3 -m pip available for dependency management")
    else
      results+=("- [WARN] python3 -m pip unavailable. Install pip to allow the installer to seed Python modules automatically.")
      if [[ "$overall" == "OK" ]]; then
        overall="WARN"
      fi
    fi

    if python3 - <<'PY' >/dev/null 2>&1; then
import importlib.util, sys
sys.exit(0 if importlib.util.find_spec("tiktoken") else 1)
PY
      results+=("- [OK] Python module 'tiktoken' available for accurate token estimates")
    else
      results+=("- [WARN] Python module 'tiktoken' missing. Run \`python3 -m pip install tiktoken\` for precise token counts.")
      if [[ "$overall" == "OK" ]]; then
        overall="WARN"
      fi
    fi

    if python3 - <<'PY' >/dev/null 2>&1; then
import importlib.util, sys
sys.exit(0 if importlib.util.find_spec("openai") else 1)
PY
      results+=("- [OK] Python module 'openai' available for API access")
    else
      results+=("- [WARN] Python module 'openai' missing. Run \`python3 -m pip install openai\` to enable direct API calls.")
      if [[ "$overall" == "OK" ]]; then
        overall="WARN"
      fi
    fi
  else
    results+=("- [WARN] Skipped Python module checks because python3 is unavailable.")
    if [[ "$overall" == "OK" ]]; then
      overall="WARN"
    fi
  fi

  if [[ -f "$CX_HOME/dict" ]]; then
    results+=("- [OK] Dictionary seed present at $CX_HOME/dict")
  else
    results+=("- [WARN] Dictionary seed missing at $CX_HOME/dict. Run ./install.sh to populate starter symbols.")
    if [[ "$overall" == "OK" ]]; then
      overall="WARN"
    fi
  fi

  if [[ -n "${OPENAI_API_KEY:-}" ]]; then
    results+=("- [OK] OPENAI_API_KEY detected in the environment")
  else
    results+=("- [WARN] OPENAI_API_KEY not set. cx will prompt before API calls or store prompts offline.")
    if [[ "$overall" == "OK" ]]; then
      overall="WARN"
    fi
  fi

  local dir="$CX_HOME/doctor"
  mkdir -p "$dir"
  local timestamp
  timestamp=$(date -u +%Y-%m-%dT%H%MZ)
  local log="$dir/$project-$timestamp.md"
  local latest="$dir/$project-latest.md"

  {
    echo "# Codex environment diagnostics for $project"
    echo
    echo "- Project root: $PROJECT_ROOT"
    echo "- CX_HOME: $CX_HOME"
    echo
    printf '%s\n' "${results[@]}"
    echo
    echo "Overall status: $overall"
  } | tee "$log"

  cp "$log" "$latest" 2>/dev/null || cp "$log" "$latest"
  echo "Environment diagnostics saved to $log" >&2
  return $status
}

show_module_weak_points() {
  local json_output
  if ! json_output=$(CX_MODULES_OUTPUT=json generate_module_markdown 2>/dev/null); then
    echo "Module analysis requires python; install python3 to enable weak point triage." >&2
    return 1
  fi

  if [[ -z "$json_output" ]]; then
    echo "Module analysis did not produce any data. Add source files and rerun." >&2
    return 1
  fi

  local dir="$CX_HOME/weakpoints"
  mkdir -p "$dir"
  local timestamp
  timestamp=$(date -u +%Y-%m-%dT%H%MZ)
  local json_file="$dir/$project-$timestamp.json"
  printf '%s\n' "$json_output" >"$json_file"

  local summary_file="$dir/$project-$timestamp.md"
  local python_cmd="python3"
  if ! command -v "$python_cmd" >/dev/null 2>&1; then
    if command -v python >/dev/null 2>&1; then
      python_cmd="python"
    fi
  fi

  if "$python_cmd" - "$json_file" "$summary_file" <<'PY'
import json
import os
import sys
from collections import defaultdict
from pathlib import Path

json_path = Path(sys.argv[1])
summary_path = Path(sys.argv[2])

data = json.loads(json_path.read_text(encoding='utf-8'))
project = data.get('project') or json_path.stem
weak_points = data.get('weak_points') or []
plan = data.get('mitigation_plan') or {}

automated = plan.get('automated') or []
manual = plan.get('manual') or []

def severity_weight(value: str) -> int:
    return {'critical': 3, 'high': 2, 'medium': 1, 'low': 0}.get((value or '').lower(), 1)

sorted_points = sorted(
    weak_points,
    key=lambda entry: (
        -severity_weight(entry.get('severity')),
        -(entry.get('score') or 0),
        (entry.get('component') or project),
    ),
)

limit_env = os.environ.get('CX_WEAKPOINT_LIMIT', '').strip()
limit = None
if limit_env:
    try:
        parsed = int(limit_env)
        if parsed > 0:
            limit = parsed
    except ValueError:
        pass
if limit is None:
    limit = 5

display = sorted_points[:limit] if limit and len(sorted_points) > limit else sorted_points

mitigation_map = defaultdict(list)
for kind, entries in (("Automated", automated), ("Manual", manual)):
    for entry in entries:
        component = (entry.get('component') or project).strip() or project
        mitigation_map[component.lower()].append({
            'kind': kind,
            'severity': (entry.get('severity') or 'medium').title(),
            'status': (entry.get('status') or ('pending' if kind == 'Automated' else 'planned')).replace('_', ' ').title(),
            'action': entry.get('action') or 'Review module health',
            'details': '; '.join(entry.get('details') or []),
        })

lines = [f"# Weak point triage for {project}", ""]

if not sorted_points:
    lines.append("No pressing weak points detected; module metrics look healthy.")
else:
    total = len(sorted_points)
    if display is sorted_points:
        lines.append(f"Identified {total} weak point{'s' if total != 1 else ''}.")
    else:
        lines.append(
            f"Identified {total} weak point{'s' if total != 1 else ''}; showing top {len(display)}."
        )
    lines.append("")

    for index, entry in enumerate(display, start=1):
        component = entry.get('component') or project
        language = (entry.get('language') or 'module').title()
        severity = (entry.get('severity') or 'medium').title()
        score = entry.get('score')
        header = f"{index}. {language} {component} — severity {severity}"
        if isinstance(score, (int, float)):
            header += f" (score {score})"
        lines.append(header)

        metrics_bits = []
        lines_count = entry.get('lines')
        if isinstance(lines_count, int) and lines_count:
            metrics_bits.append(f"~{lines_count} LOC")
        markers = entry.get('markers')
        if isinstance(markers, int) and markers:
            markers_label = 'marker' if markers == 1 else 'markers'
            metrics_bits.append(f"{markers} TODO/FIXME {markers_label}")
        max_file = entry.get('max_file_lines')
        if isinstance(max_file, int) and max_file:
            metrics_bits.append(f"largest file ≈{max_file} LOC")
        if metrics_bits:
            lines.append("   - Metrics: " + ', '.join(metrics_bits))

        reasons = entry.get('reasons') or []
        if reasons:
            lines.append("   - Reasons: " + '; '.join(reasons))

        mitigations = mitigation_map.get(component.lower(), [])
        if mitigations:
            lines.append("   - Mitigations:")
            for item in mitigations:
                detail = f" — {item['details']}" if item['details'] else ''
                lines.append(
                    f"     * [{item['kind']}] {item['severity']} ({item['status']}): {item['action']}{detail}"
                )
        else:
            lines.append("   - Mitigations: review module guidance and schedule follow-up work")

        lines.append("")

    lines.append(
        "Run `cx --modules=apply` for automated fixes or `cx --additive` to fold these findings into a full improvement sweep."
    )
    if limit and len(sorted_points) > len(display):
        lines.append(
            "Set CX_WEAKPOINT_LIMIT to a larger number to list additional entries."
        )

text = "\n".join(lines).rstrip() + "\n"
summary_path.write_text(text, encoding='utf-8')
print(text, end='')
PY
  then
    cp "$summary_file" "$dir/$project-latest.md" 2>/dev/null || cp "$summary_file" "$dir/$project-latest.md"
    cp "$json_file" "$dir/$project-latest.json" 2>/dev/null || cp "$json_file" "$dir/$project-latest.json"
    echo "Weak point report written to $summary_file" >&2
    return 0
  else
    rm -f "$summary_file"
    echo "Failed to generate weak point summary. Review $json_file for raw module data." >&2
    return 1
  fi
}

run_module_suite() {
  echo "Analyzing module scaffolding opportunities for $project" >&2
  local timestamp
  timestamp=$(date -u +%Y-%m-%dT%H%MZ)
  local dir="$CX_HOME/modules"
  mkdir -p "$dir"
  local mode="${CX_MODULES_OUTPUT:-markdown}"
  mode=${mode,,}
  local ext="md"
  local json_capture="$dir/$project-$timestamp.json"
  case "$mode" in
    json)
      ext="json"
      json_capture="$dir/$project-$timestamp.json"
      ;;
    apply|markdown)
      ext="md"
      ;;
    *)
      mode="markdown"
      ext="md"
      ;;
  esac

  local file="$dir/$project-$timestamp.$ext"
  local status=0

  if [[ "$mode" == "apply" ]]; then
    local json_file="$dir/$project-$timestamp.json"
    if CX_MODULES_OUTPUT="$mode" CX_MODULES_JSON_PATH="$json_file" generate_module_markdown >"$file"; then
      json_capture="$json_file"
      if [[ ! -s "$json_file" ]]; then
        rm -f "$json_file"
        json_capture=""
      fi
    else
      status=$?
      rm -f "$json_file"
      json_capture=""
    fi
  else
    if ! CX_MODULES_OUTPUT="$mode" CX_MODULES_JSON_PATH="$json_capture" generate_module_markdown >"$file"; then
      status=$?
    fi
  fi

  if (( status == 0 )); then
    if [[ "$mode" == "apply" ]]; then
      echo "Module scaffolding summary written to $file" >&2
    else
      echo "Module analysis written to $file" >&2
    fi
  else
    echo "Module analysis saved to $file, but enable python3 for deeper insights." >&2
  fi

  if (( status == 0 )) && [[ -n "$json_capture" && -s "$json_capture" ]]; then
    if ! module_regression_check "$json_capture"; then
      status=1
      echo "Module regression detected—address the newly flagged gaps or export CX_MODULE_ALLOW_REGRESSION=1 to override." >&2
      if [[ -n ${MODULE_REGRESSION_OUTPUT//[[:space:]]/} ]]; then
        echo "$MODULE_REGRESSION_OUTPUT" >&2
      fi
    elif [[ ${MODULE_REGRESSION_ALLOWED:-false} == true ]]; then
      echo "Module regression detected but allowed because CX_MODULE_ALLOW_REGRESSION=1. Review the following gaps:" >&2
      if [[ -n ${MODULE_REGRESSION_OUTPUT//[[:space:]]/} ]]; then
        echo "$MODULE_REGRESSION_OUTPUT" >&2
      fi
    fi
  fi

  return $status
}

module_scaffold_apply() {
  local quiet=${1:-false}
  local timestamp
  timestamp=$(date -u +%Y-%m-%dT%H%MZ)
  local dir="$CX_HOME/scaffold"
  mkdir -p "$dir"
  local base="$dir/$project-$timestamp"
  local log="$base.md"
  local json="$base.json"
  local status=0
  if [[ "$quiet" == "true" ]]; then
    if ! CX_MODULES_OUTPUT=apply CX_MODULES_JSON_PATH="$json" generate_module_markdown >"$log"; then
      status=$?
    fi
  else
    if ! CX_MODULES_OUTPUT=apply CX_MODULES_JSON_PATH="$json" generate_module_markdown | tee "$log"; then
      status=$?
    fi
  fi

  if [[ $status -ne 0 ]]; then
    rm -f "$log" "$json"
    return $status
  fi

  if [[ ! -s "$json" ]]; then
    rm -f "$json"
  fi

  MODULE_SCAFFOLD_LOG_PATH="$log"
  return 0
}

run_module_scaffold() {
