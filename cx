detect_python_manager() {
  if command -v poetry >/dev/null 2>&1; then
    if [[ -f poetry.lock ]]; then
      printf 'poetry'
      return 0
    fi
    if [[ -f pyproject.toml ]] && grep -q '\[tool\.poetry\]' pyproject.toml; then
      printf 'poetry'
      return 0
    fi
  fi
  if command -v pipenv >/dev/null 2>&1 && [[ -f Pipfile ]]; then
    printf 'pipenv'
    return 0
  fi
  if python_has_pip; then
    if [[ -f requirements.txt || -f requirements-dev.txt || -f dev-requirements.txt ]]; then
      printf 'pip'
      return 0
    fi
    if [[ -f pyproject.toml || -f setup.py || -f setup.cfg ]]; then
      printf 'pip'
      return 0
    fi
  fi
  return 1
}

