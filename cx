def severity_rank(label: str) -> int:
    return severity_weights.get((label or '').lower(), 1)


def register_mitigation(category, language, component, action, severity, details=None, status=None):
    component_label = nice(component)
    severity = (severity or 'medium').lower()
    details = list(dict.fromkeys(details or []))
    if category == 'automated':
        status = (status or 'pending').lower()
    else:
        status = (status or 'planned').lower()

    key = (category, language, component_label, action)
    existing = _mitigation_index.get(key)
    if existing:
        if severity_rank(severity) > severity_rank(existing.get('severity')):
            existing['severity'] = severity
        if details:
            current = existing.setdefault('details', [])
            for item in details:
                if item not in current:
                    current.append(item)
        if category == 'automated' and status != existing.get('status'):
            # Promote status but avoid downgrading completed work back to pending.
            current_rank = {'satisfied': 3, 'completed': 3, 'pending': 1}.get(existing.get('status'), 1)
            new_rank = {'satisfied': 3, 'completed': 3, 'pending': 1}.get(status, 1)
            if new_rank >= current_rank:
                existing['status'] = status
        return existing

    entry = {
        'language': language,
        'component': component_label,
        'action': action,
        'severity': severity,
    }
    if details:
        entry['details'] = details
    entry['status'] = status
    mitigation_plan[category].append(entry)
    _mitigation_index[key] = entry
    return entry


