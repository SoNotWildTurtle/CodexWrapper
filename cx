        if age < min_age_seconds:
            continue
        rows.append((age, commit_time, commit_hash, author, path))
    rows.sort(key=lambda item: item[0], reverse=True)
    print("Age(days)  Last Commit  Commit  Author  Path")
    if not rows:
        print(f"No tracked files older than {min_age} days.")
        return 0
    for age, commit_time, commit_hash, author, path in rows[:limit]:
        age_days = age // 86400
        commit_date = datetime.fromtimestamp(commit_time, tz=timezone.utc).strftime("%Y-%m-%d")
        short_hash = commit_hash[:7]
        print(f"{age_days:>9}  {commit_date}  {short_hash:<7}  {author}  {path}")
    return 0


