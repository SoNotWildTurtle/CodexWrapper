run_project_actions() {
  local status=0
  local ran_any=false

  if command -v git >/dev/null 2>&1 && git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    run_baseline_step "Git status summary" git status -sb || status=1
    ran_any=true
  fi

  local node_manager
  if node_manager=$(detect_node_manager); then
    local manager_label=$node_manager
    if ! $SKIP_INSTALL && ! node_dependencies_ready; then
      run_baseline_step "Install Node dependencies ($manager_label)" run_node_install "$node_manager" || status=1
      ran_any=true
    elif $SKIP_INSTALL && ! node_dependencies_ready; then
      echo ">>> Skipping Node dependency installation ($manager_label) because CX_START_SKIP_INSTALL is set" >&2
    fi
    if npm_has_script lint; then
      run_baseline_step "Run $manager_label lint script" run_node_script "$node_manager" "lint" || status=1
      ran_any=true
    fi
    if npm_has_script test; then
      if ! $SKIP_TESTS; then
        run_baseline_step "Run $manager_label test script" run_node_script "$node_manager" "test" || status=1
        ran_any=true
      else
        echo ">>> Skipping $manager_label test script because CX_START_SKIP_TESTS is set" >&2
      fi
    fi
  elif [[ -f package.json ]]; then
    echo ">>> Detected package.json but no supported Node package manager (npm, yarn, pnpm, bun) was found" >&2
  fi

  if ruby_project_present; then
    if command -v bundle >/dev/null 2>&1; then
      if ! $SKIP_INSTALL; then
        run_baseline_step "Install Ruby gems (bundle)" run_bundle_install || status=1
        ran_any=true
      else
        echo ">>> Skipping bundle install because CX_START_SKIP_INSTALL is set" >&2
      fi
      if ! $SKIP_TESTS; then
        if bundle_rspec_available && [[ -d spec ]]; then
          run_baseline_step "Run bundle exec rspec" bundle exec rspec || status=1
          ran_any=true
        elif bundle_has_task test; then
          run_baseline_step "Run bundle exec rake test" bundle exec rake test || status=1
          ran_any=true
        elif bundle_has_task spec; then
          run_baseline_step "Run bundle exec rake spec" bundle exec rake spec || status=1
          ran_any=true
        fi
      else
        echo ">>> Skipping Ruby test commands because CX_START_SKIP_TESTS is set" >&2
      fi
    else
      echo ">>> Detected Gemfile but the bundle command is unavailable" >&2
    fi
  fi

  if composer_project_present; then
    if command -v composer >/dev/null 2>&1; then
      if ! $SKIP_INSTALL; then
        run_baseline_step "Install PHP dependencies (composer)" composer install --no-interaction || status=1
        ran_any=true
      else
        echo ">>> Skipping composer install because CX_START_SKIP_INSTALL is set" >&2
      fi
      if ! $SKIP_TESTS; then
        if composer_has_script test; then
          run_baseline_step "Run composer test script" run_composer_script test || status=1
          ran_any=true
        elif [[ -x vendor/bin/phpunit ]]; then
          run_baseline_step "Run vendor/bin/phpunit" vendor/bin/phpunit || status=1
          ran_any=true
        fi
      else
        echo ">>> Skipping composer test commands because CX_START_SKIP_TESTS is set" >&2
      fi
    else
      echo ">>> Detected composer.json but composer is not installed" >&2
    fi
  fi

  if mix_project_present; then
    if command -v mix >/dev/null 2>&1; then
      if ! $SKIP_INSTALL; then
        run_baseline_step "Install Elixir dependencies (mix deps.get)" mix deps.get || status=1
        ran_any=true
      else
        echo ">>> Skipping mix deps.get because CX_START_SKIP_INSTALL is set" >&2
      fi
      if mix_tests_present; then
        if ! $SKIP_TESTS; then
          run_baseline_step "Run mix test" mix test || status=1
          ran_any=true
        else
          echo ">>> Skipping mix test because CX_START_SKIP_TESTS is set" >&2
        fi
      fi
    else
      echo ">>> Detected mix.exs but the mix command is unavailable" >&2
    fi
  fi

  if stack_project_present; then
    if command -v stack >/dev/null 2>&1; then
      if ! $SKIP_INSTALL; then
        run_baseline_step "Install Haskell dependencies (stack build --only-dependencies)" stack build --only-dependencies || status=1
        ran_any=true
      else
        echo ">>> Skipping stack build --only-dependencies because CX_START_SKIP_INSTALL is set" >&2
      fi
      if stack_tests_present; then
        if ! $SKIP_TESTS; then
          run_baseline_step "Run stack test" stack test || status=1
          ran_any=true
        else
          echo ">>> Skipping stack test because CX_START_SKIP_TESTS is set" >&2
        fi
      fi
    else
      echo ">>> Detected stack.yaml but the stack command is unavailable" >&2
    fi
  fi

  if cabal_project_present; then
    if command -v cabal >/dev/null 2>&1; then
      if ! $SKIP_INSTALL; then
        run_baseline_step "Prepare Haskell dependencies (cabal v2-build --only-dependencies)" cabal v2-build --only-dependencies || status=1
        ran_any=true
      else
        echo ">>> Skipping cabal v2-build --only-dependencies because CX_START_SKIP_INSTALL is set" >&2
      fi
      if cabal_tests_present; then
        if ! $SKIP_TESTS; then
          run_baseline_step "Run cabal v2-test" cabal v2-test || status=1
          ran_any=true
        else
          echo ">>> Skipping cabal v2-test because CX_START_SKIP_TESTS is set" >&2
        fi
      fi
    else
      echo ">>> Detected Cabal files but the cabal command is unavailable" >&2
    fi
  fi

  if swift_package_present; then
    if command -v swift >/dev/null 2>&1; then
      if ! $SKIP_INSTALL; then
        run_baseline_step "Resolve Swift package dependencies" swift package resolve || status=1
        ran_any=true
      else
        echo ">>> Skipping swift package resolve because CX_START_SKIP_INSTALL is set" >&2
      fi
      if swift_tests_present; then
        if ! $SKIP_TESTS; then
          run_baseline_step "Run swift test" swift test || status=1
          ran_any=true
        else
          echo ">>> Skipping swift test because CX_START_SKIP_TESTS is set" >&2
        fi
      fi
    else
      echo ">>> Detected Package.swift but the swift command is unavailable" >&2
    fi
  fi

  if sbt_project_present; then
    if command -v sbt >/dev/null 2>&1; then
      if ! $SKIP_INSTALL; then
        run_baseline_step "Warm sbt dependencies" sbt update || status=1
        ran_any=true
      else
        echo ">>> Skipping sbt update because CX_START_SKIP_INSTALL is set" >&2
      fi
      if sbt_tests_present; then
        if ! $SKIP_TESTS; then
          run_baseline_step "Run sbt test" sbt test || status=1
          ran_any=true
        else
          echo ">>> Skipping sbt test because CX_START_SKIP_TESTS is set" >&2
        fi
      fi
    else
      echo ">>> Detected sbt build files but sbt is not installed" >&2
    fi
  fi

  if flutter_project_present; then
    if command -v flutter >/dev/null 2>&1; then
      if ! $SKIP_INSTALL; then
        run_baseline_step "Fetch Flutter dependencies" flutter pub get || status=1
        ran_any=true
      else
        echo ">>> Skipping flutter pub get because CX_START_SKIP_INSTALL is set" >&2
      fi
      if flutter_tests_present; then
        if ! $SKIP_TESTS; then
          run_baseline_step "Run flutter test" flutter test || status=1
          ran_any=true
        else
          echo ">>> Skipping flutter test because CX_START_SKIP_TESTS is set" >&2
        fi
      fi
    else
      echo ">>> Detected Flutter pubspec but the flutter command is unavailable" >&2
    fi
  elif dart_project_present; then
    if command -v dart >/dev/null 2>&1; then
      if ! $SKIP_INSTALL; then
        run_baseline_step "Fetch Dart dependencies" dart pub get || status=1
        ran_any=true
      else
        echo ">>> Skipping dart pub get because CX_START_SKIP_INSTALL is set" >&2
      fi
      if dart_tests_present; then
        if ! $SKIP_TESTS; then
          run_baseline_step "Run dart test" dart test || status=1
          ran_any=true
        else
          echo ">>> Skipping dart test because CX_START_SKIP_TESTS is set" >&2
        fi
      fi
    else
      echo ">>> Detected Dart pubspec but the dart command is unavailable" >&2
    fi
  fi

  local python_manager
  if python_manager=$(detect_python_manager); then
    local python_label
    case "$python_manager" in
      poetry) python_label="Poetry" ;;
      pipenv) python_label="Pipenv" ;;
      pip) python_label="pip" ;;
      *) python_label="$python_manager" ;;
    esac
    if ! $SKIP_INSTALL; then
      run_baseline_step "Install Python dependencies ($python_label)" run_python_install "$python_manager" || status=1
      ran_any=true
    else
      echo ">>> Skipping Python dependency installation ($python_label) because CX_START_SKIP_INSTALL is set" >&2
    fi
  else
    local poetry_hint=0
    if [[ -f poetry.lock ]]; then
      poetry_hint=1
    elif [[ -f pyproject.toml ]]; then
      if grep -q '\[tool\.poetry\]' pyproject.toml 2>/dev/null; then
        poetry_hint=1
      fi
    fi
    if (( poetry_hint )) && ! command -v poetry >/dev/null 2>&1; then
      echo ">>> Detected Poetry configuration but the poetry command is unavailable" >&2
    elif [[ -f Pipfile ]] && ! command -v pipenv >/dev/null 2>&1; then
      echo ">>> Detected Pipfile but pipenv is not installed" >&2
    elif [[ -f requirements.txt || -f requirements-dev.txt || -f dev-requirements.txt || -f setup.py || -f setup.cfg || -f pyproject.toml ]] && ! command -v python3 >/dev/null 2>&1; then
      echo ">>> Detected Python requirements but python3 is not installed" >&2
    elif [[ -f requirements.txt || -f requirements-dev.txt || -f dev-requirements.txt || -f setup.py || -f setup.cfg || -f pyproject.toml ]] && ! python_has_pip; then
      echo ">>> Python is available but pip is missing; install pip to automate dependency setup" >&2
    fi
  fi

  if command -v python3 >/dev/null 2>&1; then
    local ran_python_suite=false
    if [[ -f tox.ini ]]; then
      if ! $SKIP_TESTS; then
        if command -v tox >/dev/null 2>&1; then
          run_baseline_step "Run tox test suite" tox -q || status=1
          ran_any=true
          ran_python_suite=true
        elif python_module_available tox; then
          run_baseline_step "Run tox test suite" python3 -m tox -q || status=1
          ran_any=true
          ran_python_suite=true
        else
          echo ">>> Skipping tox run because the tox module is not installed" >&2
        fi
      else
        echo ">>> Skipping tox test suite because CX_START_SKIP_TESTS is set" >&2
      fi
    fi
    if ! $SKIP_TESTS && ! $ran_python_suite && python_tests_present; then
      if python_module_available pytest; then
        run_baseline_step "Run pytest" python3 -m pytest -q || status=1
        ran_any=true
      else
        echo ">>> Skipping pytest run because the pytest module is not installed" >&2
      fi
    elif python_tests_present && $SKIP_TESTS; then
      echo ">>> Skipping pytest run because CX_START_SKIP_TESTS is set" >&2
    fi
  fi

  if precommit_config_present; then
    if command -v pre-commit >/dev/null 2>&1; then
      if ! $SKIP_INSTALL; then
        if git_repository_present; then
          run_baseline_step "Install pre-commit hooks" pre-commit install --install-hooks || status=1
          ran_any=true
        else
          echo ">>> Skipping pre-commit install because a git repository was not detected" >&2
        fi
      else
        echo ">>> Skipping pre-commit install because CX_START_SKIP_INSTALL is set" >&2
      fi
      if ! $SKIP_TESTS; then
        run_baseline_step "Run pre-commit checks" pre-commit run --all-files || status=1
        ran_any=true
      else
        echo ">>> Skipping pre-commit checks because CX_START_SKIP_TESTS is set" >&2
      fi
    else
      echo ">>> Detected pre-commit configuration but the pre-commit command is unavailable" >&2
    fi
  fi

  if justfile_present; then
    if command -v just >/dev/null 2>&1; then
      if ! $SKIP_INSTALL && just_has_recipe install; then
        run_baseline_step "Run just install" just install || status=1
        ran_any=true
      elif $SKIP_INSTALL && just_has_recipe install; then
        echo ">>> Skipping just install because CX_START_SKIP_INSTALL is set" >&2
      fi
      if just_has_recipe lint; then
        if ! $SKIP_TESTS; then
          run_baseline_step "Run just lint" just lint || status=1
          ran_any=true
        else
          echo ">>> Skipping just lint because CX_START_SKIP_TESTS is set" >&2
        fi
      fi
      if just_has_recipe test; then
        if ! $SKIP_TESTS; then
          run_baseline_step "Run just test" just test || status=1
          ran_any=true
        else
          echo ">>> Skipping just test because CX_START_SKIP_TESTS is set" >&2
        fi
      fi
    else
      echo ">>> Detected Justfile but the just command is unavailable" >&2
    fi
  fi

  if taskfile_present; then
    if command -v task >/dev/null 2>&1; then
      if ! $SKIP_INSTALL && task_has_target install; then
        run_baseline_step "Run task install" task install || status=1
        ran_any=true
      elif $SKIP_INSTALL && task_has_target install; then
        echo ">>> Skipping task install because CX_START_SKIP_INSTALL is set" >&2
      fi
      if task_has_target lint; then
        if ! $SKIP_TESTS; then
          run_baseline_step "Run task lint" task lint || status=1
          ran_any=true
        else
          echo ">>> Skipping task lint because CX_START_SKIP_TESTS is set" >&2
        fi
      fi
      if task_has_target test; then
        if ! $SKIP_TESTS; then
          run_baseline_step "Run task test" task test || status=1
          ran_any=true
        else
          echo ">>> Skipping task test because CX_START_SKIP_TESTS is set" >&2
        fi
      fi
    else
      echo ">>> Detected Taskfile but the task command is unavailable" >&2
    fi
  fi

  if bazel_project_present; then
    local bazel_cmd
    if bazel_cmd=$(bazel_command); then
      local bazel_label
      bazel_label=$(basename "$bazel_cmd")
      if ! $SKIP_INSTALL; then
        local -a bazel_build_cmd=(build)
        if [[ -n "${CX_START_BAZEL_BUILD_ARGS:-}" ]]; then
          # shellcheck disable=SC2206
          bazel_build_cmd+=(${CX_START_BAZEL_BUILD_ARGS})
        fi
        local -a bazel_build_targets=(//...)
        if [[ -n "${CX_START_BAZEL_BUILD_TARGETS:-}" ]]; then
          # shellcheck disable=SC2206
          bazel_build_targets=(${CX_START_BAZEL_BUILD_TARGETS})
        fi
        if (( ${#bazel_build_targets[@]} )); then
          local bazel_target
          for bazel_target in "${bazel_build_targets[@]}"; do
            bazel_build_cmd+=("$bazel_target")
          done
          local build_desc="${bazel_build_targets[*]}"
          run_baseline_step "Run ${bazel_label} build ${build_desc}" "$bazel_cmd" "${bazel_build_cmd[@]}" || status=1
          ran_any=true
        else
          echo ">>> Skipping Bazel build because CX_START_BAZEL_BUILD_TARGETS provided no targets" >&2
        fi
      else
        echo ">>> Skipping Bazel build because CX_START_SKIP_INSTALL is set" >&2
      fi
      if ! $SKIP_TESTS; then
        local -a bazel_test_cmd=(test)
        if [[ -n "${CX_START_BAZEL_TEST_ARGS:-}" ]]; then
          # shellcheck disable=SC2206
          bazel_test_cmd+=(${CX_START_BAZEL_TEST_ARGS})
        fi
        local -a bazel_test_targets=(//...)
        if [[ -n "${CX_START_BAZEL_TEST_TARGETS:-}" ]]; then
          # shellcheck disable=SC2206
          bazel_test_targets=(${CX_START_BAZEL_TEST_TARGETS})
        fi
        if (( ${#bazel_test_targets[@]} )); then
          local bazel_test_target
          for bazel_test_target in "${bazel_test_targets[@]}"; do
            bazel_test_cmd+=("$bazel_test_target")
          done
          local test_desc="${bazel_test_targets[*]}"
          run_baseline_step "Run ${bazel_label} test ${test_desc}" "$bazel_cmd" "${bazel_test_cmd[@]}" || status=1
          ran_any=true
        else
          echo ">>> Skipping Bazel tests because CX_START_BAZEL_TEST_TARGETS provided no targets" >&2
        fi
      else
        echo ">>> Skipping Bazel tests because CX_START_SKIP_TESTS is set" >&2
      fi
    else
      echo ">>> Detected Bazel workspace but no bazel/bazelisk/bazelw command is available" >&2
    fi
  fi

  if pants_project_present; then
    local pants_cmd
    if pants_cmd=$(pants_command); then
      if ! $SKIP_INSTALL; then
        local -a pants_deps_args=()
        if [[ -n "${CX_START_PANTS_DEPS_ARGS:-}" ]]; then
          # shellcheck disable=SC2206
          pants_deps_args+=(${CX_START_PANTS_DEPS_ARGS})
        fi
        local -a pants_deps_targets=(::)
        if [[ -n "${CX_START_PANTS_DEPS_TARGETS:-}" ]]; then
          # shellcheck disable=SC2206
          pants_deps_targets=(${CX_START_PANTS_DEPS_TARGETS})
        fi
        if (( ${#pants_deps_targets[@]} )); then
          run_baseline_step "Run Pants dependencies ${pants_deps_targets[*]}" "$pants_cmd" "${pants_deps_args[@]}" dependencies "${pants_deps_targets[@]}" || status=1
          ran_any=true
        else
          echo ">>> Skipping Pants dependencies because CX_START_PANTS_DEPS_TARGETS provided no targets" >&2
        fi
      else
        echo ">>> Skipping Pants dependencies because CX_START_SKIP_INSTALL is set" >&2
      fi
      if ! $SKIP_TESTS; then
        local -a pants_lint_args=()
        if [[ -n "${CX_START_PANTS_LINT_ARGS:-}" ]]; then
          # shellcheck disable=SC2206
          pants_lint_args+=(${CX_START_PANTS_LINT_ARGS})
        fi
        local -a pants_lint_targets=(::)
        if [[ -n "${CX_START_PANTS_LINT_TARGETS:-}" ]]; then
          # shellcheck disable=SC2206
          pants_lint_targets=(${CX_START_PANTS_LINT_TARGETS})
        fi
        if (( ${#pants_lint_targets[@]} )); then
          run_baseline_step "Run Pants lint ${pants_lint_targets[*]}" "$pants_cmd" "${pants_lint_args[@]}" lint "${pants_lint_targets[@]}" || status=1
          ran_any=true
        else
          echo ">>> Skipping Pants lint because CX_START_PANTS_LINT_TARGETS provided no targets" >&2
        fi
        local -a pants_test_args=()
        if [[ -n "${CX_START_PANTS_TEST_ARGS:-}" ]]; then
          # shellcheck disable=SC2206
          pants_test_args+=(${CX_START_PANTS_TEST_ARGS})
        fi
        local -a pants_test_targets=(::)
        if [[ -n "${CX_START_PANTS_TEST_TARGETS:-}" ]]; then
          # shellcheck disable=SC2206
          pants_test_targets=(${CX_START_PANTS_TEST_TARGETS})
        fi
        if (( ${#pants_test_targets[@]} )); then
          run_baseline_step "Run Pants test ${pants_test_targets[*]}" "$pants_cmd" "${pants_test_args[@]}" test "${pants_test_targets[@]}" || status=1
          ran_any=true
        else
          echo ">>> Skipping Pants tests because CX_START_PANTS_TEST_TARGETS provided no targets" >&2
        fi
      else
        echo ">>> Skipping Pants lint/test because CX_START_SKIP_TESTS is set" >&2
      fi
    else
      echo ">>> Detected Pants configuration but no pants launcher was found" >&2
    fi
  fi

  if command -v make >/dev/null 2>&1; then
    if has_make_target lint; then
      run_baseline_step "Run make lint" make lint || status=1
      ran_any=true
    fi
    if has_make_target test; then
      if ! $SKIP_TESTS; then
        run_baseline_step "Run make test" make test || status=1
        ran_any=true
      else
        echo ">>> Skipping make test because CX_START_SKIP_TESTS is set" >&2
      fi
    fi
  fi

  if [[ -f go.mod ]] && command -v go >/dev/null 2>&1; then
    if ! $SKIP_TESTS; then
      run_baseline_step "Run go test ./..." go test ./... || status=1
      ran_any=true
    else
      echo ">>> Skipping go test ./... because CX_START_SKIP_TESTS is set" >&2
    fi
  fi

  if [[ -f Cargo.toml ]] && command -v cargo >/dev/null 2>&1; then
    if ! $SKIP_TESTS; then
      run_baseline_step "Run cargo test" cargo test || status=1
      ran_any=true
    else
      echo ">>> Skipping cargo test because CX_START_SKIP_TESTS is set" >&2
    fi
  fi

  if dotnet_project_present; then
    if command -v dotnet >/dev/null 2>&1; then
      if ! $SKIP_INSTALL; then
        run_baseline_step "Run dotnet restore" dotnet restore || status=1
        ran_any=true
      else
        echo ">>> Skipping dotnet restore because CX_START_SKIP_INSTALL is set" >&2
      fi
      if ! $SKIP_TESTS; then
        run_baseline_step "Run dotnet test" dotnet test || status=1
        ran_any=true
      else
        echo ">>> Skipping dotnet test because CX_START_SKIP_TESTS is set" >&2
      fi
    else
      echo ">>> Detected .NET solution or project files but the dotnet CLI is unavailable" >&2
    fi
  fi

  if maven_project_present; then
    if command -v mvn >/dev/null 2>&1; then
      if ! $SKIP_INSTALL; then
        run_baseline_step "Prepare Maven dependencies" mvn -B dependency:go-offline || status=1
        ran_any=true
      else
        echo ">>> Skipping Maven dependency warmup because CX_START_SKIP_INSTALL is set" >&2
      fi
      if ! $SKIP_TESTS; then
        run_baseline_step "Run mvn test" mvn -B test || status=1
        ran_any=true
      else
        echo ">>> Skipping mvn test because CX_START_SKIP_TESTS is set" >&2
      fi
    else
      echo ">>> Detected pom.xml but Maven (mvn) is not installed" >&2
    fi
  fi

  if gradle_project_present; then
    local -a gradle_cmd=()
    if [[ -f gradlew ]]; then
      if [[ -x gradlew ]]; then
        gradle_cmd=(./gradlew)
      else
        gradle_cmd=(bash ./gradlew)
      fi
    elif command -v gradle >/dev/null 2>&1; then
      gradle_cmd=(gradle)
    fi
    if (( ${#gradle_cmd[@]} )); then
      if ! $SKIP_TESTS; then
        run_baseline_step "Run Gradle tests" "${gradle_cmd[@]}" test || status=1
        ran_any=true
      else
        echo ">>> Skipping Gradle tests because CX_START_SKIP_TESTS is set" >&2
      fi
    else
      echo ">>> Detected Gradle build files but gradle/gradlew is not available" >&2
    fi
  fi

  if cmake_project_present; then
    if command -v cmake >/dev/null 2>&1; then
      local build_dir
      build_dir=$(cmake_build_dir)
      local configure_ok=false
      if ! $SKIP_INSTALL; then
        if run_baseline_step "Configure CMake project ($build_dir)" run_cmake_configure; then
          configure_ok=true
        else
          status=1
        fi
        ran_any=true
        if $configure_ok; then
          run_baseline_step "Build CMake project ($build_dir)" run_cmake_build || status=1
          ran_any=true
        fi
      else
        echo ">>> Skipping CMake configure/build because CX_START_SKIP_INSTALL is set" >&2
      fi
      if ! $SKIP_TESTS; then
        if command -v ctest >/dev/null 2>&1; then
          if cmake_ctest_ready; then
            run_baseline_step "Run ctest ($build_dir)" run_ctest_suite || status=1
            ran_any=true
          else
            echo ">>> Skipping ctest because $build_dir has no CTest configuration yet; run cmake configure/build first" >&2
          fi
        else
          echo ">>> Detected CMake project but the ctest command is unavailable" >&2
        fi
      else
        echo ">>> Skipping ctest because CX_START_SKIP_TESTS is set" >&2
      fi
    else
      echo ">>> Detected CMakeLists.txt but cmake is not installed" >&2
    fi
  fi

  local extra_install=${CX_START_EXTRA_INSTALL-}
  if [[ -n ${extra_install//[[:space:]]/} ]]; then
    if ! $SKIP_INSTALL; then
      run_custom_block "Custom install" "$extra_install" || status=1
      if $CUSTOM_BLOCK_LAST_RAN; then
        ran_any=true
      fi
    else
      echo ">>> Skipping custom install commands because CX_START_SKIP_INSTALL is set" >&2
    fi
  fi

  local extra_test=${CX_START_EXTRA_TEST-}
  if [[ -n ${extra_test//[[:space:]]/} ]]; then
    if ! $SKIP_TESTS; then
      run_custom_block "Custom test" "$extra_test" || status=1
      if $CUSTOM_BLOCK_LAST_RAN; then
        ran_any=true
      fi
    else
      echo ">>> Skipping custom test commands because CX_START_SKIP_TESTS is set" >&2
    fi
  fi

  local extra_steps=${CX_START_EXTRA_STEPS-}
  if [[ -n ${extra_steps//[[:space:]]/} ]]; then
    run_custom_block "Custom start" "$extra_steps" || status=1
    if $CUSTOM_BLOCK_LAST_RAN; then
      ran_any=true
    fi
  fi

  if ! $ran_any; then
    echo ">>> No additional project-specific actions detected" >&2
  fi

  return $status
}

collect_formatter_files() {
  local -a patterns=("$@")
  (( ${#patterns[@]} )) || return 0
  if command -v git >/dev/null 2>&1 && git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    git ls-files -- "${patterns[@]}" 2>/dev/null | sort -u
  else
    local pattern
    for pattern in "${patterns[@]}"; do
      find . -type f -name "$pattern" -print
    done | sort -u
  fi
}

run_formatter_suite() {
  local status=0
  local log_dir="$CX_HOME/format"
  mkdir -p "$log_dir"
  local log_file="$log_dir/$project.log"
  local sweep_stamp
  sweep_stamp=$(date -u +%Y-%m-%dT%H:%M:%SZ)
  printf '[%s] formatter sweep started\n' "$sweep_stamp" >> "$log_file"

  local ran_any=false
  local -a skip_notes=()
  local -a success_notes=()
  local -a failure_notes=()

  run_formatter() {
    local name=$1
    shift
    local -a cmd=("$@")
    ran_any=true
    local step_stamp
    step_stamp=$(date -u +%Y-%m-%dT%H:%M:%SZ)
    local display
    printf -v display '%q ' "${cmd[@]}"
    display=${display%% }
    echo ">>> Running formatter: $name" >&2
    printf '[%s] >>> %s command: %s\n' "$step_stamp" "$name" "$display" >> "$log_file"
    if "${cmd[@]}" 2>&1 | tee -a "$log_file"; then
      success_notes+=("$name")
      printf '[%s] <<< %s success\n' "$step_stamp" "$name" >> "$log_file"
      echo ">>> Formatter $name completed" >&2
    else
      local rc=${PIPESTATUS[0]:-1}
      failure_notes+=("$name (exit $rc)")
      printf '[%s] <<< %s failed (exit %s)\n' "$step_stamp" "$name" "$rc" >> "$log_file"
      echo ">>> Formatter $name failed (exit $rc)" >&2
      status=1
    fi
  }

  record_skip() {
    local note=$1
    local stamp
    stamp=$(date -u +%Y-%m-%dT%H:%M:%SZ)
    skip_notes+=("$note")
    printf '[%s] >>> skipped: %s\n' "$stamp" "$note" >> "$log_file"
  }

  if command -v shfmt >/dev/null 2>&1; then
    local -a shell_files=()
    mapfile -t shell_files < <(collect_formatter_files '*.sh')
    if (( ${#shell_files[@]} )); then
      run_formatter "shfmt" shfmt -w "${shell_files[@]}"
    else
      record_skip "shfmt (no shell scripts)"
    fi
  else
    record_skip "shfmt (command not found)"
  fi

  local -a py_files=()
  mapfile -t py_files < <(collect_formatter_files '*.py' '*.pyw')
  if command -v black >/dev/null 2>&1; then
    if (( ${#py_files[@]} )); then
      run_formatter "black" black --quiet "${py_files[@]}"
    else
      record_skip "black (no Python files)"
    fi
  else
    record_skip "black (command not found)"
  fi

  if command -v isort >/dev/null 2>&1; then
    if (( ${#py_files[@]} )); then
      run_formatter "isort" isort "${py_files[@]}"
    else
      record_skip "isort (no Python files)"
    fi
  else
    record_skip "isort (command not found)"
  fi

  if command -v ruff >/dev/null 2>&1; then
    if (( ${#py_files[@]} )); then
      run_formatter "ruff" ruff check --fix "${py_files[@]}"
    else
      record_skip "ruff (no Python files)"
    fi
  else
    record_skip "ruff (command not found)"
  fi

  local -a go_files=()
  mapfile -t go_files < <(collect_formatter_files '*.go')
  if command -v goimports >/dev/null 2>&1; then
    if (( ${#go_files[@]} )); then
      run_formatter "goimports" goimports -w "${go_files[@]}"
    else
      record_skip "goimports (no Go files)"
    fi
  else
    record_skip "goimports (command not found)"
  fi

  if command -v gofmt >/dev/null 2>&1; then
    if (( ${#go_files[@]} )); then
      run_formatter "gofmt" gofmt -w "${go_files[@]}"
    else
      record_skip "gofmt (no Go files)"
    fi
  else
    record_skip "gofmt (command not found)"
  fi

  local -a rs_files=()
  if [[ -f Cargo.toml ]]; then
    if command -v cargo >/dev/null 2>&1; then
      run_formatter "cargo fmt" cargo fmt
    elif command -v rustfmt >/dev/null 2>&1; then
      mapfile -t rs_files < <(collect_formatter_files '*.rs')
      if (( ${#rs_files[@]} )); then
        run_formatter "rustfmt" rustfmt "${rs_files[@]}"
      else
        record_skip "rustfmt (no Rust files)"
      fi
    else
      record_skip "cargo fmt (cargo/rustfmt not found)"
    fi
  else
    mapfile -t rs_files < <(collect_formatter_files '*.rs')
    if (( ${#rs_files[@]} )); then
      if command -v rustfmt >/dev/null 2>&1; then
        run_formatter "rustfmt" rustfmt "${rs_files[@]}"
      else
        record_skip "rustfmt (command not found)"
      fi
    fi
  fi

  local -a prettier_candidates=()
  mapfile -t prettier_candidates < <(collect_formatter_files '*.js' '*.jsx' '*.ts' '*.tsx' '*.mjs' '*.cjs' '*.json' '*.css' '*.scss' '*.md')
  if (( ${#prettier_candidates[@]} )); then
    local prettier_cmd=""
    if [[ -x node_modules/.bin/prettier ]]; then
      prettier_cmd=node_modules/.bin/prettier
    elif command -v prettier >/dev/null 2>&1; then
      prettier_cmd=$(command -v prettier)
    fi
    if [[ -n "$prettier_cmd" ]]; then
      run_formatter "prettier" "$prettier_cmd" --write "${prettier_candidates[@]}"
    else
      record_skip "prettier (command not found; install prettier locally)"
    fi
  else
    record_skip "prettier (no matching files)"
  fi

  if command -v terraform >/dev/null 2>&1; then
    if compgen -G "*.tf" >/dev/null 2>&1 || compgen -G "*.tf.json" >/dev/null 2>&1; then
      run_formatter "terraform fmt" terraform fmt -recursive
    else
      record_skip "terraform fmt (no Terraform files)"
    fi
  else
    record_skip "terraform fmt (terraform not found)"
  fi

  local -a clang_files=()
  mapfile -t clang_files < <(collect_formatter_files '*.c' '*.cc' '*.cpp' '*.cxx' '*.h' '*.hh' '*.hpp' '*.hxx')
  if (( ${#clang_files[@]} )); then
    if command -v clang-format >/dev/null 2>&1; then
      run_formatter "clang-format" clang-format -i "${clang_files[@]}"
    else
      record_skip "clang-format (command not found)"
    fi
  else
    record_skip "clang-format (no C/C++ sources)"
  fi

  if $ran_any; then
    if (( ${#failure_notes[@]} )); then
      echo "Formatter sweep completed with issues. Review $log_file for details." >&2
    else
      echo "Formatter sweep complete. Results logged to $log_file." >&2
    fi
  else
    echo "No formatter commands were executed. See $log_file for skip details." >&2
  fi

  {
    echo "Summary:"
    if (( ${#success_notes[@]} )); then
      printf '  - succeeded: %s\n' "${success_notes[*]}"
    fi
    if (( ${#failure_notes[@]} )); then
      printf '  - failed: %s\n' "${failure_notes[*]}"
    fi
    if (( ${#skip_notes[@]} )); then
      printf '  - skipped: %s\n' "${skip_notes[*]}"
    fi
    echo
  } >> "$log_file"

  return $status
}

run_depscan_suite() {
  local status=0
  local log_dir="$CX_HOME/depscan"
  mkdir -p "$log_dir"
  local log_file="$log_dir/$project.log"
  local timestamp
  timestamp=$(date -u +%Y-%m-%dT%H:%M:%SZ)
  local tmp
  tmp=$(mktemp)
  local ran_any=false

  {
    echo "# Dependency scan ($timestamp UTC)"
    echo
  } >"$tmp"

  depscan_run_section() {
    local title=$1
    shift
    local -a cmd=("$@")
    ran_any=true
    {
      echo "## $title"
      if (( ${#cmd[@]} )); then
        local display
        printf -v display '%q ' "${cmd[@]}"
        display=${display%% }
        printf '$ %s\n' "$display"
      fi
    } >>"$tmp"
    local output
    if output=$("${cmd[@]}" 2>&1); then
      if [[ -z ${output//[[:space:]]/} ]]; then
        echo "(no outdated dependencies reported)" >>"$tmp"
      else
        printf '%s\n' "$output" >>"$tmp"
      fi
    else
      local rc=$?
      if [[ -n ${output//[[:space:]]/} ]]; then
        printf '%s\n' "$output" >>"$tmp"
      else
        echo "(command produced no output)" >>"$tmp"
      fi
      echo "(command exited with $rc)" >>"$tmp"
      status=1
    fi
    echo >>"$tmp"
  }

  depscan_note_skip() {
    local title=$1
    local message=$2
    {
      echo "## $title"
      echo "$message"
      echo
    } >>"$tmp"
  }

  local node_manager=""
  if node_manager=$(detect_node_manager); then
    case "$node_manager" in
      npm)
        depscan_run_section "Node dependencies via npm" npm outdated
        ;;
      yarn)
        depscan_run_section "Node dependencies via yarn" yarn outdated
        ;;
      pnpm)
        depscan_run_section "Node dependencies via pnpm" pnpm outdated
        ;;
      bun)
        depscan_run_section "Node dependencies via bun" bun outdated
        ;;
      *)
        depscan_note_skip "Node dependencies" "Detected package.json but no supported outdated command for $node_manager."
        ;;
    esac
  elif [[ -f package.json ]]; then
    depscan_note_skip "Node dependencies" "package.json detected but no Node package manager is installed."
  fi

  local python_manager=""
  if python_manager=$(detect_python_manager); then
    case "$python_manager" in
      poetry)
        depscan_run_section "Python dependencies via Poetry" poetry show --outdated
        ;;
      pipenv)
        depscan_run_section "Python dependencies via Pipenv" pipenv run pip list --outdated --format=columns
        ;;
      pip)
        if command -v python3 >/dev/null 2>&1; then
          depscan_run_section "Python dependencies via pip" python3 -m pip list --outdated --format=columns
        else
          depscan_note_skip "Python dependencies" "pip manifests detected but python3 is unavailable to run pip list."
        fi
        ;;
      *)
        depscan_note_skip "Python dependencies" "Detected Python manifests but no supported dependency manager was found."
        ;;
    esac
  fi

  if [[ $ran_any == false ]]; then
    depscan_note_skip "Dependency scan" "No supported dependency managers detected."
  fi

  if [[ -f "$log_file" ]]; then
    echo >>"$log_file"
  fi
  if ! cat "$tmp" | tee -a "$log_file"; then
    status=1
  fi
  rm -f "$tmp"

  if [[ $ran_any == true ]]; then
    echo "Dependency scan complete. Results logged to $log_file." >&2
  else
    echo "Dependency scan recorded skip details in $log_file." >&2
  fi

  return $status
}

