# Auto-mint domain tags for repeated phrases
auto_mint_tags() {
  if [[ -n "${CX_DISABLE_MINT:-}" ]]; then
    return 0
  fi
  local text="$1"
  local lower=$(printf '%s' "$text" | tr '[:upper:]' '[:lower:]')
  local repeats=$(printf '%s' "$lower" |
    tr -s ' ' '\n' |
    awk '{w[NR]=$0} END{for(i=1;i<NR;i++){p=w[i]" "w[i+1];c[p]++} for(p in c) if(c[p]>1) print p}')
  mapfile -t phrases <<< "$repeats"
  for phrase in "${phrases[@]}"; do
    [[ -z "$phrase" ]] && continue
    local found=0
    for val in "${DICT[@]}"; do
      if [[ "$val" == "$phrase" ]]; then
        found=1
        break
      fi
    done
    [[ $found -eq 1 ]] && continue
    read -p "Mint tag for \"$phrase\"? Enter @tag or blank to skip: " tag
    if [[ $tag == @* ]]; then
      mkdir -p "$PROJECT_DOT_CX"
      echo "$tag=$phrase" >> "$PROJECT_DICT"
      DICT["$tag"]="$phrase"
      USAGE["$tag"]=$(( ${USAGE[$tag]:-0} + 1 ))
      {
        for k in "${!USAGE[@]}"; do
          echo "$k=${USAGE[$k]}"
        done
      } | sort > "$PROJECT_USAGE"
      usage_report "$PROJECT_USAGE" "$PROJECT_DICT"
      analyze_prune "$PROJECT_DICT"
    fi
  done
}

