      top_dir=${trimmed%%/*}
    fi
    DIR_COUNTS["$top_dir"]=$(( ${DIR_COUNTS[$top_dir]:-0} + 1 ))
    DIR_LINES["$top_dir"]=$(( ${DIR_LINES[$top_dir]:-0} + lines ))

    printf '%s\t%s\t%s\n' "$size" "$lines" "$rel" >> "$tmp_sizes"
  done < <(file_iter) || true

  inspect_dir="$CX_HOME/inspect"
