  [[ -n $rec_file ]] || return 0
  if [[ ! -w $rec_file ]]; then
    echo ">>> recommendations backlog exists but is not writable: $rec_file" >&2
    return 0
  fi

  local stamp icon outcome log_hint summary
  stamp=$(date -u +'%Y-%m-%dT%H:%M:%SZ')
  log_hint="$CX_HOME/improve/$project.log"
  if (( status == 0 )); then
    icon="✅"
    outcome="Improve sweep succeeded"
  else
    icon="⚠️"
    outcome="Improve sweep encountered issues"
  fi
  summary="- $icon [$stamp] $outcome; review $log_hint for details."

  local summary_written=false

  if command -v python3 >/dev/null 2>&1; then
    if python3 - "$rec_file" "$summary" <<'PY'
import sys
from pathlib import Path

path = Path(sys.argv[1])
entry = sys.argv[2]

text = path.read_text(encoding="utf-8")
heading = "## Auto-generated Summaries"

placeholder = "- (auto summaries will be appended here after `cx --improve` runs)"
lines = text.splitlines()
