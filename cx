      min_age=$raw_min_age
    else
      min_age=180
    fi
    raw_limit=${CX_STALE_LIMIT:-20}
    if [[ $raw_limit =~ ^[0-9]+$ && $raw_limit -gt 0 ]]; then
      stale_limit=$raw_limit
    else
      stale_limit=20
    fi
    dir="$CX_HOME/stale"
    mkdir -p "$dir"
    log="$dir/$project.log"
    timestamp=$(date -u +%Y-%m-%dT%H:%MZ)
    if [[ -z $(git rev-list -1 HEAD 2>/dev/null) ]]; then
      {
        echo "# Stale files analysis ($timestamp UTC)"
        echo "Repository has no commits yet."
      } | tee "$log"
    elif ! command -v python3 >/dev/null 2>&1; then
      echo "python3 is required for stale analysis" >&2
      status=1
    else
      if ! python3 - "$min_age" "$stale_limit" <<'PY' | tee "$log"
from datetime import datetime, timezone
import subprocess
import sys
import time

def main() -> int:
    try:
        min_age = int(sys.argv[1])
    except (IndexError, ValueError):
        min_age = 180
    try:
        limit = int(sys.argv[2])
    except (IndexError, ValueError):
        limit = 20
    if limit <= 0:
        limit = 20
    now = int(time.time())
    min_age_seconds = max(0, min_age) * 86400
    try:
        tracked_raw = subprocess.check_output([
            "git",
            "ls-files",
        ], text=True)
    except subprocess.CalledProcessError as exc:
        sys.stderr.write(exc.output)
        return 1
    tracked = {
        line.strip()
        for line in tracked_raw.splitlines()
        if line.strip()
    }
    timestamp = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%MZ")
    print(f"# Stale files analysis ({timestamp} UTC)")
    print(f"# Minimum age: {min_age} days | Showing up to {limit} entries")
    if not tracked:
        print("Repository has no tracked files yet.")
        return 0
    try:
        log_raw = subprocess.check_output([
            "git",
            "log",
            "--name-only",
            "--format=%ct\t%H\t%an",
        ], text=True)
    except subprocess.CalledProcessError as exc:
        sys.stderr.write(exc.output)
        return 1
    seen = {}
    current = None
    for raw_line in log_raw.splitlines():
        stripped = raw_line.strip()
        if not stripped:
            current = None
            continue
        parts = raw_line.split('\t')
        if len(parts) >= 3 and parts[0].isdigit():
            try:
                commit_time = int(parts[0])
            except ValueError:
                current = None
                continue
            commit_hash = parts[1]
            author = parts[2]
            current = (commit_time, commit_hash, author)
            continue
        path = stripped
        if path not in tracked:
            continue
        if current and path not in seen:
            seen[path] = current
    rows = []
    for path, (commit_time, commit_hash, author) in seen.items():
        age = now - commit_time
        if age < min_age_seconds:
            continue
        rows.append((age, commit_time, commit_hash, author, path))
    rows.sort(key=lambda item: item[0], reverse=True)
    print("Age(days)  Last Commit  Commit  Author  Path")
    if not rows:
        print(f"No tracked files older than {min_age} days.")
        return 0
    for age, commit_time, commit_hash, author, path in rows[:limit]:
        age_days = age // 86400
        commit_date = datetime.fromtimestamp(commit_time, tz=timezone.utc).strftime("%Y-%m-%d")
        short_hash = commit_hash[:7]
        print(f"{age_days:>9}  {commit_date}  {short_hash:<7}  {author}  {path}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
PY
      then
        echo "Failed to analyze stale files" >&2
        status=1
      fi
    fi
  fi
  leave_project_root
  exit $status
fi

if $SHOW_INSPECT; then
