try:
    with urllib.request.urlopen(req) as resp:
        out = json.load(resp)
    print(out['choices'][0]['message']['content'])
except Exception as e:
    sys.stderr.write(str(e))
    sys.exit(1)
PY
    ); then
      printf '%s\n' "$response"
      rm "$f"
      rmdir -p "$(dirname "$f")" 2>/dev/null || true
      echo "Replayed and removed $f" >&2
    else
      echo "Failed to replay $f; leaving in queue" >&2
    fi
  done
  exit 0
fi

if $SHOW_METRICS; then
  file="$HOME/.cx/metrics/$project.log"
  if [ -f "$file" ]; then
    cat "$file"
  else
    echo "No metrics log for $project" >&2
  fi
  exit 0
fi

if $SHOW_GRID; then
  file="$HOME/.cx/grid/$project.grid"
  if [ -f "$file" ]; then
    cat "$file"
  else
    echo "No grid for $project" >&2
  fi
  exit 0
fi

if $SHOW_LINT; then
  status=0
  { git ls-files 2>/dev/null || find . -type f; } | while read -r f; do
    case "$f" in
      *.sh|cx|cx5)
        bash -n "$f" || status=1
        if command -v shellcheck >/dev/null 2>&1; then
          shellcheck "$f" || status=1
        fi
        ;;
      *.ps1)
        if command -v pwsh >/dev/null 2>&1; then
          pwsh -NoLogo -NoProfile -Command "[System.Management.Automation.Language.Parser]::ParseFile('$PWD/$f',[ref]$null,[ref]$e); if($e.Count -gt 0){$e; exit 1}" || status=1
        elif command -v powershell >/dev/null 2>&1; then
          powershell -NoLogo -NoProfile -Command "[System.Management.Automation.Language.Parser]::ParseFile('$PWD/$f',[ref]$null,[ref]$e); if($e.Count -gt 0){$e; exit 1}" || status=1
        else
          echo "Skipping $f: PowerShell not found" >&2
        fi
        ;;
      *.py)
        if command -v python >/dev/null 2>&1; then
          python -m py_compile "$f" || status=1
        else
          echo "Skipping $f: python not found" >&2
        fi
        ;;
      *.js|*.mjs|*.cjs)
        if command -v node >/dev/null 2>&1; then
          node --check "$f" >/dev/null || status=1
        else
          echo "Skipping $f: node not found" >&2
        fi
        ;;
      *.json)
        if command -v python >/dev/null 2>&1; then
          python -m json.tool "$f" >/dev/null || status=1
        else
          echo "Skipping $f: python not found" >&2
        fi
        ;;
      *.yml|*.yaml)
        if command -v python >/dev/null 2>&1; then
          if ! python - <<'PY' "$f"; then status=1; fi
import sys
try:
    import yaml
except Exception:
    sys.exit(0)
with open(sys.argv[1]) as fh:
    yaml.safe_load(fh)
PY
        else
          echo "Skipping $f: python not found" >&2
        fi
        ;;
      *.toml)
        if command -v python >/dev/null 2>&1; then
          if ! python - <<'PY' "$f"; then status=1; fi
import sys
try:
    import tomllib
except Exception:
    import tomli as tomllib
with open(sys.argv[1], 'rb') as fh:
    tomllib.load(fh)
PY
        else
          echo "Skipping $f: python not found" >&2
        fi
        ;;
    esac

    if grep -Iq . "$f"; then
      if grep -n -E '[[:space:]]$' "$f" >/dev/null; then
        if $FIX; then
          sed -i 's/[ \t]*$//' "$f"
          echo "Fixed trailing whitespace in $f" >&2
        else
          echo "Trailing whitespace in $f:" >&2
          grep -n -E '[[:space:]]$' "$f" >&2
          status=1
        fi
      fi
      last=$(tail -c1 "$f" 2>/dev/null | od -An -t u1)
      if [[ "${last//[[:space:]]/}" != "10" ]]; then
        if $FIX; then
          printf '\n' >> "$f"
          echo "Added newline at end of file: $f" >&2
        else
          echo "No newline at end of file: $f" >&2
          status=1
        fi
      fi
      if grep -nE '^(<<<<<<<|=======|>>>>>>>)' "$f" >/dev/null; then
        echo "Merge conflict markers in $f:" >&2
        grep -nE '^(<<<<<<<|=======|>>>>>>>)' "$f" >&2
        status=1
      fi
    fi
  done
  exit $status
fi

if $SHOW_AUDIT; then
  dir="$HOME/.cx/audit"
  mkdir -p "$dir"
  file="$dir/$project.log"
  {
    echo "# File line counts"
    { git ls-files 2>/dev/null || find . -type f; } | while read -r f; do
      [[ -f "$f" ]] || continue
      lines=$(wc -l < "$f")
      echo "$f $lines"
    done
    echo "# TODO/FIXME/BUG"
    if command -v rg >/dev/null 2>&1; then
      rg --color=never -n 'TODO|FIXME|BUG' || true
    else
      grep -RIn 'TODO\|FIXME\|BUG' . || true
    fi
  } | tee "$file"
  exit 0
fi

if $SHOW_HOTSPOTS; then
  if ! command -v git >/dev/null 2>&1; then
    echo "git is required for hotspot analysis" >&2
    exit 1
  fi
  if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    echo "Hotspot analysis requires a git repository" >&2
    exit 1
  fi
  raw_days=${CX_HOTSPOTS_DAYS:-90}
  if [[ $raw_days =~ ^[0-9]+$ ]]; then
    days=$raw_days
  else
    days=90
  fi
  raw_limit=${CX_HOTSPOTS_LIMIT:-10}
  if [[ $raw_limit =~ ^[0-9]+$ && $raw_limit -gt 0 ]]; then
    limit=$raw_limit
  else
    limit=10
  fi
  if ! command -v python >/dev/null 2>&1; then
    echo "Python is required to calculate hotspots" >&2
    exit 1
  fi
  declare -a since_arg=()
  if (( days > 0 )); then
    since_arg+=("--since=${days} days ago")
    if [[ -z $(git rev-list "${since_arg[@]}" -1 HEAD 2>/dev/null) ]]; then
      timestamp=$(date -u +%Y-%m-%dT%H:%MZ)
      dir="$HOME/.cx/hotspots"
      mkdir -p "$dir"
      log="$dir/$project.log"
      {
        echo "# Hotspot analysis ($timestamp UTC)"
        echo "No commits in the last $days days."
      } | tee "$log"
      exit 0
    fi
  else
    if [[ -z $(git rev-list -1 HEAD 2>/dev/null) ]]; then
      timestamp=$(date -u +%Y-%m-%dT%H:%MZ)
      dir="$HOME/.cx/hotspots"
      mkdir -p "$dir"
      log="$dir/$project.log"
      {
        echo "# Hotspot analysis ($timestamp UTC)"
        echo "Repository has no commits yet."
      } | tee "$log"
      exit 0
    fi
  fi
  dir="$HOME/.cx/hotspots"
  mkdir -p "$dir"
  log="$dir/$project.log"
  timestamp=$(date -u +%Y-%m-%dT%H:%MZ)
  tmp_input=$(mktemp)
  if ! git log "${since_arg[@]}" --numstat --no-merges --format=$'\x1f%an\x1f' --date=short > "$tmp_input"; then
    rm -f "$tmp_input"
    echo "Failed to read git history for hotspot analysis" >&2
    exit 1
  fi
  tmp_report=$(mktemp)
  if ! python - "$limit" "$days" "$tmp_input" > "$tmp_report" <<'PY'
import collections
import sys

def parse_int(value: str) -> int:
    try:
        return int(value)
    except (TypeError, ValueError):
        return 0

limit = 10
try:
    limit = int(sys.argv[1])
    if limit <= 0:
        limit = 10
except (IndexError, ValueError):
    pass

window = sys.argv[2] if len(sys.argv) > 2 else '0'
history_path = sys.argv[3] if len(sys.argv) > 3 else None
if not history_path:
    sys.exit('Missing git history path for hotspot analysis')

authors = collections.Counter()
file_commits = collections.Counter()
file_churn = collections.Counter()
dir_churn = collections.Counter()
total_commits = 0
current_files = set()

with open(history_path, 'r', encoding='utf-8', errors='ignore') as fh:
    for raw_line in fh:
        line = raw_line.rstrip('\n')
        if not line:
            continue
        if line.startswith('\x1f'):
            author = line.strip().strip('\x1f').strip()
            total_commits += 1
            if author:
                authors[author] += 1
            current_files = set()
            continue
        parts = line.split('\t')
        if len(parts) != 3:
            continue
        added, removed, path = parts
        path = path.strip()
        if not path:
            continue
        if ' -> ' in path:
            path = path.split(' -> ')[-1].strip()
        if not path or path == '/dev/null':
            continue
        if path not in current_files:
            file_commits[path] += 1
            current_files.add(path)
        churn = parse_int(added) + parse_int(removed)
        file_churn[path] += churn
        directory = path.split('/', 1)[0] if '/' in path else '.'
        dir_churn[directory] += churn

window_label = 'entire history' if window == '0' else f'last {window} days'
print(f"Analyzed git history for the {window_label}.")
print(f"Total commits: {total_commits}")
print(f"Files touched: {len(file_commits)}")
print(f"Active authors: {len(authors)}")
print()
print('Top authors by commit count:')
if authors:
    for author, count in authors.most_common(limit):
        print(f"  {author}: {count}")
else:
    print('  (none)')
print()
print('Hot files by commit frequency:')
if file_commits:
    for path, count in sorted(file_commits.items(), key=lambda kv: (-kv[1], kv[0]))[:limit]:
        churn = file_churn.get(path, 0)
        print(f"  {path}: {count} commits, {churn} lines touched")
else:
    print('  (none)')
print()
print('Hot files by churn (lines added+removed):')
if file_churn:
    for path, churn in sorted(file_churn.items(), key=lambda kv: (-kv[1], kv[0]))[:limit]:
        commits = file_commits.get(path, 0)
        print(f"  {path}: {churn} lines touched across {commits} commits")
else:
    print('  (none)')
print()
print('Highest-churn directories:')
if dir_churn:
    for directory, churn in sorted(dir_churn.items(), key=lambda kv: (-kv[1], kv[0]))[:limit]:
        print(f"  {directory}: {churn} lines touched")
else:
    print('  (none)')
PY
  then
    rm -f "$tmp_input" "$tmp_report"
    echo "Failed to compute hotspot report" >&2
    exit 1
  fi
  rm -f "$tmp_input"
  {
    echo "# Hotspot analysis ($timestamp UTC)"
    cat "$tmp_report"
  } | tee "$log"
  rm -f "$tmp_report"
  exit 0
fi

if $SHOW_STALE; then
  if ! command -v git >/dev/null 2>&1; then
    echo "git is required for stale analysis" >&2
    exit 1
  fi
  if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    echo "Stale analysis requires a git repository" >&2
    exit 1
  fi
  if [[ -z $(git rev-list -1 HEAD 2>/dev/null) ]]; then
    timestamp=$(date -u +%Y-%m-%dT%H:%MZ)
    dir="$HOME/.cx/stale"
    mkdir -p "$dir"
    log="$dir/$project.log"
    {
      echo "# Stale files analysis ($timestamp UTC)"
      echo "Repository has no commits yet."
    } | tee "$log"
    exit 0
  fi
  raw_min_age=${CX_STALE_MIN_AGE:-180}
  if [[ $raw_min_age =~ ^[0-9]+$ ]]; then
    min_age=$raw_min_age
  else
    min_age=180
  fi
  raw_limit=${CX_STALE_LIMIT:-20}
  if [[ $raw_limit =~ ^[0-9]+$ && $raw_limit -gt 0 ]]; then
    stale_limit=$raw_limit
  else
    stale_limit=20
  fi
  if ! command -v python3 >/dev/null 2>&1; then
    echo "python3 is required for stale analysis" >&2
    exit 1
  fi
  dir="$HOME/.cx/stale"
  mkdir -p "$dir"
  log="$dir/$project.log"
  if ! python3 - "$min_age" "$stale_limit" <<'PY' | tee "$log"
from datetime import datetime, timezone
import subprocess
import sys
import time

def main() -> int:
    try:
        min_age = int(sys.argv[1])
    except (IndexError, ValueError):
        min_age = 180
    try:
        limit = int(sys.argv[2])
    except (IndexError, ValueError):
        limit = 20
    if limit <= 0:
        limit = 20
    now = int(time.time())
    min_age_seconds = max(0, min_age) * 86400
    try:
        tracked_raw = subprocess.check_output([
            "git",
            "ls-files",
        ], text=True)
    except subprocess.CalledProcessError as exc:
        sys.stderr.write(exc.output)
        return 1
    tracked = {
        line.strip()
        for line in tracked_raw.splitlines()
        if line.strip()
    }
    timestamp = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%MZ")
    print(f"# Stale files analysis ({timestamp} UTC)")
    print(f"# Minimum age: {min_age} days | Showing up to {limit} entries")
    if not tracked:
        print("Repository has no tracked files yet.")
        return 0
    try:
        log_raw = subprocess.check_output([
            "git",
            "log",
            "--name-only",
            "--format=%ct\t%H\t%an",
        ], text=True)
    except subprocess.CalledProcessError as exc:
        sys.stderr.write(exc.output)
        return 1
    seen = {}
    current = None
    for raw_line in log_raw.splitlines():
        stripped = raw_line.strip()
        if not stripped:
            current = None
            continue
        parts = raw_line.split('\t')
        if len(parts) >= 3 and parts[0].isdigit():
            try:
                commit_time = int(parts[0])
            except ValueError:
                current = None
                continue
            commit_hash = parts[1]
            author = parts[2]
            current = (commit_time, commit_hash, author)
            continue
        path = stripped
        if path not in tracked:
            continue
        if current and path not in seen:
            seen[path] = current
    rows = []
    for path, (commit_time, commit_hash, author) in seen.items():
        age = now - commit_time
        if age < min_age_seconds:
            continue
        rows.append((age, commit_time, commit_hash, author, path))
    rows.sort(key=lambda item: item[0], reverse=True)
    print("Age(days)  Last Commit  Commit  Author  Path")
    if not rows:
        print(f"No tracked files older than {min_age} days.")
        return 0
    for age, commit_time, commit_hash, author, path in rows[:limit]:
        age_days = age // 86400
        commit_date = datetime.fromtimestamp(commit_time, tz=timezone.utc).strftime("%Y-%m-%d")
        short_hash = commit_hash[:7]
        print(f"{age_days:>9}  {commit_date}  {short_hash:<7}  {author}  {path}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
PY
  then
    echo "Failed to analyze stale files" >&2
    exit 1
  fi
  exit 0
fi

if $SHOW_INSPECT; then
  tmp_sizes=$(mktemp)
  trap 'rm -f "$tmp_sizes"' EXIT
  declare -A EXT_COUNTS=()
  declare -A EXT_LINES=()
  declare -A DIR_COUNTS=()
  declare -A DIR_LINES=()
  total_files=0
  total_lines=0
  inside_git=false
  if git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    inside_git=true
  fi

  file_iter() {
    if $inside_git; then
      git ls-files -z
    else
      find . -type f -print0
    fi
  }

  while IFS= read -r -d '' f; do
    [[ -f "$f" ]] || continue
    (( total_files++ ))
    rel=${f#./}
    [[ -n "$rel" ]] || rel="$f"
    lines=$(wc -l < "$f" 2>/dev/null || echo 0)
    size=$(wc -c < "$f" 2>/dev/null || echo 0)
    total_lines=$(( total_lines + lines ))

    base=${rel##*/}
    ext="(none)"
    if [[ "$base" == *.* && "$base" != .* ]]; then
      ext=${base##*.}
    elif [[ "$base" == .* && "$base" == *.*.* ]]; then
      ext=${base##*.}
    fi
    ext=${ext,,}
    EXT_COUNTS["$ext"]=$(( ${EXT_COUNTS[$ext]:-0} + 1 ))
    EXT_LINES["$ext"]=$(( ${EXT_LINES[$ext]:-0} + lines ))

    top_dir="."
    trimmed=${rel#./}
    if [[ "$trimmed" == */* ]]; then
      top_dir=${trimmed%%/*}
    fi
    DIR_COUNTS["$top_dir"]=$(( ${DIR_COUNTS[$top_dir]:-0} + 1 ))
    DIR_LINES["$top_dir"]=$(( ${DIR_LINES[$top_dir]:-0} + lines ))

    printf '%s\t%s\t%s\n' "$size" "$lines" "$rel" >> "$tmp_sizes"
  done < <(file_iter) || true

  inspect_dir="$HOME/.cx/inspect"
  mkdir -p "$inspect_dir"
  log="$inspect_dir/$project.log"
  timestamp=$(date -u +%Y-%m-%dT%H:%MZ)

  if (( total_files == 0 )); then
    {
      echo "# Repository inspection ($timestamp UTC)"
      echo "No files found to inspect."
    } | tee "$log"
    exit 0
  fi

  format_count_lines() {
    if (( $# == 0 )); then
      echo "(none)"
      return
    fi
    printf '%s\n' "$@" | while IFS=$'\t' read -r count lines name; do
      printf '%-12s files=%s lines=%s\n' "$name" "$count" "$lines"
    done
  }

  ext_summary=()
  if (( ${#EXT_COUNTS[@]} )); then
    while IFS= read -r line; do
      ext_summary+=("$line")
    done < <(
      for ext in "${!EXT_COUNTS[@]}"; do
        printf '%s\t%s\t%s\n' "${EXT_COUNTS[$ext]}" "${EXT_LINES[$ext]}" "$ext"
      done | sort -k1,1nr -k2,2nr | head -n 10
    )
  fi

  dir_summary=()
  if (( ${#DIR_COUNTS[@]} )); then
    while IFS= read -r line; do
      dir_summary+=("$line")
    done < <(
      for dir in "${!DIR_COUNTS[@]}"; do
        printf '%s\t%s\t%s\n' "${DIR_COUNTS[$dir]}" "${DIR_LINES[$dir]}" "$dir"
      done | sort -k2,2nr -k1,1nr | head -n 10
    )
  fi

  largest_files=$(sort -k1,1nr "$tmp_sizes" | head -n 10)

  if $inside_git; then
    todo_output=$(git grep -n 'TODO\|FIXME\|BUG' 2>/dev/null || true)
    conflict_output=$(git grep -nE '^[[:space:]]*<<<<<<< ' 2>/dev/null || true)
    debug_output=$(git grep -nE 'console\\.log|debugger;|pdb\\.set_trace|ipdb\\.set_trace' -- '*.js' '*.jsx' '*.ts' '*.tsx' '*.mjs' '*.cjs' '*.py' 2>/dev/null || true)
  else
    todo_output=$(grep -RIn 'TODO\|FIXME\|BUG' . 2>/dev/null || true)
    conflict_output=$(grep -RInE '^[[:space:]]*<<<<<<< ' . 2>/dev/null || true)
    debug_output=$(grep -RInE 'console\\.log|debugger;|pdb\\.set_trace|ipdb\\.set_trace' . --include='*.js' --include='*.jsx' --include='*.ts' --include='*.tsx' --include='*.mjs' --include='*.cjs' --include='*.py' 2>/dev/null || true)
  fi

  todo_output=$(printf '%s\n' "$todo_output" | sed '/^$/d')
  todo_count=$(printf '%s\n' "$todo_output" | sed '/^$/d' | wc -l | tr -d ' ')

  conflict_output=$(printf '%s\n' "$conflict_output" | sed '/^$/d')
  conflict_count=$(printf '%s\n' "$conflict_output" | sed '/^$/d' | wc -l | tr -d ' ')

  debug_output=$(printf '%s\n' "$debug_output" | sed '/^$/d')
  debug_count=$(printf '%s\n' "$debug_output" | sed '/^$/d' | wc -l | tr -d ' ')

  {
    echo "# Repository inspection ($timestamp UTC)"
    echo "Total tracked files: $total_files"
    echo "Total lines of code: $total_lines"
    echo
    echo "## Files by extension (top 10 by file count)"
    if (( ${#ext_summary[@]} )); then
      format_count_lines "${ext_summary[@]}"
    else
      echo "(none)"
    fi
    echo
    echo "## Top directories by line count"
    if (( ${#dir_summary[@]} )); then
      format_count_lines "${dir_summary[@]}"
    else
      echo "(none)"
    fi
    echo
    echo "## Largest files (top 10 by bytes)"
    if [[ -n "$largest_files" ]]; then
      printf '%s\n' "$largest_files" | while IFS=$'\t' read -r size lines path; do
        printf '%-40s size=%sB lines=%s\n' "$path" "$size" "$lines"
      done
    else
      echo "(none)"
    fi
    echo
    echo "## TODO / FIXME / BUG markers ($todo_count matches)"
    if [[ -n "$todo_output" ]]; then
      printf '%s\n' "$todo_output" | head -n 10
      [[ $todo_count -gt 10 ]] && echo "..."
    else
      echo "None found."
    fi
    echo
    echo "## Merge conflict markers ($conflict_count matches)"
    if [[ -n "$conflict_output" ]]; then
      printf '%s\n' "$conflict_output" | head -n 10
      [[ $conflict_count -gt 10 ]] && echo "..."
    else
      echo "None found."
    fi
    echo
    echo "## Potential debug statements ($debug_count matches)"
    if [[ -n "$debug_output" ]]; then
      printf '%s\n' "$debug_output" | head -n 10
      [[ $debug_count -gt 10 ]] && echo "..."
    else
      echo "None found."
    fi
  } | tee "$log"
  exit 0
fi

