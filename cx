    echo
    echo "## Merge conflict markers ($conflict_count matches)"
    if [[ -n "$conflict_output" ]]; then
      printf '%s\n' "$conflict_output" | head -n 10
      [[ $conflict_count -gt 10 ]] && echo "..."
    else
