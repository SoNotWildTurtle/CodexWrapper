summarize_module_json() {
  local path=$1
  local limit=${CX_MODULE_SUMMARY_LIMIT:-3}

  if [[ ! -s "$path" ]]; then
    return 1
  fi

  if ! command -v python >/dev/null 2>&1; then
    return 1
  fi

  python - "$path" "$limit" <<'PY'
import json
import sys
from pathlib import Path

path = Path(sys.argv[1])
limit = int(sys.argv[2]) if len(sys.argv) > 2 else 3

with path.open('r', encoding='utf-8') as handle:
    data = json.load(handle)

project = data.get('project') or path.stem

def nice(value):
    if not value or value in ('.', project):
        return project
    return value.replace('\\', '/').strip()

items = []
seen = set()

def record(text):
    text = text.strip()
    if not text or text in seen:
        return
    seen.add(text)
    items.append(text)

def add_missing(section, label):
    entries = data.get(section, {}).get('missing_init', [])
    for value in entries[:limit]:
        record(f"Add __init__.py to {nice(value)}")

def add_tests(section, label):
    entries = data.get(section, {}).get('no_tests', [])
    for value in entries[:limit]:
        record(f"Create tests for {label} {nice(value)}")

def add_heavy(section, label):
    container = data.get(section, {})
    components = container.get('components', {})
    heavy = container.get('heavy', [])
    for value in heavy[:limit]:
        details = components.get(value, {})
        files = details.get('files')
        suffix = f" ({files} files)" if isinstance(files, int) and files else ''
        record(f"Refine large {label} {nice(value)}{suffix}")

add_missing('python', 'Python package')
add_tests('python', 'Python module')
add_tests('node', 'Node/TypeScript area')
add_tests('go', 'Go package')
add_tests('rust', 'Rust module')
add_heavy('python', 'Python module')
add_heavy('node', 'Node/TypeScript area')
add_heavy('go', 'Go package')
add_heavy('rust', 'Rust module')

decision_priority = {
    'immediate': 'Prioritize',
    'short_term': 'Plan for',
    'monitor': 'Monitor',
}

decisions = data.get('decisions', {})
for bucket, label in decision_priority.items():
    entries = decisions.get(bucket, [])
    for entry in entries[:limit]:
        language = entry.get('language', 'module').title()
        component = nice(entry.get('component'))
        reasons = entry.get('reasons') or []
        reason_text = '; '.join(reasons) if reasons else 'review recommended improvements'
        record(f"{label} {language} module {component} ({reason_text})")

weak_points = data.get('weak_points') or []
for entry in weak_points[:limit]:
    language = (entry.get('language') or 'module').title()
    component = nice(entry.get('component'))
    severity = (entry.get('severity') or 'medium').title()
    reasons = entry.get('reasons') or []
    reason_text = '; '.join(reasons) if reasons else 'review module health'
    record(f"{severity} weak point: {language} {component} ({reason_text})")

for line in items:
    print(line)
PY
}

compare_module_baseline() {
  local current=$1
  local baseline=$2

  if [[ ! -s "$current" || ! -s "$baseline" ]]; then
    return 0
  fi

  if ! command -v python >/dev/null 2>&1; then
    echo "Python is required to compare module analysis baselines." >&2
    return 1
  fi

  python - "$current" "$baseline" <<'PY'
import json
import sys
from pathlib import Path

current_path = Path(sys.argv[1])
baseline_path = Path(sys.argv[2])

try:
    current = json.loads(current_path.read_text(encoding='utf-8'))
    baseline = json.loads(baseline_path.read_text(encoding='utf-8'))
except Exception as exc:  # pragma: no cover - defensive
    print(f"Unable to load module analysis snapshots: {exc}")
    raise SystemExit(1)

labels = {
    ("python", "missing_init"): "Python packages missing __init__.py",
    ("python", "no_tests"): "Python modules lacking tests",
    ("python", "heavy"): "Large Python areas flagged",
    ("node", "no_tests"): "Node/TypeScript areas lacking tests",
    ("node", "heavy"): "Large Node/TypeScript areas flagged",
    ("go", "no_tests"): "Go packages lacking tests",
    ("go", "heavy"): "Large Go packages flagged",
    ("rust", "no_tests"): "Rust modules lacking tests",
    ("rust", "heavy"): "Large Rust modules flagged",
}

def ensure_list(section: dict, key: str) -> list:
    if not isinstance(section, dict):
        return []
    value = section.get(key, [])
    if value is None:
        return []
    if isinstance(value, list):
        return value
    if isinstance(value, dict):
        return list(value)
    try:
        return list(value)
    except TypeError:
        return []

issues = []

for (section, key), label in labels.items():
    current_values = ensure_list(current.get(section, {}), key)
    baseline_values = ensure_list(baseline.get(section, {}), key)
    if len(current_values) > len(baseline_values):
        extra = sorted(set(current_values) - set(baseline_values))
        if extra:
            preview = ", ".join(extra[:3])
        else:
            preview = "additional entries"
        issues.append(
            f"{label} increased to {len(current_values)} (was {len(baseline_values)}): {preview}"
        )

def normalise_weak(entries):
    result = set()
    for entry in entries or []:
        if not isinstance(entry, dict):
            continue
        lang = (entry.get('language') or '').lower()
        comp = entry.get('component') or ''
        severity = (entry.get('severity') or '').lower()
        result.add((lang, comp, severity))
    return result

current_weak = normalise_weak(current.get('weak_points'))
baseline_weak = normalise_weak(baseline.get('weak_points'))
if current_weak - baseline_weak:
    preview = ", ".join(
        f"{lang or 'module'}:{comp or '<root>'}" for lang, comp, _ in sorted(current_weak - baseline_weak)[:3]
    )
    issues.append(
        "New module weak points detected since the last baseline: " + preview
    )

if issues:
    print("\n".join(issues))
    raise SystemExit(1)
PY
}

module_regression_check() {
  local current=$1
  MODULE_REGRESSION_OUTPUT=""
  MODULE_REGRESSION_ALLOWED=false

  if [[ ! -s "$current" ]]; then
    return 0
  fi

  local dir="$CX_HOME/modules"
  mkdir -p "$dir"
  local baseline="$dir/$project-latest.json"
  local previous="$dir/$project-prev.json"
  local allow="${CX_MODULE_ALLOW_REGRESSION:-0}"

  if [[ -f "$baseline" ]]; then
    local output=""
    if ! output=$(compare_module_baseline "$current" "$baseline" 2>/dev/null); then
      MODULE_REGRESSION_OUTPUT="$output"
      if [[ "$allow" != "1" ]]; then
        return 1
      fi
      MODULE_REGRESSION_ALLOWED=true
    fi
    cp "$baseline" "$previous" 2>/dev/null || true
  fi

  cp "$current" "$baseline.tmp"
  mv "$baseline.tmp" "$baseline"

  return 0
}

run_additive_suite() {
  local status=0
  echo "Starting additive improvement automation for $project" >&2
  if ! run_improve_suite; then
    status=1
  fi

  local timestamp
  timestamp=$(date -u +%Y-%m-%dT%H%MZ)
  local dir="$CX_HOME/additive"
  mkdir -p "$dir"
  local file="$dir/$project-$timestamp.md"

  local iso
  iso=$(date -u +%Y-%m-%dT%H:%M:%SZ)

  local module_json_dir="$CX_HOME/modules"
  mkdir -p "$module_json_dir"
  local module_json_file="$module_json_dir/$project-$timestamp.json"
  MODULE_JSON_PATH="$module_json_file"

  local audit_log="$CX_HOME/audit/$project.log"
  local hotspots_log="$CX_HOME/hotspots/$project.log"
  local stale_log="$CX_HOME/stale/$project.log"
  local depscan_log="$CX_HOME/depscan/$project.log"
  local format_log="$CX_HOME/format/$project.log"
  local inspect_log="$CX_HOME/inspect/$project.log"

  local -a summary=()
  local module_output=""
  local additive_mode="$ADDITIVE_MODE"
  local -a module_summary_lines=()

  MODULE_SCAFFOLD_LOG_PATH=""
  local want_analysis_before=false
  local want_analysis_after=false
  local apply_scaffold=false

  case "$additive_mode" in
    plan)
      want_analysis_before=true
      ;;
    apply)
      apply_scaffold=true
      ;;
    full)
      apply_scaffold=true
      want_analysis_after=true
      ;;
  esac

  if [[ "${CX_ADDITIVE_APPLY_SCAFFOLD:-0}" == "1" ]]; then
    apply_scaffold=true
    if [[ "$want_analysis_before" == false && "$want_analysis_after" == false ]]; then
      want_analysis_before=true
    fi
  fi

  if $want_analysis_before; then
    module_output=$(CX_MODULES_JSON_PATH="$module_json_file" generate_module_markdown) || true
  fi

  if $apply_scaffold; then
    if module_scaffold_apply true; then
      local log_hint="${MODULE_SCAFFOLD_LOG_PATH:-$CX_HOME/scaffold}"
      summary+=("Seed scaffolding assets (review ${log_hint})")
      if [[ -f "$MODULE_SCAFFOLD_LOG_PATH" ]]; then
        local scaffold_markdown
        scaffold_markdown=$(<"$MODULE_SCAFFOLD_LOG_PATH") || scaffold_markdown=""
        if [[ "$additive_mode" == "apply" ]]; then
          module_output="$scaffold_markdown"
        elif [[ "$additive_mode" != "full" && -z "${module_output//[[:space:]]/}" ]]; then
          module_output="$scaffold_markdown"
        fi
      fi
    else
      summary+=("Module scaffolding skipped—ensure python3 is available and rerun `cx --scaffold`.")
    fi
  fi

  if $apply_scaffold; then
    if $want_analysis_after; then
      local post_module_output=""
      post_module_output=$(CX_MODULES_JSON_PATH="$module_json_file" generate_module_markdown) || true
      if [[ -n ${post_module_output//[[:space:]]/} ]]; then
        module_output="$post_module_output"
      fi
    fi
  else
    if [[ "$want_analysis_before" == false && -z "${module_output//[[:space:]]/}" ]]; then
      module_output=$(CX_MODULES_JSON_PATH="$module_json_file" generate_module_markdown) || true
    fi
  fi

  if [[ ! -s "$module_json_file" ]]; then
    CX_MODULES_JSON_PATH="$module_json_file" generate_module_markdown >/dev/null 2>&1 || true
  fi

  if [[ -s "$module_json_file" ]]; then
    if mapfile -t module_summary_lines < <(summarize_module_json "$module_json_file" 2>/dev/null); then
      if (( ${#module_summary_lines[@]} )); then
        summary+=("${module_summary_lines[@]}")
      fi
    fi
    if ! module_regression_check "$module_json_file"; then
      status=1
      summary+=("Module regression detected—resolve the new gaps before committing changes.")
      if [[ -n ${MODULE_REGRESSION_OUTPUT//[[:space:]]/} ]]; then
        while IFS= read -r line; do
          [[ -z ${line//[[:space:]]/} ]] && continue
          summary+=("  - $line")
        done <<<"$MODULE_REGRESSION_OUTPUT"
      fi
      summary+=("Export CX_MODULE_ALLOW_REGRESSION=1 to bypass this guard after manual review.")
    elif [[ ${MODULE_REGRESSION_ALLOWED:-false} == true ]]; then
      summary+=("Module regression detected but accepted because CX_MODULE_ALLOW_REGRESSION=1. Review the new gaps below.")
      if [[ -n ${MODULE_REGRESSION_OUTPUT//[[:space:]]/} ]]; then
        while IFS= read -r line; do
          [[ -z ${line//[[:space:]]/} ]] && continue
          summary+=("  - $line")
        done <<<"$MODULE_REGRESSION_OUTPUT"
      fi
    fi
  else
    summary+=("Run 'cx --modules' after enabling python3 to capture structured module opportunities.")
  fi

  if [[ -f "$audit_log" ]]; then
    local todo_sample=""
    if command -v rg >/dev/null 2>&1; then
      todo_sample=$(rg --no-heading -n 'TODO|FIXME|BUG' "$audit_log" 2>/dev/null | head -n 1)
    else
      todo_sample=$(grep -nE 'TODO|FIXME|BUG' "$audit_log" 2>/dev/null | head -n 1)
    fi
    if [[ -n $todo_sample ]]; then
      summary+=("Address audit marker: ${todo_sample}")
    fi
  else
    summary+=("Run \`cx --audit\` to capture TODO/FIXME markers before the next sweep.")
  fi

  if [[ -f "$hotspots_log" ]]; then
    local hotspot_sample=""
    hotspot_sample=$(awk '/^Hot files by churn:/{flag=1;next} flag{if(!NF){exit} print}' "$hotspots_log" | head -n 1)
    if [[ -n $hotspot_sample ]]; then
      summary+=("Stabilize hotspot: ${hotspot_sample}")
    fi
  fi

  if [[ -f "$stale_log" ]]; then
    local stale_sample=""
    stale_sample=$(awk 'NR>4 && NF {print}' "$stale_log" | head -n 1)
    if [[ -n $stale_sample ]]; then
      summary+=("Modernize stale file: ${stale_sample}")
    fi
  fi

  if [[ -f "$depscan_log" ]]; then
    local depscan_sample=""
    depscan_sample=$(grep -v '^#' "$depscan_log" | sed '/^[[:space:]]*$/d' | head -n 1)
    if [[ -n $depscan_sample ]]; then
      if [[ ${depscan_sample,,} == no\ supported* ]]; then
        summary+=("${depscan_sample}")
      else
        summary+=("Plan dependency updates: ${depscan_sample}")
      fi
    fi
  else
    summary+=("Run \`cx --depscan\` to keep dependency updates in view.")
  fi

  if [[ -f "$format_log" ]]; then
    local format_skip=""
    format_skip=$(grep '>>> skipped:' "$format_log" | head -n 1)
    if [[ -n $format_skip ]]; then
      summary+=("Install missing formatter: ${format_skip#*skipped: }")
    fi
  fi

  local inspect_excerpt=""
  if [[ -f "$inspect_log" ]]; then
    inspect_excerpt=$(tail -n 10 "$inspect_log")
  fi

  {
    echo "# Additive improvement plan for $project"
    echo
    echo "_Generated: ${iso}_"
    echo
    echo "## Automation summary"
    echo
    echo "- Baseline lint/audit/inspect with autofixes."
    echo "- Formatter sweep across available tools."
    echo "- Dependency scan for Python/Node managers."
    echo "- Project bootstrap actions via \`cx --start\`."
    if [[ -n ${CX_IMPROVE_EXTRA-} ]]; then
      echo "- Custom commands from \`CX_IMPROVE_EXTRA\`."
    fi
    echo
    echo "## High-priority follow-ups"
    echo
    if (( ${#summary[@]} )); then
      declare -A seen=()
      local item
      for item in "${summary[@]}"; do
        item="${item//$'\n'/ }"
        if [[ -n ${item//[[:space:]]/} && -z ${seen["$item"]+x} ]]; then
          seen["$item"]=1
          printf -- "- %s\n" "$item"
        fi
      done
      if (( ${#seen[@]} == 0 )); then
        echo "- Improvement sweep produced no actionable highlights."
      fi
    else
      echo "- Improvement sweep produced no actionable highlights."
    fi
    echo
    echo "## Module-building opportunities"
    echo
    echo "_Mode: ${additive_mode^}_"
    echo
    if [[ -n ${module_output//[[:space:]]/} ]]; then
      if command -v sed >/dev/null 2>&1; then
        printf '%s\n' "$module_output" | sed '1,2d'
      else
        printf '%s\n' "$module_output" | tail -n +3
      fi
    else
      echo "- Module analysis is unavailable."
    fi
    if (( ${#module_summary_lines[@]} )); then
      echo
      echo "### Quick module tasks"
      local entry
      for entry in "${module_summary_lines[@]}"; do
        printf -- "- %s\n" "$entry"
      done
    fi
    echo
    echo "## Log references"
    echo
    echo "- Audit: $audit_log"
    echo "- Hotspots: $hotspots_log"
    echo "- Stale files: $stale_log"
    echo "- Formatter sweep: $format_log"
    echo "- Dependency scan: $depscan_log"
    if [[ -s "$module_json_file" ]]; then
      echo "- Module analysis JSON: $module_json_file"
    else
      echo "- Module analysis JSON: (not generated)"
    fi
    if [[ -n "$MODULE_SCAFFOLD_LOG_PATH" ]]; then
      echo "- Scaffolding run: $MODULE_SCAFFOLD_LOG_PATH"
    else
      echo "- Scaffolding run: (not yet executed)"
    fi
    echo "- Improvement history: $CX_HOME/improve/$project.log"
    echo
    if [[ -n "$inspect_excerpt" ]]; then
      echo "### Recent inspection excerpt"
      echo '```'
      printf '%s\n' "$inspect_excerpt"
      echo '```'
      echo
    fi
    echo "## Next steps"
    echo
    if [[ -n "$MODULE_SCAFFOLD_LOG_PATH" ]]; then
      echo "- Review scaffolding placeholders captured in $MODULE_SCAFFOLD_LOG_PATH and replace TODOs with real logic."
    else
      echo "- Run \`cx --scaffold\` to create starter package and test files when module gaps appear."
    fi
    echo "- Re-run \`cx --modules\` after adding new code to refresh scaffolding suggestions."
    echo "- Use \`cx --enhance\` to turn these findings into a longer-term improvement plan."
    echo "- Queue outstanding fixes in \`cx --backlog\` so progress stays visible."
  } >"$file"

  echo "Additive improvement plan written to $file" >&2
  return $status
}

