  if (( ${#EXT_COUNTS[@]} )); then
    while IFS= read -r line; do
      ext_summary+=("$line")
    done < <(
      for ext in "${!EXT_COUNTS[@]}"; do
        printf '%s\t%s\t%s\n' "${EXT_COUNTS[$ext]}" "${EXT_LINES[$ext]}" "$ext"
      done | sort -k1,1nr -k2,2nr | head -n 10
    )
  fi

  dir_summary=()
  if (( ${#DIR_COUNTS[@]} )); then
    while IFS= read -r line; do
      dir_summary+=("$line")
    done < <(
      for dir in "${!DIR_COUNTS[@]}"; do
        printf '%s\t%s\t%s\n' "${DIR_COUNTS[$dir]}" "${DIR_LINES[$dir]}" "$dir"
      done | sort -k2,2nr -k1,1nr | head -n 10
    )
  fi

  largest_files=$(sort -k1,1nr "$tmp_sizes" | head -n 10)

  if $inside_git; then
    todo_output=$(git grep -n 'TODO\|FIXME\|BUG' 2>/dev/null || true)
    conflict_output=$(git grep -nE '^[[:space:]]*<<<<<<< ' 2>/dev/null || true)
    debug_output=$(git grep -nE 'console\\.log|debugger;|pdb\\.set_trace|ipdb\\.set_trace' -- '*.js' '*.jsx' '*.ts' '*.tsx' '*.mjs' '*.cjs' '*.py' 2>/dev/null || true)
  else
