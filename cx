  return 0
}

generate_enhancement_plan() {
  local improve_status=${1:-0}
  local timestamp
  timestamp=$(date -u +%Y-%m-%dT%H%MZ)
  local dir="$CX_HOME/enhance"
  mkdir -p "$dir"
  local file="$dir/$project-$timestamp.md"
  ENHANCE_PLAN_PATH="$file"

  local -a context_lines=()
  if mapfile -t context_lines < <(describe_project_context "$PROJECT_ROOT" "$INITIAL_CWD"); then
    :
  else
    context_lines=()
  fi

  local detected_root="$PROJECT_ROOT"
  local working_dir="$INITIAL_CWD"
  local relative_path="."
  local -a capabilities=()
  local -a warnings=()
  local section=""
  local line
  for line in "${context_lines[@]}"; do
    case "$line" in
      "Detected project root:"*)
        detected_root="${line#Detected project root: }"
        ;;
      "Working directory:"*)
        working_dir="${line#Working directory: }"
        ;;
      "Current directory:"*)
        working_dir="${line#Current directory: }"
        ;;
      "Relative path from root:"*)
        relative_path="${line#Relative path from root: }"
        ;;
      "Detected automation opportunities:")
        section="capabilities"
        ;;
      "Gaps to address before automation:")
        section="warnings"
        ;;
      "")
        section=""
        ;;
      "  -"*)
        local entry="${line#  - }"
        if [[ $section == "capabilities" ]]; then
          capabilities+=("$entry")
        elif [[ $section == "warnings" ]]; then
          warnings+=("$entry")
        fi
        ;;
      *)
        ;;
    esac
  done

  local audit_log="$CX_HOME/audit/$project.log"
  local inspect_log="$CX_HOME/inspect/$project.log"
  local hotspots_log="$CX_HOME/hotspots/$project.log"
  local stale_log="$CX_HOME/stale/$project.log"
  local improve_log="$CX_HOME/improve/$project.log"
  local format_log="$CX_HOME/format/$project.log"
  local depscan_log="$CX_HOME/depscan/$project.log"

  local audit_todo_count="0"
  local audit_samples=""
  if [[ -f "$audit_log" ]]; then
    audit_todo_count=$(awk 'match($0, /(TODO|FIXME|BUG)/){count++} END{print count+0}' "$audit_log")
    audit_samples=$(awk 'match($0, /(TODO|FIXME|BUG)/){print; if (++count==5) exit}' "$audit_log")
  fi

  local inspect_excerpt=""
  if [[ -f "$inspect_log" ]]; then
    inspect_excerpt=$(tail -n 40 "$inspect_log")
  fi

  local hotspots_excerpt=""
  if [[ -f "$hotspots_log" ]]; then
    hotspots_excerpt=$(tail -n 40 "$hotspots_log")
  fi

  local stale_excerpt=""
  if [[ -f "$stale_log" ]]; then
    stale_excerpt=$(tail -n 40 "$stale_log")
  fi

  local improve_entry=""
  if [[ -f "$improve_log" ]]; then
    improve_entry=$(awk 'BEGIN{RS="";ORS="\n\n"} {block=$0} END{print block}' "$improve_log")
  fi

  local format_excerpt=""
  if [[ -f "$format_log" ]]; then
    format_excerpt=$(tail -n 40 "$format_log")
  fi

  local depscan_excerpt=""
  if [[ -f "$depscan_log" ]]; then
    depscan_excerpt=$(tail -n 40 "$depscan_log")
  fi

  local status_label
  if (( improve_status == 0 )); then
    status_label="success"
  else
    status_label="completed with issues (exit $improve_status)"
  fi

  {
    echo "# Automated enhancement summary for $project"
    echo
    echo "* Generated: $timestamp UTC"
    echo "* Project root: $detected_root"
    echo "* Invocation directory: $working_dir"
    if [[ -n "$relative_path" && "$relative_path" != "." ]]; then
      echo "* Relative path during execution: $relative_path"
    fi
    echo "* Latest improve sweep: $status_label"
    echo
    echo "## Detected automation opportunities"
    local cap
    if (( ${#capabilities[@]} )); then
      for cap in "${capabilities[@]}"; do
        printf -- '- [ ] %s\n' "$cap"
      done
    else
      echo "- None detected yet. Add manifests or configuration files to unlock project automation."
    fi
    if (( ${#warnings[@]} )); then
      echo
      echo "## Automation gaps to close"
      local warn
      for warn in "${warnings[@]}"; do
        printf -- '- [ ] %s\n' "$warn"
      done
    fi
    echo
    echo "## Recommended follow-up actions"
    echo "- Review git status to inspect automated fixes applied during the sweep."
    echo "- Address any failing steps above and rerun \`cx --improve\` until the sweep succeeds."
    echo "- Schedule regular \`cx --baseline --fix\` runs to refresh lint, audit, inspect, hotspot, and stale insights."
    echo "- Apply available formatters with \`cx --format\` so automated cleanups stay consistent before rerunning \`cx --improve\`."
    echo "- Review \`cx --depscan\` output to schedule dependency updates or security patches."
    echo "- Use \`cx --start\` for ecosystem automation, honoring \`CX_START_SKIP_INSTALL\` and \`CX_START_SKIP_TESTS\` when needed."
    echo "- Extend automation with \`CX_START_EXTRA_INSTALL\`, \`CX_START_EXTRA_TEST\`, \`CX_START_EXTRA_STEPS\`, and \`CX_IMPROVE_EXTRA\` for project-specific commands."
    echo "- Promote recurring findings into symbols or topics so Codex conversations stay compressed."
    echo
    echo "## Repository audit focus"
    if [[ -f "$audit_log" ]]; then
      echo "* Source: $audit_log"
      echo "* TODO/FIXME/BUG markers detected: $audit_todo_count"
      if [[ -n "$audit_samples" ]]; then
        echo
        echo "Sample findings:"
        echo '```'
        printf '%s\n' "$audit_samples"
        echo '```'
      fi
    else
      echo "Run \`cx --audit\` to generate TODO/FIXME/BUG findings and line counts."
    fi
    echo
    echo "## Inspection highlights"
    if [[ -f "$inspect_log" ]]; then
      echo "* Source: $inspect_log"
      echo '```'
      printf '%s\n' "$inspect_excerpt"
      echo '```'
    else
      echo "Run \`cx --inspect\` to capture repository structure and debug markers."
    fi
    echo
    echo "## Hotspot analysis"
    if [[ -f "$hotspots_log" ]]; then
      echo "* Source: $hotspots_log"
      echo '```'
      printf '%s\n' "$hotspots_excerpt"
      echo '```'
    else
      echo "Run \`cx --hotspots\` inside a git repository to surface high-churn files."
    fi
    echo
    echo "## Stale file scan"
    if [[ -f "$stale_log" ]]; then
      echo "* Source: $stale_log"
      echo '```'
      printf '%s\n' "$stale_excerpt"
      echo '```'
    else
      echo "Run \`cx --stale\` to flag long-unmodified tracked files."
    fi
    echo
    echo "## Formatter sweep"
    if [[ -f "$format_log" ]]; then
      echo "* Source: $format_log"
      echo '```'
      printf '%s\n' "$format_excerpt"
      echo '```'
    else
      echo "Run \`cx --format\` to execute available formatters and log the results."
    fi
    echo
    echo "## Dependency scan"
    if [[ -f "$depscan_log" ]]; then
      echo "* Source: $depscan_log"
      echo '```'
      printf '%s\n' "$depscan_excerpt"
      echo '```'
    else
      echo "Run \`cx --depscan\` to capture dependency update suggestions."
    fi
    if [[ -f "$improve_log" ]]; then
      echo
      echo "## Improve sweep log excerpt"
      echo "* Source: $improve_log"
      echo '```'
      printf '%s\n' "$improve_entry"
      echo '```'
    fi
  } | tee "$file"
  echo "Enhancement summary written to $file" >&2
}

run_enhance_suite() {
  local status=0
  echo "Starting enhancement automation for $project" >&2
  if ! run_improve_suite; then
    status=$?
  fi
  generate_enhancement_plan "$status"
  if (( status == 0 )); then
    echo "Enhancement automation complete. Review $ENHANCE_PLAN_PATH for prioritized follow-ups." >&2
  else
    echo "Enhancement automation completed with issues. Review $ENHANCE_PLAN_PATH for prioritized follow-ups." >&2
  fi
  return $status
}

describe_project_context() {
  local root=$1
  local cwd=$2
  [[ -n "$root" ]] || root="$cwd"

  echo "Detected project root: $root"
  if [[ "$cwd" == "$root" ]]; then
    echo "Working directory: $cwd"
  else
    echo "Current directory: $cwd"
    if [[ -n "$root" && "$root" != "/" && "$cwd" == "$root"* ]]; then
      local rel=${cwd#"$root"/}
      if [[ "$rel" == "$cwd" ]]; then
        rel="."
      fi
      echo "Relative path from root: ${rel:-.}"
    elif [[ "$root" == "/" ]]; then
      local rel=${cwd#/}
      echo "Relative path from root: ${rel:-.}"
    else
      echo "Relative path from root: (outside detected root)"
      echo "Automation commands will run from $root." >&2
    fi
  fi

  echo

  local pushed=false
  if [[ -d "$root" && "$cwd" != "$root" ]]; then
    if pushd "$root" >/dev/null; then
      pushed=true
    fi
  fi

  local -a capabilities=()
  local -a warnings=()

  if command -v git >/dev/null 2>&1 && git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    local branch
    branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo HEAD)
    capabilities+=("Git repository (branch $branch) — hotspot and stale analyses available.")
  elif [[ -d .git ]]; then
    warnings+=("Git metadata detected but the git CLI is unavailable; install git to unlock history-driven reports.")
  fi

  local node_manager
  if node_manager=$(detect_node_manager); then
    local -a scripts=()
    npm_has_script lint && scripts+=("lint")
    npm_has_script test && scripts+=("test")
    local note="Node project via $node_manager (dependency install ready"
    if (( ${#scripts[@]} )); then
      local IFS=', '
      note+="; scripts: ${scripts[*]}"
    fi
    note+="; cx --depscan will report outdated dependencies"
    note+=")"
    capabilities+=("$note")
  elif [[ -f package.json ]]; then
    warnings+=("package.json detected but no npm/yarn/pnpm/bun CLI found; install a Node package manager so --start can automate it.")
  fi

  if precommit_config_present; then
    if command -v pre-commit >/dev/null 2>&1; then
      if git_repository_present; then
        capabilities+=("pre-commit configuration (pre-commit install/run --all-files ready).")
      else
        capabilities+=("pre-commit configuration (pre-commit run --all-files ready; install hooks once git is available).")
      fi
    else
      warnings+=(".pre-commit-config.yaml detected but the pre-commit CLI is unavailable; install it to run repository checks.")
    fi
  fi

  if justfile_present; then
    if command -v just >/dev/null 2>&1; then
      local -a just_tasks=()
      just_has_recipe install && just_tasks+=(install)
      just_has_recipe lint && just_tasks+=(lint)
      just_has_recipe test && just_tasks+=(test)
      if (( ${#just_tasks[@]} )); then
        local IFS=', '
        capabilities+=("Justfile (just ${just_tasks[*]} ready).")
      else
        capabilities+=("Justfile detected (just command available).")
      fi
    else
      warnings+=("Justfile detected but the just CLI is unavailable; install just to enable recipe automation.")
    fi
  fi

  if taskfile_present; then
    if command -v task >/dev/null 2>&1; then
      local -a task_tasks=()
      task_has_target install && task_tasks+=(install)
      task_has_target lint && task_tasks+=(lint)
      task_has_target test && task_tasks+=(test)
      if (( ${#task_tasks[@]} )); then
        local IFS=', '
        capabilities+=("Taskfile (task ${task_tasks[*]} ready).")
      else
        capabilities+=("Taskfile detected (task command available).")
      fi
    else
      warnings+=("Taskfile detected but the task CLI is unavailable; install go-task to automate those targets.")
    fi
  fi

  if bazel_project_present; then
    local bazel_cli
    if bazel_cli=$(bazel_command); then
      local bazel_label
      bazel_label=$(basename "$bazel_cli")
      local bazel_build_targets_display="${CX_START_BAZEL_BUILD_TARGETS:-//...}"
      if [[ -z "$bazel_build_targets_display" ]]; then
        bazel_build_targets_display="(set CX_START_BAZEL_BUILD_TARGETS to choose targets)"
      fi
      local bazel_test_targets_display="${CX_START_BAZEL_TEST_TARGETS:-//...}"
      if [[ -z "$bazel_test_targets_display" ]]; then
        bazel_test_targets_display="(set CX_START_BAZEL_TEST_TARGETS to choose targets)"
      fi
      capabilities+=("Bazel workspace (${bazel_label} build ${bazel_build_targets_display}, test ${bazel_test_targets_display}).")
    else
      warnings+=("Bazel markers detected but no bazel/bazelisk/bazelw command is available; install Bazel or add a ./bazelw wrapper.")
    fi
  fi

  if pants_project_present; then
    local pants_cli
    if pants_cli=$(pants_command); then
      local pants_deps_targets_display="${CX_START_PANTS_DEPS_TARGETS:-::}"
      if [[ -z "$pants_deps_targets_display" ]]; then
        pants_deps_targets_display="(set CX_START_PANTS_DEPS_TARGETS to choose targets)"
      fi
      local pants_lint_targets_display="${CX_START_PANTS_LINT_TARGETS:-::}"
      if [[ -z "$pants_lint_targets_display" ]]; then
        pants_lint_targets_display="(set CX_START_PANTS_LINT_TARGETS to choose targets)"
      fi
      local pants_test_targets_display="${CX_START_PANTS_TEST_TARGETS:-::}"
      if [[ -z "$pants_test_targets_display" ]]; then
        pants_test_targets_display="(set CX_START_PANTS_TEST_TARGETS to choose targets)"
      fi
      capabilities+=("Pants project ($(basename "$pants_cli") dependencies ${pants_deps_targets_display}, lint ${pants_lint_targets_display}, test ${pants_test_targets_display}).")
    else
      warnings+=("Pants configuration detected but no ./pants script or pants CLI was found; install Pants or make the launcher executable.")
    fi
  fi

  if nix_project_present; then
    if command -v nix >/dev/null 2>&1; then
      local nix_label="Nix environment"
      if [[ -f flake.nix ]]; then
        nix_label="Nix flake"
      elif [[ -f shell.nix ]]; then
        nix_label="Nix shell"
      fi
      capabilities+=("${nix_label} (nix develop, nix build).")
    else
      warnings+=("Nix configuration detected but the nix CLI is unavailable; install Nix to enter project shells or builds.")
    fi
  fi

  if terraform_project_present; then
    if command -v terraform >/dev/null 2>&1; then
      capabilities+=("Terraform IaC (terraform init, terraform fmt -check, terraform validate).")
    else
      warnings+=("Terraform files detected but the terraform CLI is missing; install Terraform before running infrastructure checks.")
    fi
  fi

  if ansible_project_present; then
    if command -v ansible-playbook >/dev/null 2>&1; then
      local ansible_note="Ansible playbooks (ansible-playbook --syntax-check"
      if command -v ansible-lint >/dev/null 2>&1; then
        ansible_note+=", ansible-lint"
      fi
      ansible_note+=")."
      capabilities+=("$ansible_note")
    else
      warnings+=("Ansible configuration detected but ansible-playbook is unavailable; install Ansible to validate playbooks.")
    fi
  fi

  if helm_chart_present; then
    if command -v helm >/dev/null 2>&1; then
      capabilities+=("Helm chart (helm lint, helm template).")
    else
      warnings+=("Chart.yaml detected but the helm CLI is missing; install Helm to lint and render the chart.")
    fi
  fi

  if kustomize_project_present; then
    if command -v kustomize >/dev/null 2>&1; then
      capabilities+=("Kustomize overlays (kustomize build).")
    elif command -v kubectl >/dev/null 2>&1; then
      capabilities+=("Kustomize overlays (kubectl kustomize).")
    else
      warnings+=("kustomization.yaml detected but neither kustomize nor kubectl is available; install one to build manifests.")
    fi
  fi

  if docker_compose_present; then
    if command -v docker-compose >/dev/null 2>&1; then
      capabilities+=("Docker Compose project (docker-compose config, docker-compose build).")
    elif command -v docker >/dev/null 2>&1; then
      capabilities+=("Docker Compose project (docker compose config/build available when Docker daemon is running).")
    else
      warnings+=("Docker Compose file detected but docker/docker-compose is missing; install Docker to build services.")
    fi
  fi

  if vagrant_project_present; then
    if command -v vagrant >/dev/null 2>&1; then
      capabilities+=("Vagrant environment (vagrant validate ready).")
    else
      warnings+=("Vagrantfile detected but the vagrant CLI is unavailable; install Vagrant before provisioning environments.")
    fi
  fi

  if ruby_project_present; then
    if command -v bundle >/dev/null 2>&1; then
      local note="Ruby project (bundle install"
      if [[ -d spec || -d test ]]; then
        note+=", rspec/rake tests"
      fi
      note+=")"
      capabilities+=("$note")
    else
      warnings+=("Gemfile detected but Bundler is unavailable; install bundle to enable dependency and test automation.")
    fi
  fi

  if composer_project_present; then
    if command -v composer >/dev/null 2>&1; then
      local -a composer_bits=("composer install")
      if composer_has_script test; then
        composer_bits+=("composer test script")
      elif [[ -x vendor/bin/phpunit ]]; then
        composer_bits+=("vendor/bin/phpunit")
      fi
      local IFS=', '
      capabilities+=("PHP Composer project (${composer_bits[*]})")
    else
      warnings+=("composer.json detected but composer is missing; install Composer for automated setup and tests.")
    fi
  fi

  if mix_project_present; then
    if command -v mix >/dev/null 2>&1; then
      local note="Elixir mix project (mix deps.get"
      if mix_tests_present; then
        note+=", mix test"
      fi
      note+=")"
      capabilities+=("$note")
    else
      warnings+=("mix.exs detected but mix CLI unavailable; install Elixir tooling to enable automation.")
    fi
  fi

  if stack_project_present; then
    if command -v stack >/dev/null 2>&1; then
      local note="Haskell Stack project (stack build --only-dependencies"
      if stack_tests_present; then
        note+=", stack test"
      fi
      note+=")"
      capabilities+=("$note")
    else
      warnings+=("stack.yaml detected but stack CLI missing; install Stack to warm dependencies and run tests automatically.")
    fi
  fi

  if cabal_project_present; then
    if command -v cabal >/dev/null 2>&1; then
      local note="Haskell Cabal project (cabal v2-build --only-dependencies"
      if cabal_tests_present; then
        note+=", cabal v2-test"
      fi
      note+=")"
      capabilities+=("$note")
    else
      warnings+=("Cabal files detected but the cabal CLI is missing; install the toolchain to automate builds/tests.")
    fi
  fi

  if swift_package_present; then
    if command -v swift >/dev/null 2>&1; then
      capabilities+=("Swift package (swift package resolve, swift test).")
    else
      warnings+=("Package.swift detected but the swift CLI is unavailable.")
    fi
  fi

  if sbt_project_present; then
    if command -v sbt >/dev/null 2>&1; then
      capabilities+=("Scala sbt project (sbt update, sbt test).")
    else
      warnings+=("sbt build files detected but the sbt CLI is missing; install sbt to automate builds/tests.")
    fi
  fi

  if flutter_project_present; then
    if command -v flutter >/dev/null 2>&1; then
      local note="Flutter project (flutter pub get"
      if flutter_tests_present; then
        note+=", flutter test"
      fi
      note+=")"
      capabilities+=("$note")
    else
      warnings+=("Flutter configuration detected but the flutter command is unavailable.")
    fi
  elif dart_project_present; then
    if command -v dart >/dev/null 2>&1; then
      local note="Dart project (dart pub get"
      if dart_tests_present; then
        note+=", dart test"
      fi
      note+=")"
      capabilities+=("$note")
    else
      warnings+=("Dart pubspec detected but the dart CLI is missing.")
    fi
  fi

  if dotnet_project_present; then
    if command -v dotnet >/dev/null 2>&1; then
      capabilities+=(".NET project (dotnet restore, dotnet test).")
    else
      warnings+=(".sln/.csproj files detected but the dotnet CLI is unavailable.")
    fi
  fi

  if maven_project_present; then
    if command -v mvn >/dev/null 2>&1; then
      capabilities+=("Maven project (mvn dependency:go-offline, mvn test).")
    else
      warnings+=("pom.xml detected but Maven (mvn) is missing.")
    fi
  fi

  if gradle_project_present; then
    if [[ -f gradlew ]]; then
      if [[ -x gradlew ]]; then
        capabilities+=("Gradle project (./gradlew test).")
      else
        capabilities+=("Gradle project (bash ./gradlew test).")
      fi
    elif command -v gradle >/dev/null 2>&1; then
      capabilities+=("Gradle project (gradle test).")
    else
      warnings+=("Gradle build files detected but gradle/gradlew is unavailable.")
    fi
  fi

  if cmake_project_present; then
    if command -v cmake >/dev/null 2>&1; then
      local note="CMake project (cmake -S . -B ${CX_CMAKE_BUILD_DIR:-build}, cmake --build"
      if command -v ctest >/dev/null 2>&1; then
        note+=", ctest"
      fi
      note+=")"
      capabilities+=("$note")
    else
      warnings+=("CMakeLists.txt detected but cmake is missing.")
    fi
  fi

  if [[ -f Makefile || -f makefile ]]; then
    local -a targets=()
    has_make_target lint && targets+=("lint")
    has_make_target test && targets+=("test")
    if (( ${#targets[@]} )); then
      local IFS=', '
      capabilities+=("Makefile with targets ${targets[*]}.")
    else
      capabilities+=("Makefile detected.")
    fi
  fi

  if [[ -f go.mod ]]; then
    if command -v go >/dev/null 2>&1; then
      capabilities+=("Go module (go test ./...).")
    else
      warnings+=("go.mod detected but the Go toolchain is missing.")
    fi
  fi

  if [[ -f Cargo.toml ]]; then
    if command -v cargo >/dev/null 2>&1; then
      capabilities+=("Rust crate (cargo test).")
    else
      warnings+=("Cargo.toml detected but cargo is unavailable.")
    fi
  fi

  local python_manifest=false
  local file
  for file in pyproject.toml setup.py setup.cfg requirements.txt requirements-dev.txt dev-requirements.txt Pipfile poetry.lock; do
    if [[ -f $file ]]; then
      python_manifest=true
      break
    fi
  done
  if [[ -d tests || -d test || -f pytest.ini || -f tox.ini ]]; then
    python_manifest=true
  fi

  local python_manager=""
  if python_manager=$(detect_python_manager); then
    local note="Python project via $python_manager"
    local -a tests=()
    if [[ -f tox.ini ]]; then
      if command -v tox >/dev/null 2>&1 || python_module_available tox; then
        tests+=("tox")
      else
        warnings+=("tox.ini detected but tox is not installed; add tox to the environment for automated runs.")
      fi
    fi
    if python_tests_present; then
      if command -v pytest >/dev/null 2>&1 || python_module_available pytest; then
        tests+=("pytest")
      else
        warnings+=("Pytest-style tests detected but pytest is missing; install it to enable automation.")
      fi
    fi
    if (( ${#tests[@]} )); then
      local IFS=', '
      note+=" (tests: ${tests[*]})"
    elif [[ -f tox.ini || python_tests_present ]]; then
      note+=" (tests detected; install pytest/tox to run them)"
    fi
    note+="; cx --depscan can review outdated packages"
    capabilities+=("$note")
  elif $python_manifest; then
    warnings+=("Python manifests detected but Poetry/Pipenv/pip aren't available; install a dependency manager so --start can bootstrap Python.")
  fi

  if $pushed; then
    popd >/dev/null || true
  fi

  echo "Detected automation opportunities:"
  if (( ${#capabilities[@]} )); then
    local entry
    for entry in "${capabilities[@]}"; do
      printf '  - %s\n' "$entry"
    done
  else
    echo "  - None detected yet. Add build/test manifests so cx --start can assist."
  fi

  if (( ${#warnings[@]} )); then
    echo
    echo "Gaps to address before automation:"
    local warn
    for warn in "${warnings[@]}"; do
      printf '  - %s\n' "$warn"
    done
  fi
}

ESTIMATE=false
ESTIMATE_DETAIL=false
DRY=false
OFFLINE=false
REPLAY=false
SHOW_DICT=false
SHOW_CONFIG=false
SHOW_CONFIG_LIST=false
SHOW_CONFIG_WHICH=false
SHOW_CONFIG_DIFF=false
SHOW_CONFIG_ENV=false
SHOW_METRICS=false
SHOW_RECOMMENDATIONS=false
RECOMMENDATIONS_FILTERS=()
RECOMMENDATIONS_SEARCHES=()
SHOW_ESTIMATE_SUMMARY=false
SHOW_GRID=false
SHOW_REL=false
SHOW_TOPICS=false
SHOW_AUDIT=false
SHOW_INSPECT=false
SHOW_HOTSPOTS=false
SHOW_STALE=false
SHOW_LINT=false
SHOW_LOCATE=false
SHOW_WEAKPOINTS=false
FIX=false
RUN_FORMAT=false
RUN_DEPSCAN=false
RUN_BASELINE=false
RUN_START=false
RUN_IMPROVE=false
RUN_ADDITIVE=false
RUN_ENHANCE=false
RUN_MODULES=false
RUN_SCAFFOLD=false
RUN_BACKLOG=false
RUN_DOCTOR=false
SKIP_INSTALL=false
SKIP_TESTS=false
MODULES_MODE=""
ADDITIVE_MODE="${CX_ADDITIVE_MODE:-plan}"
ARGS=()

if [[ -n "${CX_START_SKIP_INSTALL:-}" ]]; then
  SKIP_INSTALL=true
fi
if [[ -n "${CX_START_SKIP_TESTS:-}" ]]; then
  SKIP_TESTS=true
fi

for arg in "$@"; do
  case "$arg" in
    --estimate)
      ESTIMATE=true
      ;;
    --estimate-detail)
      ESTIMATE=true
      ESTIMATE_DETAIL=true
      ;;
    --estimate-summary)
      SHOW_ESTIMATE_SUMMARY=true
      ;;
    --dry)
      DRY=true
      ;;
    --offline)
      OFFLINE=true
      ;;
    --replay)
      REPLAY=true
      ;;
    --dict)
      SHOW_DICT=true
      ;;
    --config)
      SHOW_CONFIG=true
      ;;
    --config-list)
      SHOW_CONFIG_LIST=true
      ;;
    --config-which)
      SHOW_CONFIG_WHICH=true
      CONFIG_WHICH_KEYS=""
      ;;
    --config-which=*)
      SHOW_CONFIG_WHICH=true
      CONFIG_WHICH_KEYS="${arg#--config-which=}"
      ;;
    --config-validate)
      SHOW_CONFIG_VALIDATE=true
      CONFIG_VALIDATE_SCOPE=""
      ;;
    --config-validate=*)
      SHOW_CONFIG_VALIDATE=true
      CONFIG_VALIDATE_SCOPE="${arg#--config-validate=}"
      ;;
    --config-env)
      SHOW_CONFIG_ENV=true
      CONFIG_ENV_FORMAT=""
      ;;
    --config-env=*)
      SHOW_CONFIG_ENV=true
      CONFIG_ENV_FORMAT="${arg#--config-env=}"
      ;;
    --config-diff)
      SHOW_CONFIG_DIFF=true
      CONFIG_DIFF_PAIR=""
      ;;
    --config-diff=*)
      SHOW_CONFIG_DIFF=true
      CONFIG_DIFF_PAIR="${arg#--config-diff=}"
      ;;
    --config-export)
      CONFIG_EXPORT_REQUESTED=true
      CONFIG_EXPORT_PATH=""
      ;;
    --config-export=*)
      CONFIG_EXPORT_REQUESTED=true
      CONFIG_EXPORT_PATH="${arg#--config-export=}"
      ;;
    --config-template)
      SHOW_CONFIG_TEMPLATE=true
      CONFIG_TEMPLATE_SPEC=""
      ;;
    --config-template=*)
      SHOW_CONFIG_TEMPLATE=true
      CONFIG_TEMPLATE_SPEC="${arg#--config-template=}"
      ;;
    --config-set=*)
      CONFIG_MANAGE=true
      CONFIG_SET_ENTRIES+=("${arg#--config-set=}")
      ;;
    --config-unset=*)
      CONFIG_MANAGE=true
      CONFIG_UNSET_KEYS+=("${arg#--config-unset=}")
      ;;
    --config-import=*)
      CONFIG_MANAGE=true
      CONFIG_IMPORT_FILES+=("${arg#--config-import=}")
      ;;
    --config-reset)
      CONFIG_MANAGE=true
      CONFIG_RESET_SPECS+=("")
      ;;
    --config-reset=*)
      CONFIG_MANAGE=true
      CONFIG_RESET_SPECS+=("${arg#--config-reset=}")
      ;;
    --config-edit)
      CONFIG_MANAGE=true
      CONFIG_EDIT_SPECS+=("")
      ;;
    --config-edit=*)
      CONFIG_MANAGE=true
      CONFIG_EDIT_SPECS+=("${arg#--config-edit=}")
      ;;
    --config-scope=*)
      CONFIG_SCOPE="${arg#--config-scope=}"
      ;;
    --config-path=*)
      CONFIG_CUSTOM_PATH="${arg#--config-path=}"
      ;;
    --project-root=*)
      PROJECT_ROOT_OVERRIDE="${arg#--project-root=}"
      ;;
    --select-root)
      SELECT_PROJECT_ROOT=true
      ;;
    --metrics)
      SHOW_METRICS=true
      ;;
    --recommendations)
      SHOW_RECOMMENDATIONS=true
      ;;
    --recommendations-filter=*)
      SHOW_RECOMMENDATIONS=true
      RECOMMENDATIONS_FILTERS+=("${arg#--recommendations-filter=}")
      ;;
    --recommendations-search=*)
      SHOW_RECOMMENDATIONS=true
      RECOMMENDATIONS_SEARCHES+=("${arg#--recommendations-search=}")
      ;;
    --grid)
      SHOW_GRID=true
      ;;
    --relations)
      SHOW_REL=true
      ;;
    --topics)
      SHOW_TOPICS=true
      ;;
    --locate)
      SHOW_LOCATE=true
      ;;
    --weakpoints)
      SHOW_WEAKPOINTS=true
      ;;
    --audit)
      SHOW_AUDIT=true
      ;;
    --inspect)
      SHOW_INSPECT=true
      ;;
    --hotspots)
      SHOW_HOTSPOTS=true
      ;;
    --stale)
      SHOW_STALE=true
      ;;
    --lint)
      SHOW_LINT=true
      ;;
    --fix)
      SHOW_LINT=true
      FIX=true
      ;;
    --baseline)
      RUN_BASELINE=true
      ;;
    --start)
      RUN_START=true
      ;;
    --format)
      RUN_FORMAT=true
      ;;
    --depscan)
      RUN_DEPSCAN=true
      ;;
    --improve)
      RUN_IMPROVE=true
      ;;
    --additive)
      RUN_ADDITIVE=true
      ;;
    --additive=*)
      RUN_ADDITIVE=true
      ADDITIVE_MODE="${arg#--additive=}"
      ;;
    --enhance)
      RUN_ENHANCE=true
      ;;
    --modules)
      RUN_MODULES=true
      ;;
    --modules=*)
      RUN_MODULES=true
      MODULES_MODE="${arg#--modules=}"
      ;;
    --scaffold)
      RUN_SCAFFOLD=true
      ;;
    --backlog)
      RUN_BACKLOG=true
      ;;
    --doctor)
      RUN_DOCTOR=true
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      ARGS+=("$arg")
      ;;
  esac
done

if $SHOW_CONFIG_ENV; then
  if [[ -z $CONFIG_ENV_FORMAT ]]; then
    CONFIG_ENV_FORMAT="shell"
  else
    CONFIG_ENV_FORMAT="${CONFIG_ENV_FORMAT,,}"
  fi
fi

if $RUN_ADDITIVE; then
  RUN_IMPROVE=false
fi

ROLE=""
GOAL=""
CONS=""
REASON=""
OUT=""
RAW=""
TOPICS=""
MODEL="${CX_MODEL:-gpt-3.5-turbo}"
TEMP="${CX_TEMP:-0.7}"
if [[ -n $PROJECT_ROOT_OVERRIDE ]]; then
  PROJECT_ROOT_OVERRIDE=$(expand_path "$PROJECT_ROOT_OVERRIDE")
fi

if $SELECT_PROJECT_ROOT; then
  if ! PROJECT_ROOT_OVERRIDE=$(select_project_directory "${PROJECT_ROOT_OVERRIDE:-$INITIAL_CWD}"); then
    echo "Project root selection cancelled." >&2
    exit 1
  fi
fi

if [[ -n $PROJECT_ROOT_OVERRIDE ]]; then
  if [[ ! -d $PROJECT_ROOT_OVERRIDE ]]; then
    echo "Project root override '$PROJECT_ROOT_OVERRIDE' does not exist." >&2
    exit 1
  fi
  PROJECT_ROOT="$PROJECT_ROOT_OVERRIDE"
  echo "Selected project root: $PROJECT_ROOT" >&2
else
  PROJECT_ROOT=$(resolve_project_root "$INITIAL_CWD")
  [[ -n "$PROJECT_ROOT" ]] || PROJECT_ROOT="$INITIAL_CWD"
fi
project=$(derive_project_name "$PROJECT_ROOT" "$INITIAL_CWD")
PROJECT_DOT_CX="$PROJECT_ROOT/.cx"
PROJECT_DICT="$PROJECT_DOT_CX/dict"
PROJECT_USAGE="$PROJECT_DOT_CX/usage"
ENHANCE_PLAN_PATH=""
BACKLOG_REPORT_PATH=""
MODULE_SCAFFOLD_LOG_PATH=""

if $CONFIG_MANAGE; then
  manage_config_updates
  CONFIG_MANAGE_PERFORMED=true
fi

load_config_defaults "$CX_HOME/config"
load_config_defaults "$PROJECT_DOT_CX/config"
if [[ -n $CONFIG_CUSTOM_PATH ]]; then
  custom_path=$(expand_path "$CONFIG_CUSTOM_PATH")
  if [[ -n $custom_path ]]; then
    load_config_defaults "$custom_path"
  fi
  unset custom_path
fi
if [[ -n "${CX_CONFIG:-}" ]]; then
  IFS=':' read -ra CX_EXTRA_CONFIGS <<<"${CX_CONFIG}"
  load_config_defaults "${CX_EXTRA_CONFIGS[@]}"
  unset CX_EXTRA_CONFIGS
fi

if $CONFIG_MANAGE_PERFORMED; then
  action_needed=false
  if $SHOW_CONFIG || $SHOW_CONFIG_LIST || $SHOW_CONFIG_WHICH || $SHOW_CONFIG_DIFF || $SHOW_CONFIG_VALIDATE || $SHOW_CONFIG_ENV || $SHOW_CONFIG_TEMPLATE || $SHOW_DICT || $SHOW_METRICS || $SHOW_RECOMMENDATIONS || $SHOW_ESTIMATE_SUMMARY || $SHOW_GRID || $SHOW_REL || $SHOW_TOPICS || \
     $SHOW_AUDIT || $SHOW_INSPECT || $SHOW_HOTSPOTS || $SHOW_STALE || $SHOW_LINT || $SHOW_LOCATE || \
     $SHOW_WEAKPOINTS; then
    action_needed=true
  fi
  if $CONFIG_EXPORT_REQUESTED; then
    action_needed=true
  fi
  if $RUN_FORMAT || $RUN_DEPSCAN || $RUN_BASELINE || $RUN_START || $RUN_IMPROVE || $RUN_ADDITIVE || \
     $RUN_ENHANCE || $RUN_MODULES || $RUN_SCAFFOLD || $RUN_BACKLOG || $RUN_DOCTOR; then
    action_needed=true
  fi
  if [[ $action_needed == false && ${#ARGS[@]} -eq 0 ]]; then
    exit 0
  fi
fi

if [[ -n "$MODULES_MODE" ]]; then
  local_mode="${MODULES_MODE,,}"
  case "$local_mode" in
    markdown|json|apply)
      MODULES_MODE="$local_mode"
      ;;
    *)
      echo "Unknown modules mode '$MODULES_MODE'; falling back to markdown." >&2
      MODULES_MODE="markdown"
      ;;
  esac
fi

ADDITIVE_MODE="${ADDITIVE_MODE,,}"
case "$ADDITIVE_MODE" in
  ""|plan|apply|full)
    if [[ -z "$ADDITIVE_MODE" ]]; then
      ADDITIVE_MODE="plan"
    fi
    ;;
  *)
    echo "Unknown additive mode '$ADDITIVE_MODE'; falling back to plan." >&2
    ADDITIVE_MODE="plan"
    ;;
esac

for pair in "${CONFIG_ARGS[@]}"; do
  key="${pair%%=*}"
  value="${pair#*=}"
  case "$key" in
    role) ROLE="$value" ;;
    goal) GOAL="$value" ;;
    cons) CONS="$value" ;;
    reason) REASON="$value" ;;
    out) OUT="$value" ;;
    raw) RAW="$value" ;;
    topic) TOPICS="$value" ;;
    model) MODEL="$value" ;;
    temp) TEMP="$value" ;;
  esac
done

for pair in "${ARGS[@]}"; do
  key="${pair%%=*}"
  value="${pair#*=}"
  case "$key" in
    role)
      ROLE="$value"
      CLI_OVERRIDES+=("role=$value")
      CLI_OVERRIDE_MAP["role"]="$value"
      ;;
    goal)
      GOAL="$value"
      CLI_OVERRIDES+=("goal=$value")
      CLI_OVERRIDE_MAP["goal"]="$value"
      ;;
    cons|constraints)
      CONS="$value"
      CLI_OVERRIDES+=("cons=$value")
      CLI_OVERRIDE_MAP["cons"]="$value"
      ;;
    reason|reasons)
      REASON="$value"
      CLI_OVERRIDES+=("reason=$value")
      CLI_OVERRIDE_MAP["reason"]="$value"
      ;;
