#!/usr/bin/env bash
set -euo pipefail

CX_HOME="${CX_HOME:-$HOME/.cx}"

usage() {
  cat <<'USAGE' >&2
Usage: cx role=VALUE goal=VALUE [cons=VAL] [reason=VAL] [out=VAL] [raw=VAL] [topic=VAL] [model=VAL] [temp=VAL] [--estimate] [--dry] [--offline] [--replay] [--dict] [--metrics] [--grid] [--relations] [--topics] [--audit] [--inspect] [--hotspots] [--stale] [--lint] [--fix] [--baseline] [--start]
USAGE
}

run_baseline_step() {
  local label=$1
  shift
  echo >&2
  echo ">>> $label" >&2
  if "$@"; then
    echo ">>> $label completed" >&2
    return 0
  else
    local rc=$?
    echo ">>> $label failed (exit $rc)" >&2
    return $rc
  fi
}

run_baseline_suite() {
  local status=0
  echo "Starting baseline repository automation for $project" >&2
  local -a lint_cmd=("$0" "--lint")
  if $FIX; then
    lint_cmd+=("--fix")
  fi
  run_baseline_step "Lint checks" "${lint_cmd[@]}" || status=1
  run_baseline_step "Repository audit" "$0" "--audit" || status=1
  run_baseline_step "Repository inspection" "$0" "--inspect" || status=1
  if command -v git >/dev/null 2>&1 && git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    run_baseline_step "Hotspot analysis" "$0" "--hotspots" || status=1
    run_baseline_step "Stale file scan" "$0" "--stale" || status=1
  else
    echo ">>> Skipping git-based analyses (repository not detected)" >&2
  fi
  if (( status == 0 )); then
    echo "Baseline automation complete. Review the logs under $CX_HOME for details." >&2
  else
    echo "Baseline automation finished with issues. Review the output above." >&2
  fi
  return $status
}

run_custom_block() {
  local label=$1
  local commands=$2
  local status=0

  CUSTOM_BLOCK_LAST_RAN=false

  while IFS= read -r cmd; do
    if [[ $cmd =~ ^[[:space:]]*$ ]]; then
      continue
    fi
    if [[ $cmd =~ ^[[:space:]]*# ]]; then
      continue
    fi
    CUSTOM_BLOCK_LAST_RAN=true
    run_baseline_step "$label: $cmd" bash -lc "$cmd" || status=1
  done <<<"$commands"

  return $status
}

detect_node_manager() {
  if [[ ! -f package.json ]]; then
    return 1
  fi
  if [[ -f bun.lockb || -f bunfig.toml ]] && command -v bun >/dev/null 2>&1; then
    printf 'bun'
    return 0
  fi
  if [[ -f pnpm-lock.yaml ]] && command -v pnpm >/dev/null 2>&1; then
    printf 'pnpm'
    return 0
  fi
  if [[ -f yarn.lock ]] && command -v yarn >/dev/null 2>&1; then
    printf 'yarn'
    return 0
  fi
  if command -v npm >/dev/null 2>&1; then
    printf 'npm'
    return 0
  fi
  return 1
}

node_dependencies_ready() {
  [[ -d node_modules || -f .pnp.cjs || -f .pnp.js ]]
}

run_node_install() {
  local manager=$1
  case "$manager" in
    bun)
      bun install --frozen-lockfile
      ;;
    pnpm)
      pnpm install --frozen-lockfile
      ;;
    yarn)
      yarn install --silent --frozen-lockfile
      ;;
    npm)
      npm install --no-audit --no-fund
      ;;
    *)
      echo "Unknown Node package manager: $manager" >&2
      return 1
      ;;
  esac
}

npm_has_script() {
  local script=$1
  [[ -f package.json ]] || return 1
  command -v python3 >/dev/null 2>&1 || return 1
  python3 - "$script" <<'PY'
import json, sys
script = sys.argv[1]
try:
    with open('package.json', encoding='utf-8') as fh:
        data = json.load(fh)
except Exception:
    sys.exit(1)
scripts = data.get('scripts') or {}
cmd = scripts.get(script)
if isinstance(cmd, str) and cmd.strip():
    sys.exit(0)
sys.exit(1)
PY
}

run_node_script() {
  local manager=$1
  local script=$2
  case "$manager" in
    bun)
      bun run "$script"
      ;;
    pnpm)
      pnpm run "$script"
      ;;
    yarn)
      yarn run "$script"
      ;;
    npm)
      npm run "$script"
      ;;
    *)
      echo "Unknown Node package manager: $manager" >&2
      return 1
      ;;
  esac
}

python_module_available() {
  local module=$1
  command -v python3 >/dev/null 2>&1 || return 1
  python3 - "$module" <<'PY'
import importlib.util, sys
module = sys.argv[1]
spec = importlib.util.find_spec(module)
sys.exit(0 if spec is not None else 1)
PY
}

python_tests_present() {
  [[ -d tests || -d test || -f pytest.ini || -f tox.ini ]]
}

python_has_pip() {
  if ! command -v python3 >/dev/null 2>&1; then
    return 1
  fi
  if python3 -m pip --version >/dev/null 2>&1; then
    return 0
  fi
  return 1
}

detect_python_manager() {
  if command -v poetry >/dev/null 2>&1; then
    if [[ -f poetry.lock ]]; then
      printf 'poetry'
      return 0
    fi
    if [[ -f pyproject.toml ]] && grep -q '\[tool\.poetry\]' pyproject.toml; then
      printf 'poetry'
      return 0
    fi
  fi
  if command -v pipenv >/dev/null 2>&1 && [[ -f Pipfile ]]; then
    printf 'pipenv'
    return 0
  fi
  if python_has_pip; then
    if [[ -f requirements.txt || -f requirements-dev.txt || -f dev-requirements.txt ]]; then
      printf 'pip'
      return 0
    fi
    if [[ -f pyproject.toml || -f setup.py || -f setup.cfg ]]; then
      printf 'pip'
      return 0
    fi
  fi
  return 1
}

run_python_install() {
  local manager=$1
  case "$manager" in
    poetry)
      poetry install
      ;;
    pipenv)
      pipenv install --dev
      ;;
    pip)
      local -a pip_args=()
      if [[ -z "${VIRTUAL_ENV:-}" ]]; then
        local current_uid=${EUID:-$(id -u)}
        if [[ $current_uid -ne 0 ]]; then
          pip_args+=(--user)
        fi
      fi
      local rc=0
      local ran=false
      local req
      for req in requirements.txt requirements-dev.txt dev-requirements.txt; do
        if [[ -f $req ]]; then
          ran=true
          if ! python3 -m pip install "${pip_args[@]}" -r "$req"; then
            rc=1
          fi
        fi
      done
      if ! $ran; then
        if [[ -f pyproject.toml || -f setup.py || -f setup.cfg ]]; then
          ran=true
          if ! python3 -m pip install "${pip_args[@]}" -e .; then
            rc=1
          fi
        fi
      fi
      if ! $ran; then
        echo ">>> No Python requirements found to install" >&2
      fi
      return $rc
      ;;
    *)
      echo "Unknown Python dependency manager: $manager" >&2
      return 1
      ;;
  esac
}

has_make_target() {
  local target=$1
  if [[ ! -f Makefile && ! -f makefile ]]; then
    return 1
  fi
  make -q "$target" >/dev/null 2>&1
  local rc=$?
  [[ $rc -eq 0 || $rc -eq 1 ]]
}

ruby_project_present() {
  [[ -f Gemfile || -f gems.rb ]]
}

run_bundle_install() {
  bundle install --jobs "${BUNDLE_JOBS:-4}" --retry "${BUNDLE_RETRY:-3}"
}

bundle_rspec_available() {
  command -v bundle >/dev/null 2>&1 || return 1
  bundle exec rspec --version >/dev/null 2>&1
}

bundle_has_task() {
  local task=$1
  command -v bundle >/dev/null 2>&1 || return 1
  local tasks
  if ! tasks=$(bundle exec rake -AT 2>/dev/null); then
    return 1
  fi
  grep -E "^rake ${task}(\\[|$)" <<<"$tasks" >/dev/null 2>&1
}

composer_project_present() {
  [[ -f composer.json ]]
}

composer_has_script() {
  local script=$1
  [[ -f composer.json ]] || return 1
  command -v python3 >/dev/null 2>&1 || return 1
  python3 - "$script" <<'PY'
import json, sys
script = sys.argv[1]
try:
    with open('composer.json', encoding='utf-8') as fh:
        data = json.load(fh)
except Exception:
    sys.exit(1)
scripts = data.get('scripts') or {}
cmd = scripts.get(script)
if isinstance(cmd, str) and cmd.strip():
    sys.exit(0)
sys.exit(1)
PY
}

run_composer_script() {
  local script=$1
  composer run-script --no-interaction "$script"
}

mix_project_present() {
  [[ -f mix.exs ]]
}

mix_tests_present() {
  [[ -d test ]]
}

stack_project_present() {
  [[ -f stack.yaml ]]
}

stack_tests_present() {
  if cabal_tests_present; then
    return 0
  fi
  [[ -d test || -d tests ]]
}

cabal_project_present() {
  compgen -G "*.cabal" >/dev/null 2>&1
}

cabal_tests_present() {
  local file
  for file in *.cabal; do
    if [[ -e $file ]] && grep -Eq '^[[:space:]]*test-suite[[:space:]]+' "$file"; then
      return 0
    fi
  done
  return 1
}

swift_package_present() {
  [[ -f Package.swift ]]
}

swift_tests_present() {
  [[ -d Tests ]]
}

sbt_project_present() {
  [[ -f build.sbt || -d project || -d project/project ]]
}

sbt_tests_present() {
  [[ -d src/test || -d src/test/scala || -d src/test/java || -d src/test/kotlin ]]
}

flutter_project_present() {
  [[ -f pubspec.yaml ]] || return 1
  if grep -Eq '^\s*flutter:' pubspec.yaml 2>/dev/null || grep -Eq 'sdk:\s*flutter' pubspec.yaml 2>/dev/null; then
    return 0
  fi
  return 1
}

flutter_tests_present() {
  [[ -d test || -d integration_test ]]
}

dart_project_present() {
  [[ -f pubspec.yaml ]] || return 1
  if flutter_project_present; then
    return 1
  fi
  return 0
}

dart_tests_present() {
  [[ -d test ]]
}

dotnet_project_present() {
  local file
  for file in *.sln *.csproj *.fsproj *.vbproj; do
    if [[ -e $file ]]; then
      return 0
    fi
  done
  return 1
}

maven_project_present() {
  [[ -f pom.xml ]]
}

gradle_project_present() {
  [[ -f build.gradle || -f build.gradle.kts || -f settings.gradle || -f settings.gradle.kts || -f gradlew ]]
}

cmake_project_present() {
  [[ -f CMakeLists.txt ]]
}

cmake_build_dir() {
  printf '%s' "${CX_CMAKE_BUILD_DIR:-build}"
}

run_cmake_configure() {
  local build_dir
  build_dir=$(cmake_build_dir)
  local -a extra_args=()
  if [[ -n "${CX_CMAKE_CONFIGURE_ARGS:-}" ]]; then
    # shellcheck disable=SC2206
    extra_args=(${CX_CMAKE_CONFIGURE_ARGS})
  fi
  cmake -S . -B "$build_dir" "${extra_args[@]}"
}

run_cmake_build() {
  local build_dir
  build_dir=$(cmake_build_dir)
  local -a build_args=()
  if [[ -n "${CX_CMAKE_BUILD_TARGET:-}" ]]; then
    build_args+=(--target "${CX_CMAKE_BUILD_TARGET}")
  fi
  if [[ -n "${CX_CMAKE_BUILD_ARGS:-}" ]]; then
    # shellcheck disable=SC2206
    build_args+=(${CX_CMAKE_BUILD_ARGS})
  fi
  cmake --build "$build_dir" "${build_args[@]}"
}

cmake_ctest_ready() {
  local build_dir
  build_dir=$(cmake_build_dir)
  [[ -d "$build_dir" ]] || return 1
  [[ -f "$build_dir/CTestTestfile.cmake" || -d "$build_dir/Testing" ]]
}

run_ctest_suite() {
  local build_dir
  build_dir=$(cmake_build_dir)
  local -a ctest_args=(--output-on-failure)
  if [[ -n "${CX_CTEST_ARGS:-}" ]]; then
    ctest_args=()
    # shellcheck disable=SC2206
    ctest_args=(${CX_CTEST_ARGS})
  fi
  (cd "$build_dir" && ctest "${ctest_args[@]}")
}

run_project_actions() {
  local status=0
  local ran_any=false

  if command -v git >/dev/null 2>&1 && git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    run_baseline_step "Git status summary" git status -sb || status=1
    ran_any=true
  fi

  local node_manager
  if node_manager=$(detect_node_manager); then
    local manager_label=$node_manager
    if ! $SKIP_INSTALL && ! node_dependencies_ready; then
      run_baseline_step "Install Node dependencies ($manager_label)" run_node_install "$node_manager" || status=1
      ran_any=true
    elif $SKIP_INSTALL && ! node_dependencies_ready; then
      echo ">>> Skipping Node dependency installation ($manager_label) because CX_START_SKIP_INSTALL is set" >&2
    fi
    if npm_has_script lint; then
      run_baseline_step "Run $manager_label lint script" run_node_script "$node_manager" "lint" || status=1
      ran_any=true
    fi
    if npm_has_script test; then
      if ! $SKIP_TESTS; then
        run_baseline_step "Run $manager_label test script" run_node_script "$node_manager" "test" || status=1
        ran_any=true
      else
        echo ">>> Skipping $manager_label test script because CX_START_SKIP_TESTS is set" >&2
      fi
    fi
  elif [[ -f package.json ]]; then
    echo ">>> Detected package.json but no supported Node package manager (npm, yarn, pnpm, bun) was found" >&2
  fi

  if ruby_project_present; then
    if command -v bundle >/dev/null 2>&1; then
      if ! $SKIP_INSTALL; then
        run_baseline_step "Install Ruby gems (bundle)" run_bundle_install || status=1
        ran_any=true
      else
        echo ">>> Skipping bundle install because CX_START_SKIP_INSTALL is set" >&2
      fi
      if ! $SKIP_TESTS; then
        if bundle_rspec_available && [[ -d spec ]]; then
          run_baseline_step "Run bundle exec rspec" bundle exec rspec || status=1
          ran_any=true
        elif bundle_has_task test; then
          run_baseline_step "Run bundle exec rake test" bundle exec rake test || status=1
          ran_any=true
        elif bundle_has_task spec; then
          run_baseline_step "Run bundle exec rake spec" bundle exec rake spec || status=1
          ran_any=true
        fi
      else
        echo ">>> Skipping Ruby test commands because CX_START_SKIP_TESTS is set" >&2
      fi
    else
      echo ">>> Detected Gemfile but the bundle command is unavailable" >&2
    fi
  fi

  if composer_project_present; then
    if command -v composer >/dev/null 2>&1; then
      if ! $SKIP_INSTALL; then
        run_baseline_step "Install PHP dependencies (composer)" composer install --no-interaction || status=1
        ran_any=true
      else
        echo ">>> Skipping composer install because CX_START_SKIP_INSTALL is set" >&2
      fi
      if ! $SKIP_TESTS; then
        if composer_has_script test; then
          run_baseline_step "Run composer test script" run_composer_script test || status=1
          ran_any=true
        elif [[ -x vendor/bin/phpunit ]]; then
          run_baseline_step "Run vendor/bin/phpunit" vendor/bin/phpunit || status=1
          ran_any=true
        fi
      else
        echo ">>> Skipping composer test commands because CX_START_SKIP_TESTS is set" >&2
      fi
    else
      echo ">>> Detected composer.json but composer is not installed" >&2
    fi
  fi

  if mix_project_present; then
    if command -v mix >/dev/null 2>&1; then
      if ! $SKIP_INSTALL; then
        run_baseline_step "Install Elixir dependencies (mix deps.get)" mix deps.get || status=1
        ran_any=true
      else
        echo ">>> Skipping mix deps.get because CX_START_SKIP_INSTALL is set" >&2
      fi
      if mix_tests_present; then
        if ! $SKIP_TESTS; then
          run_baseline_step "Run mix test" mix test || status=1
          ran_any=true
        else
          echo ">>> Skipping mix test because CX_START_SKIP_TESTS is set" >&2
        fi
      fi
    else
      echo ">>> Detected mix.exs but the mix command is unavailable" >&2
    fi
  fi

  if stack_project_present; then
    if command -v stack >/dev/null 2>&1; then
      if ! $SKIP_INSTALL; then
        run_baseline_step "Install Haskell dependencies (stack build --only-dependencies)" stack build --only-dependencies || status=1
        ran_any=true
      else
        echo ">>> Skipping stack build --only-dependencies because CX_START_SKIP_INSTALL is set" >&2
      fi
      if stack_tests_present; then
        if ! $SKIP_TESTS; then
          run_baseline_step "Run stack test" stack test || status=1
          ran_any=true
        else
          echo ">>> Skipping stack test because CX_START_SKIP_TESTS is set" >&2
        fi
      fi
    else
      echo ">>> Detected stack.yaml but the stack command is unavailable" >&2
    fi
  fi

  if cabal_project_present; then
    if command -v cabal >/dev/null 2>&1; then
      if ! $SKIP_INSTALL; then
        run_baseline_step "Prepare Haskell dependencies (cabal v2-build --only-dependencies)" cabal v2-build --only-dependencies || status=1
        ran_any=true
      else
        echo ">>> Skipping cabal v2-build --only-dependencies because CX_START_SKIP_INSTALL is set" >&2
      fi
      if cabal_tests_present; then
        if ! $SKIP_TESTS; then
          run_baseline_step "Run cabal v2-test" cabal v2-test || status=1
          ran_any=true
        else
          echo ">>> Skipping cabal v2-test because CX_START_SKIP_TESTS is set" >&2
        fi
      fi
    else
      echo ">>> Detected Cabal files but the cabal command is unavailable" >&2
    fi
  fi

  if swift_package_present; then
    if command -v swift >/dev/null 2>&1; then
      if ! $SKIP_INSTALL; then
        run_baseline_step "Resolve Swift package dependencies" swift package resolve || status=1
        ran_any=true
      else
        echo ">>> Skipping swift package resolve because CX_START_SKIP_INSTALL is set" >&2
      fi
      if swift_tests_present; then
        if ! $SKIP_TESTS; then
          run_baseline_step "Run swift test" swift test || status=1
          ran_any=true
        else
          echo ">>> Skipping swift test because CX_START_SKIP_TESTS is set" >&2
        fi
      fi
    else
      echo ">>> Detected Package.swift but the swift command is unavailable" >&2
    fi
  fi

  if sbt_project_present; then
    if command -v sbt >/dev/null 2>&1; then
      if ! $SKIP_INSTALL; then
        run_baseline_step "Warm sbt dependencies" sbt update || status=1
        ran_any=true
      else
        echo ">>> Skipping sbt update because CX_START_SKIP_INSTALL is set" >&2
      fi
      if sbt_tests_present; then
        if ! $SKIP_TESTS; then
          run_baseline_step "Run sbt test" sbt test || status=1
          ran_any=true
        else
          echo ">>> Skipping sbt test because CX_START_SKIP_TESTS is set" >&2
        fi
      fi
    else
      echo ">>> Detected sbt build files but sbt is not installed" >&2
    fi
  fi

  if flutter_project_present; then
    if command -v flutter >/dev/null 2>&1; then
      if ! $SKIP_INSTALL; then
        run_baseline_step "Fetch Flutter dependencies" flutter pub get || status=1
        ran_any=true
      else
        echo ">>> Skipping flutter pub get because CX_START_SKIP_INSTALL is set" >&2
      fi
      if flutter_tests_present; then
        if ! $SKIP_TESTS; then
          run_baseline_step "Run flutter test" flutter test || status=1
          ran_any=true
        else
          echo ">>> Skipping flutter test because CX_START_SKIP_TESTS is set" >&2
        fi
      fi
    else
      echo ">>> Detected Flutter pubspec but the flutter command is unavailable" >&2
    fi
  elif dart_project_present; then
    if command -v dart >/dev/null 2>&1; then
      if ! $SKIP_INSTALL; then
        run_baseline_step "Fetch Dart dependencies" dart pub get || status=1
        ran_any=true
      else
        echo ">>> Skipping dart pub get because CX_START_SKIP_INSTALL is set" >&2
      fi
      if dart_tests_present; then
        if ! $SKIP_TESTS; then
          run_baseline_step "Run dart test" dart test || status=1
          ran_any=true
        else
          echo ">>> Skipping dart test because CX_START_SKIP_TESTS is set" >&2
        fi
      fi
    else
      echo ">>> Detected Dart pubspec but the dart command is unavailable" >&2
    fi
  fi

  local python_manager
  if python_manager=$(detect_python_manager); then
    local python_label
    case "$python_manager" in
      poetry) python_label="Poetry" ;;
      pipenv) python_label="Pipenv" ;;
      pip) python_label="pip" ;;
      *) python_label="$python_manager" ;;
    esac
    if ! $SKIP_INSTALL; then
      run_baseline_step "Install Python dependencies ($python_label)" run_python_install "$python_manager" || status=1
      ran_any=true
    else
      echo ">>> Skipping Python dependency installation ($python_label) because CX_START_SKIP_INSTALL is set" >&2
    fi
  else
    local poetry_hint=0
    if [[ -f poetry.lock ]]; then
      poetry_hint=1
    elif [[ -f pyproject.toml ]]; then
      if grep -q '\[tool\.poetry\]' pyproject.toml 2>/dev/null; then
        poetry_hint=1
      fi
    fi
    if (( poetry_hint )) && ! command -v poetry >/dev/null 2>&1; then
      echo ">>> Detected Poetry configuration but the poetry command is unavailable" >&2
    elif [[ -f Pipfile ]] && ! command -v pipenv >/dev/null 2>&1; then
      echo ">>> Detected Pipfile but pipenv is not installed" >&2
    elif [[ -f requirements.txt || -f requirements-dev.txt || -f dev-requirements.txt || -f setup.py || -f setup.cfg || -f pyproject.toml ]] && ! command -v python3 >/dev/null 2>&1; then
      echo ">>> Detected Python requirements but python3 is not installed" >&2
    elif [[ -f requirements.txt || -f requirements-dev.txt || -f dev-requirements.txt || -f setup.py || -f setup.cfg || -f pyproject.toml ]] && ! python_has_pip; then
      echo ">>> Python is available but pip is missing; install pip to automate dependency setup" >&2
    fi
  fi

  if command -v python3 >/dev/null 2>&1; then
    local ran_python_suite=false
    if [[ -f tox.ini ]]; then
      if ! $SKIP_TESTS; then
        if command -v tox >/dev/null 2>&1; then
          run_baseline_step "Run tox test suite" tox -q || status=1
          ran_any=true
          ran_python_suite=true
        elif python_module_available tox; then
          run_baseline_step "Run tox test suite" python3 -m tox -q || status=1
          ran_any=true
          ran_python_suite=true
        else
          echo ">>> Skipping tox run because the tox module is not installed" >&2
        fi
      else
        echo ">>> Skipping tox test suite because CX_START_SKIP_TESTS is set" >&2
      fi
    fi
    if ! $SKIP_TESTS && ! $ran_python_suite && python_tests_present; then
      if python_module_available pytest; then
        run_baseline_step "Run pytest" python3 -m pytest -q || status=1
        ran_any=true
      else
        echo ">>> Skipping pytest run because the pytest module is not installed" >&2
      fi
    elif python_tests_present && $SKIP_TESTS; then
      echo ">>> Skipping pytest run because CX_START_SKIP_TESTS is set" >&2
    fi
  fi

  if command -v make >/dev/null 2>&1; then
    if has_make_target lint; then
      run_baseline_step "Run make lint" make lint || status=1
      ran_any=true
    fi
    if has_make_target test; then
      if ! $SKIP_TESTS; then
        run_baseline_step "Run make test" make test || status=1
        ran_any=true
      else
        echo ">>> Skipping make test because CX_START_SKIP_TESTS is set" >&2
      fi
    fi
  fi

  if [[ -f go.mod ]] && command -v go >/dev/null 2>&1; then
    if ! $SKIP_TESTS; then
      run_baseline_step "Run go test ./..." go test ./... || status=1
      ran_any=true
    else
      echo ">>> Skipping go test ./... because CX_START_SKIP_TESTS is set" >&2
    fi
  fi

  if [[ -f Cargo.toml ]] && command -v cargo >/dev/null 2>&1; then
    if ! $SKIP_TESTS; then
      run_baseline_step "Run cargo test" cargo test || status=1
      ran_any=true
    else
      echo ">>> Skipping cargo test because CX_START_SKIP_TESTS is set" >&2
    fi
  fi

  if dotnet_project_present; then
    if command -v dotnet >/dev/null 2>&1; then
      if ! $SKIP_INSTALL; then
        run_baseline_step "Run dotnet restore" dotnet restore || status=1
        ran_any=true
      else
        echo ">>> Skipping dotnet restore because CX_START_SKIP_INSTALL is set" >&2
      fi
      if ! $SKIP_TESTS; then
        run_baseline_step "Run dotnet test" dotnet test || status=1
        ran_any=true
      else
        echo ">>> Skipping dotnet test because CX_START_SKIP_TESTS is set" >&2
      fi
    else
      echo ">>> Detected .NET solution or project files but the dotnet CLI is unavailable" >&2
    fi
  fi

  if maven_project_present; then
    if command -v mvn >/dev/null 2>&1; then
      if ! $SKIP_INSTALL; then
        run_baseline_step "Prepare Maven dependencies" mvn -B dependency:go-offline || status=1
        ran_any=true
      else
        echo ">>> Skipping Maven dependency warmup because CX_START_SKIP_INSTALL is set" >&2
      fi
      if ! $SKIP_TESTS; then
        run_baseline_step "Run mvn test" mvn -B test || status=1
        ran_any=true
      else
        echo ">>> Skipping mvn test because CX_START_SKIP_TESTS is set" >&2
      fi
    else
      echo ">>> Detected pom.xml but Maven (mvn) is not installed" >&2
    fi
  fi

  if gradle_project_present; then
    local -a gradle_cmd=()
    if [[ -f gradlew ]]; then
      if [[ -x gradlew ]]; then
        gradle_cmd=(./gradlew)
      else
        gradle_cmd=(bash ./gradlew)
      fi
    elif command -v gradle >/dev/null 2>&1; then
      gradle_cmd=(gradle)
    fi
    if (( ${#gradle_cmd[@]} )); then
      if ! $SKIP_TESTS; then
        run_baseline_step "Run Gradle tests" "${gradle_cmd[@]}" test || status=1
        ran_any=true
      else
        echo ">>> Skipping Gradle tests because CX_START_SKIP_TESTS is set" >&2
      fi
    else
      echo ">>> Detected Gradle build files but gradle/gradlew is not available" >&2
    fi
  fi

  if cmake_project_present; then
    if command -v cmake >/dev/null 2>&1; then
      local build_dir
      build_dir=$(cmake_build_dir)
      local configure_ok=false
      if ! $SKIP_INSTALL; then
        if run_baseline_step "Configure CMake project ($build_dir)" run_cmake_configure; then
          configure_ok=true
        else
          status=1
        fi
        ran_any=true
        if $configure_ok; then
          run_baseline_step "Build CMake project ($build_dir)" run_cmake_build || status=1
          ran_any=true
        fi
      else
        echo ">>> Skipping CMake configure/build because CX_START_SKIP_INSTALL is set" >&2
      fi
      if ! $SKIP_TESTS; then
        if command -v ctest >/dev/null 2>&1; then
          if cmake_ctest_ready; then
            run_baseline_step "Run ctest ($build_dir)" run_ctest_suite || status=1
            ran_any=true
          else
            echo ">>> Skipping ctest because $build_dir has no CTest configuration yet; run cmake configure/build first" >&2
          fi
        else
          echo ">>> Detected CMake project but the ctest command is unavailable" >&2
        fi
      else
        echo ">>> Skipping ctest because CX_START_SKIP_TESTS is set" >&2
      fi
    else
      echo ">>> Detected CMakeLists.txt but cmake is not installed" >&2
    fi
  fi

  local extra_install=${CX_START_EXTRA_INSTALL-}
  if [[ -n ${extra_install//[[:space:]]/} ]]; then
    if ! $SKIP_INSTALL; then
      run_custom_block "Custom install" "$extra_install" || status=1
      if $CUSTOM_BLOCK_LAST_RAN; then
        ran_any=true
      fi
    else
      echo ">>> Skipping custom install commands because CX_START_SKIP_INSTALL is set" >&2
    fi
  fi

  local extra_test=${CX_START_EXTRA_TEST-}
  if [[ -n ${extra_test//[[:space:]]/} ]]; then
    if ! $SKIP_TESTS; then
      run_custom_block "Custom test" "$extra_test" || status=1
      if $CUSTOM_BLOCK_LAST_RAN; then
        ran_any=true
      fi
    else
      echo ">>> Skipping custom test commands because CX_START_SKIP_TESTS is set" >&2
    fi
  fi

  local extra_steps=${CX_START_EXTRA_STEPS-}
  if [[ -n ${extra_steps//[[:space:]]/} ]]; then
    run_custom_block "Custom start" "$extra_steps" || status=1
    if $CUSTOM_BLOCK_LAST_RAN; then
      ran_any=true
    fi
  fi

  if ! $ran_any; then
    echo ">>> No additional project-specific actions detected" >&2
  fi

  return $status
}

run_start_suite() {
  local status=0
  echo "Starting project bootstrap automation for $project" >&2
  if ! run_baseline_suite; then
    status=1
  fi
  if ! run_project_actions; then
    status=1
  fi
  if (( status == 0 )); then
    echo "Project bootstrap automation complete. Review generated reports and command output for next steps." >&2
  else
    echo "Project bootstrap automation finished with issues. Review the output above." >&2
  fi
  return $status
}

