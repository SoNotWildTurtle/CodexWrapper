    for ((j=i+1; j<${#syms[@]}-1; j++)); do
      for ((k=j+1; k<${#syms[@]}; k++)); do
        combo="${syms[i]},${syms[j]},${syms[k]}"
        combos["$combo"]=$(( ${combos["$combo"]:-0} + 1 ))
      done
    done
  done
  {
    for c in "${!combos[@]}"; do
      echo "$c=${combos[$c]}"
    done
  } | sort > "$file"
}

# Maintain a neuron-like grid mapping symbols to weighted neighbors
update_symbol_grid() {
  local dir="$CX_HOME/grid"
  mkdir -p "$dir"
  local file="$dir/$project.grid"
  declare -A grid
  if [[ -f "$file" ]]; then
    while IFS=':' read -r center neighbors; do
      [[ -n "$center" ]] || continue
      grid["$center"]="$neighbors"
    done < "$file"
  fi
  local syms=(${!SESSION_SYMS[@]})
  local limit=${CX_REL_SYMBOLS:-9}
  if (( ${#syms[@]} > limit )); then
    syms=("${syms[@]:0:limit}")
  fi
  local i j center n neighbors token name count
  for ((i=0; i<${#syms[@]}; i++)); do
    center="${syms[i]}"
    declare -A counts=()
    neighbors="${grid[$center]-}"
    for token in $neighbors; do
      name="${token%%=*}"
      count="${token##*=}"
      counts[$name]=$count
    done
    for ((j=0; j<${#syms[@]}; j++)); do
      (( i == j )) && continue
      n="${syms[j]}"
      ((counts[$n]++))
    done
    local sorted=$(for name in "${!counts[@]}"; do echo "${counts[$name]} $name"; done | sort -rn | head -n8)
    neighbors=""
    while read -r c n; do
      neighbors+="$n=$c "
    done <<< "$sorted"
    neighbors="${neighbors% }"
    grid["$center"]="$neighbors"
  done
  {
    for c in "${!grid[@]}"; do
      echo "$c:${grid[$c]}"
    done
  } > "$file"
}

