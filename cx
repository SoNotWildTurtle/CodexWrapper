def classify_bucket(score):
    if score >= 4:
        return 'immediate'
    if score >= 2:
        return 'short_term'
    return 'monitor'

def record_decision(language, component, score, reasons, files):
    if score <= 0 or not reasons:
        return
    entry = {
        'language': language,
        'component': nice(component),
        'score': score,
        'reasons': reasons,
    }
    if files:
        entry['files'] = files
    bucket = classify_bucket(score)
    decisions[bucket].append(entry)


def severity_from_metrics(score, total_lines, markers, max_file_lines):
    if score >= 6 or total_lines >= 1000 or markers >= 6 or max_file_lines >= 800:
        return 'critical'
    if score >= 4 or total_lines >= 700 or markers >= 3 or max_file_lines >= 600:
        return 'high'
    return 'medium'


def maybe_record_weak(language, component, score, reasons, metrics):
    total_lines = metrics.get('lines', 0)
    markers = metrics.get('markers', 0)
    max_file_lines = metrics.get('max_file_lines', 0)

    if not reasons and not (total_lines or markers or max_file_lines):
        return

    triggers = [
        score >= 3,
        markers > 0,
        total_lines >= 400,
        max_file_lines >= 400,
    ]
    if not any(triggers):
        return

    entry = {
        'language': language,
        'component': nice(component),
        'score': score,
        'reasons': list(dict.fromkeys(reasons)),
        'severity': severity_from_metrics(score, total_lines, markers, max_file_lines),
    }
    if total_lines:
        entry['lines'] = total_lines
    if markers:
        entry['markers'] = markers
    if max_file_lines:
        entry['max_file_lines'] = max_file_lines
    weak_points.append(entry)

