#!/usr/bin/env bash
set -euo pipefail

CX_HOME="${CX_HOME:-$HOME/.cx}"
INITIAL_CWD=$(pwd)
PROJECT_ROOT=""
PROJECT_ROOT_OVERRIDE=""
SELECT_PROJECT_ROOT=false
ENTERED_PROJECT_ROOT=false
MODULE_REGRESSION_OUTPUT=""
MODULE_REGRESSION_ALLOWED=false

usage() {
  cat <<'USAGE' >&2
Usage: cx role=VALUE goal=VALUE [cons=VAL] [reason=VAL] [out=VAL] [raw=VAL] [topic=VAL] [model=VAL] [temp=VAL] [--estimate] [--estimate-detail] [--estimate-summary] [--dry] [--offline] [--replay] [--dict] [--config] [--config-list] [--config-which[=KEYS]] [--config-diff[=SCOPE[:SCOPE]]] [--config-validate[=SCOPE]] [--config-env[=FORMAT]] [--config-export[=FILE]] [--config-template[=SCOPE]] [--config-set=KEY=VAL] [--config-unset=KEY] [--config-import=FILE] [--config-reset[=SCOPE]] [--config-edit[=SCOPE]] [--config-scope=SCOPE] [--config-path=FILE] [--project-root=PATH] [--select-root] [--metrics] [--recommendations] [--grid] [--relations] [--topics] [--audit] [--inspect] [--hotspots] [--stale] [--lint] [--fix] [--format] [--depscan] [--baseline] [--start] [--improve] [--additive[=MODE]] [--enhance] [--modules[=MODE]] [--scaffold] [--backlog] [--weakpoints] [--doctor] [--locate]
USAGE
}

trim_whitespace() {
  local str=$1
  str="${str#${str%%[!$' \t\r\n']*}}"
  str="${str%${str##*[!$' \t\r\n']}}"
  printf '%s' "$str"
}

CONFIG_ARGS=()
CONFIG_DETAILS=()
CONFIG_UNKNOWN_ENTRIES=()
declare -A CONFIG_LAST_SOURCE=()
declare -A CONFIG_LAST_VALUE=()
CLI_OVERRIDES=()
declare -A CLI_OVERRIDE_MAP=()
CONFIG_SET_ENTRIES=()
CONFIG_UNSET_KEYS=()
CONFIG_IMPORT_FILES=()
CONFIG_RESET_SPECS=()
CONFIG_EDIT_SPECS=()
CONFIG_SCOPE="project"
CONFIG_CUSTOM_PATH=""
CONFIG_MANAGE=false
CONFIG_MANAGE_PERFORMED=false
CONFIG_DIFF_PAIR=""
SHOW_CONFIG_WHICH=false
CONFIG_WHICH_KEYS=""
SHOW_CONFIG_VALIDATE=false
CONFIG_VALIDATE_SCOPE=""
CONFIG_EXPORT_REQUESTED=false
CONFIG_EXPORT_PATH=""
CONFIG_ENV_FORMAT=""
SHOW_CONFIG_TEMPLATE=false
CONFIG_TEMPLATE_SPEC=""

ORIGINAL_CX_MODEL="${CX_MODEL:-}"
ORIGINAL_CX_TEMP="${CX_TEMP:-}"

expand_path() {
  local path=$1
  path=$(trim_whitespace "${path}")
  if [[ -z $path ]]; then
    printf '%s' ""
    return 0
  fi
  if command -v python3 >/dev/null 2>&1; then
    python3 - "$path" "$INITIAL_CWD" "$HOME" <<'PY'
import os
import sys

raw = sys.argv[1]
initial = sys.argv[2]
home = sys.argv[3]

if raw.startswith('~'):
    raw = os.path.join(home, raw[1:])

if not os.path.isabs(raw):
    raw = os.path.join(initial, raw)

print(os.path.normpath(raw))
PY
    return 0
  fi

  if [[ $path == ~* ]]; then
    path="$HOME${path:1}"
  fi
  if [[ $path != /* ]]; then
    path="$INITIAL_CWD/$path"
  fi
  printf '%s' "$path"
}

select_project_directory() {
  local initial=${1:-$INITIAL_CWD}
  local selection=""
  local os=${OSTYPE:-}

  if [[ -n $initial ]]; then
    initial=$(expand_path "$initial")
  fi
  if [[ -z $initial || ! -d $initial ]]; then
    initial="$INITIAL_CWD"
  fi

  local is_wsl=0
  if [[ -f /proc/sys/kernel/osrelease ]] && grep -qi 'microsoft' /proc/sys/kernel/osrelease 2>/dev/null; then
    is_wsl=1
  fi
  local is_windows_shell=0
  case "$os" in
    msys*|cygwin*|win32*)
      is_windows_shell=1
      ;;
  esac

  case "$os" in
    darwin*)
      if command -v osascript >/dev/null 2>&1; then
        local escaped
        escaped=${initial//"/\\"}
        local apple_output=""
        if apple_output=$(osascript \
          -e "set initialFolder to POSIX file \"$escaped\"" \
          -e 'try' \
          -e '  set chosenFolder to choose folder with prompt "Select project root" default location initialFolder' \
          -e '  POSIX path of chosenFolder' \
          -e 'on error' \
          -e '  ""' \
          -e 'end try' 2>/dev/null);
        then
          selection=$apple_output
          selection=${selection%%$'\r'}
          selection=${selection%$'\n'}
        fi
      fi
      ;;
    *)
      if command -v zenity >/dev/null 2>&1; then
        selection=$(zenity --file-selection --directory --title="Select project root" --filename="$initial/" 2>/dev/null || true)
      elif command -v kdialog >/dev/null 2>&1; then
        selection=$(kdialog --getexistingdirectory "$initial" 2>/dev/null || true)
      elif command -v yad >/dev/null 2>&1; then
        selection=$(yad --file-selection --directory --title="Select project root" --filename="$initial/" 2>/dev/null || true)
      fi
      ;;
  esac

  if [[ -z $selection ]] && { [[ $is_wsl -eq 1 ]] || [[ $is_windows_shell -eq 1 ]]; }; then
    local ps_launcher=""
    for candidate in powershell.exe pwsh.exe pwsh powershell; do
      if command -v "$candidate" >/dev/null 2>&1; then
        ps_launcher=$candidate
        break
      fi
    done

    if [[ -n $ps_launcher ]]; then
      local ps_script
      ps_script=$'Add-Type -AssemblyName System.Windows.Forms;
$dialog = New-Object System.Windows.Forms.FolderBrowserDialog;
$dialog.Description = "Select project root for CodexWrapper";
$dialog.ShowNewFolderButton = $true;
if ($args.Length -gt 0 -and (Test-Path $args[0])) { $dialog.SelectedPath = $args[0] }
if ($dialog.ShowDialog() -eq [System.Windows.Forms.DialogResult]::OK) { Write-Output $dialog.SelectedPath }
'

      local initial_windows="$initial"
      if [[ $is_wsl -eq 1 ]] && command -v wslpath >/dev/null 2>&1; then
        initial_windows=$(wslpath -w "$initial" 2>/dev/null || printf '%s' "$initial")
      elif [[ $is_windows_shell -eq 1 ]] && command -v cygpath >/dev/null 2>&1; then
        initial_windows=$(cygpath -w "$initial" 2>/dev/null || printf '%s' "$initial")
      fi

      local pw_output=""
      if pw_output=$("$ps_launcher" -NoLogo -NoProfile -Command "$ps_script" "$initial_windows" 2>/dev/null); then
        pw_output=${pw_output//$'\r'/}
        pw_output=$(trim_whitespace "$pw_output")
        if [[ -n $pw_output ]]; then
          if [[ $is_wsl -eq 1 ]] && command -v wslpath >/dev/null 2>&1; then
            local converted=""
            converted=$(wslpath -u "$pw_output" 2>/dev/null || true)
            if [[ -n $converted ]]; then
              pw_output=$converted
            fi
          elif [[ $is_windows_shell -eq 1 ]] && command -v cygpath >/dev/null 2>&1; then
            local converted=""
            converted=$(cygpath -u "$pw_output" 2>/dev/null || true)
            if [[ -n $converted ]]; then
              pw_output=$converted
            fi
          fi
          selection=$pw_output
        fi
      fi
    fi
  fi

  if [[ -z $selection ]]; then
    if command -v python3 >/dev/null 2>&1; then
      local py_output=""
      local py_script=$'import os\nimport sys\n\ninitial = sys.argv[1]\ntry:\n    import tkinter as tk\n    from tkinter import filedialog\nexcept Exception:\n    sys.exit(0)\n\nroot = tk.Tk()\nroot.withdraw()\ntry:\n    root.update()\nexcept Exception:\n    pass\n\npath = filedialog.askdirectory(initialdir=initial or None, title="Select project root")\nroot.destroy()\nif path:\n    print(path)\n'
      if py_output=$(python3 -c "$py_script" "$initial" 2>/dev/null); then
        selection=$py_output
      fi
    fi
  fi

  if [[ -z $selection ]]; then
    read -r -p "Enter project root path (leave blank to cancel): " selection
  fi

  selection=$(trim_whitespace "$selection")
  if [[ -z $selection ]]; then
    return 1
  fi

  selection=$(expand_path "$selection")
  if [[ ! -d $selection ]]; then
    echo "Selected project root '$selection' does not exist or is not a directory." >&2
    return 1
  fi

  printf '%s' "$selection"
}

add_config_arg() {
  local key=$1
  local value=$2
  local source=${3:-}
  CONFIG_ARGS+=("$key=$value")
  local record_source="$source"
  if [[ -z $record_source ]]; then
    record_source="(unknown)"
  fi
  CONFIG_DETAILS+=("${record_source}"$'\t'"${key}"$'\t'"${value}")
  CONFIG_LAST_SOURCE["$key"]=$record_source
  CONFIG_LAST_VALUE["$key"]="$value"
}

load_config_file() {
  local file=$1
  local source=$file
  if [[ ! -f $file ]]; then
    return 0
  fi
  while IFS= read -r line || [[ -n $line ]]; do
    line=${line%$'\r'}
    local trimmed
    trimmed=$(trim_whitespace "$line")
    if [[ -z $trimmed || $trimmed == \\#* ]]; then
      continue
    fi
    if [[ $trimmed != *=* ]]; then
      continue
    fi
    local key=${trimmed%%=*}
    local value=${trimmed#*=}
    key=$(trim_whitespace "$key")
    value=$(trim_whitespace "$value")
    key=${key,,}
    case "$key" in
      role|goal|raw|model)
        add_config_arg "$key" "$value" "$source"
        ;;
      cons|constraints)
        add_config_arg "cons" "$value" "$source"
        ;;
      reason|reasons)
        add_config_arg "reason" "$value" "$source"
        ;;
      out|output)
        add_config_arg "out" "$value" "$source"
        ;;
      topic|topics)
        add_config_arg "topic" "$value" "$source"
        ;;
      temp|temperature)
        add_config_arg "temp" "$value" "$source"
        ;;
      *)
        CONFIG_UNKNOWN_ENTRIES+=("${source}"$'\t'"${key}"$'\t'"${value}")
        ;;
    esac
  done <"$file"
}

load_config_defaults() {
  local file
  for file in "$@"; do
    [[ -n $file ]] || continue
    load_config_file "$file"
  done
}

canonicalize_config_key() {
  local key=$1
  key=$(trim_whitespace "$key")
  key=${key,,}
  case "$key" in
    constraints)
      printf '%s' "cons"
      ;;
    reasons)
      printf '%s' "reason"
      ;;
    output)
      printf '%s' "out"
      ;;
    topics)
      printf '%s' "topic"
      ;;
    temperature)
      printf '%s' "temp"
      ;;
    r)
      printf '%s' "raw"
      ;;
    *)
      printf '%s' "$key"
      ;;
  esac
}

resolve_config_spec() {
  local raw_spec=$1
  local path_var=$2
  local label_var=$3
  local spec
  spec=$(trim_whitespace "${raw_spec:-}")
  if [[ -z $spec ]]; then
    spec="project"
  fi

  local lowered=${spec,,}
  local path=""
  local label="project"

  case "$lowered" in
    project|local)
      path="$PROJECT_DOT_CX/config"
      label="project"
      ;;
    user|home|global)
      path="$CX_HOME/config"
      label="user"
      ;;
    path:*|file:*)
      local remainder=${raw_spec#*:}
      remainder=$(trim_whitespace "$remainder")
      path=$(expand_path "$remainder")
      label="custom"
      ;;
    *)
      if [[ $spec == /* || $spec == ~* ]]; then
        path=$(expand_path "$spec")
      else
        path=$(expand_path "$spec")
      fi
      label="custom"
      ;;
  esac

  if [[ -z $path ]]; then
    return 1
  fi

  printf -v "$path_var" '%s' "$path"
  printf -v "$label_var" '%s' "$label"
  return 0
}

read_config_into_map() {
  local file=$1
  local map_name=$2
  declare -n map_ref=$map_name
  map_ref=()

  if [[ ! -f $file ]]; then
    return 0
  fi

  while IFS= read -r line || [[ -n $line ]]; do
    line=${line%$'\r'}
    local trimmed
    trimmed=$(trim_whitespace "$line")
    if [[ -z $trimmed || $trimmed == \\#* ]]; then
      continue
    fi
    if [[ $trimmed != *=* ]]; then
      continue
    fi
    local key=${trimmed%%=*}
    local value=${trimmed#*=}
    key=$(canonicalize_config_key "$key")
    value=$(trim_whitespace "$value")
    if [[ -z $key ]]; then
      continue
    fi
    map_ref["$key"]="$value"
  done <"$file"
}

manage_config_updates() {
  local scope_raw=${CONFIG_SCOPE:-project}
  local scope=${scope_raw,,}
  local target_path=""
  local scope_label="project"
  local edits_requested=false

  if ((${#CONFIG_EDIT_SPECS[@]})); then
    edits_requested=true
  fi

  if ((${#CONFIG_RESET_SPECS[@]})); then
    local reset_spec
    for reset_spec in "${CONFIG_RESET_SPECS[@]}"; do
      local descriptor="$reset_spec"
      if [[ -z $descriptor ]]; then
        if [[ -n $CONFIG_CUSTOM_PATH ]]; then
          descriptor="path:${CONFIG_CUSTOM_PATH}"
        else
          descriptor="$scope_raw"
        fi
      fi
      local reset_path=""
      local reset_label=""
      if ! resolve_config_spec "$descriptor" reset_path reset_label; then
        echo "Unable to determine config target path for scope '$descriptor'." >&2
        exit 1
      fi
      if [[ -z $reset_path ]]; then
        echo "Unable to determine config target path for scope '$descriptor'." >&2
        exit 1
      fi
      if [[ -f $reset_path ]]; then
        rm -f "$reset_path"
        echo "Removed config file for $reset_label scope ($reset_path)" >&2
      else
        echo "No config file found for $reset_label scope ($reset_path)" >&2
      fi
    done
  fi

  local mutations_requested=false
  if ((${#CONFIG_SET_ENTRIES[@]} != 0 || ${#CONFIG_UNSET_KEYS[@]} != 0 || ${#CONFIG_IMPORT_FILES[@]} != 0)); then
    mutations_requested=true
  fi

  if [[ $mutations_requested == false && $edits_requested == false ]]; then
    return 0
  fi

  if [[ $mutations_requested == true ]]; then
    local spec_descriptor
    if [[ -n $CONFIG_CUSTOM_PATH ]]; then
      spec_descriptor="path:${CONFIG_CUSTOM_PATH}"
    else
      spec_descriptor="$scope_raw"
    fi

    if ! resolve_config_spec "$spec_descriptor" target_path scope_label; then
      echo "Unable to determine config target path for scope '$scope_raw'." >&2
      exit 1
    fi

    if [[ -z $target_path ]]; then
      echo "Unable to determine config target path for scope '$scope_raw'." >&2
      exit 1
    fi

    local target_dir
    target_dir=$(dirname "$target_path")
    mkdir -p "$target_dir"

    declare -A config_map=()
    declare -a config_order=()

    if [[ -f $target_path ]]; then
      while IFS= read -r line || [[ -n $line ]]; do
        line=${line%$''}
        local trimmed
        trimmed=$(trim_whitespace "$line")
        if [[ -z $trimmed || $trimmed == \#* ]]; then
          continue
        fi
        if [[ $trimmed != *=* ]]; then
          continue
        fi
        local key=${trimmed%%=*}
        local value=${trimmed#*=}
        key=$(canonicalize_config_key "$key")
        value=$(trim_whitespace "$value")
        if [[ -z $key ]]; then
          continue
        fi
        if [[ -z ${config_map[$key]+_} ]]; then
          config_order+=("$key")
        fi
        config_map["$key"]="$value"
      done <"$target_path"
    fi

    local import_file
    for import_file in "${CONFIG_IMPORT_FILES[@]}"; do
      [[ -n $import_file ]] || continue
      local resolved_import
      resolved_import=$(expand_path "$import_file")
      if [[ -z $resolved_import || ! -f $resolved_import ]]; then
        echo "Config import file not found: $import_file" >&2
        exit 1
      fi
      while IFS= read -r line || [[ -n $line ]]; do
        line=${line%$''}
        local trimmed
        trimmed=$(trim_whitespace "$line")
        if [[ -z $trimmed || $trimmed == \#* ]]; then
          continue
        fi
        if [[ $trimmed != *=* ]]; then
          continue
        fi
        local key=${trimmed%%=*}
        local value=${trimmed#*=}
        key=$(canonicalize_config_key "$key")
        value=$(trim_whitespace "$value")
        if [[ -z $key ]]; then
          continue
        fi
        if [[ -z ${config_map[$key]+_} ]]; then
          config_order+=("$key")
        fi
        config_map["$key"]="$value"
      done <"$resolved_import"
    done

    local entry
    for entry in "${CONFIG_SET_ENTRIES[@]}"; do
      [[ -n $entry ]] || continue
      if [[ $entry != *=* ]]; then
        echo "Invalid --config-set entry '$entry'; expected key=value." >&2
        exit 1
      fi
      local key=${entry%%=*}
      local value=${entry#*=}
      key=$(canonicalize_config_key "$key")
      value=$(trim_whitespace "$value")
      if [[ -z $key ]]; then
        echo "Invalid --config-set entry '$entry'; key cannot be empty." >&2
        exit 1
      fi
      if [[ -z ${config_map[$key]+_} ]]; then
        config_order+=("$key")
      fi
      config_map["$key"]="$value"
    done

    local unset_key
    if ((${#CONFIG_UNSET_KEYS[@]})); then
      for unset_key in "${CONFIG_UNSET_KEYS[@]}"; do
        [[ -n $unset_key ]] || continue
        unset_key=$(canonicalize_config_key "$unset_key")
        if [[ -z $unset_key ]]; then
          continue
        fi
        unset "config_map[$unset_key]"
      done
      if ((${#config_order[@]})); then
        local -a filtered=()
        local key
        for key in "${config_order[@]}"; do
          if [[ -n ${config_map[$key]+_} ]]; then
            filtered+=("$key")
          fi
        done
        config_order=("${filtered[@]}")
      fi
    fi

    if ((${#config_map[@]} == 0)); then
      if [[ -f $target_path ]]; then
        rm -f "$target_path"
        echo "Removed empty config file: $target_path" >&2
      else
        echo "No config entries to persist for scope '$scope_label'." >&2
      fi
    else
      if ((${#config_order[@]} == 0)); then
        config_order=("${!config_map[@]}")
      fi

      {
        echo "# cx configuration ($scope_label scope)"
        echo "# Updated: $(date -u +"%Y-%m-%dT%H:%M:%SZ")"
        local key
        for key in "${config_order[@]}"; do
          if [[ -n ${config_map[$key]+_} ]]; then
            printf '%s=%s
' "$key" "${config_map[$key]}"
          fi
        done
        for key in "${!config_map[@]}"; do
          local present=false
          local existing
          for existing in "${config_order[@]}"; do
            if [[ $existing == "$key" ]]; then
              present=true
              break
            fi
          done
          if [[ $present == false ]]; then
            printf '%s=%s
' "$key" "${config_map[$key]}"
          fi
        done
      } >"$target_path"
      echo "Wrote config to $target_path ($scope_label scope)" >&2
    fi
  fi

  if [[ $edits_requested == true ]]; then
    local editor_command=""
    if ! determine_config_editor editor_command; then
      echo "Unable to locate an editor. Set CX_CONFIG_EDITOR or EDITOR before using --config-edit." >&2
      exit 1
    fi

    local edit_spec
    for edit_spec in "${CONFIG_EDIT_SPECS[@]}"; do
      local descriptor="$edit_spec"
      if [[ -z $descriptor ]]; then
        if [[ -n $CONFIG_CUSTOM_PATH ]]; then
          descriptor="path:${CONFIG_CUSTOM_PATH}"
        else
          descriptor="$scope_raw"
        fi
      fi

      local edit_path=""
      local edit_label=""
      if ! resolve_config_spec "$descriptor" edit_path edit_label; then
        echo "Unable to resolve config scope '$descriptor' for editing." >&2
        exit 1
      fi
      if [[ -z $edit_path ]]; then
        echo "Unable to determine config path for scope '$descriptor'." >&2
        exit 1
      fi

      local edit_dir
      edit_dir=$(dirname "$edit_path")
      mkdir -p "$edit_dir"

      if [[ ! -f $edit_path ]]; then
        write_config_template_file "$edit_path" "$edit_label"
        echo "Created config template at $edit_path ($edit_label scope)" >&2
      fi

      echo "Launching editor '$editor_command' for $edit_label config ($edit_path)" >&2
      if ! invoke_editor_command "$editor_command" "$edit_path"; then
        echo "Editor command failed for $edit_path." >&2
        exit 1
      fi
    done
  fi
}

show_config_template() {
  local spec=${1:-}
  local descriptor="$spec"
  if [[ -z $descriptor ]]; then
    if [[ -n $CONFIG_CUSTOM_PATH ]]; then
      descriptor="path:${CONFIG_CUSTOM_PATH}"
    else
      descriptor="${CONFIG_SCOPE:-project}"
    fi
  fi

  local target_path=""
  local scope_label=""
  if ! resolve_config_spec "$descriptor" target_path scope_label; then
    echo "Unable to resolve config scope '$descriptor'." >&2
    return 1
  fi
  if [[ -z $target_path ]]; then
    echo "Unable to resolve config path for scope '$descriptor'." >&2
    return 1
  fi

  render_config_template "$target_path" "$scope_label" true
}

render_config_template() {
  local target_path=$1
  local scope_label=$2
  local include_hint=${3:-false}
  {
    echo "# cx configuration template (${scope_label} scope)"
    if [[ $include_hint == true ]]; then
      echo "# Save to: $target_path"
    fi
    echo "# Lines beginning with '#' are ignored."
    echo "# Configure defaults for frequently reused prompt fields."
    echo "role=You are a seasoned developer."
    echo "goal=Summarize the current objective."
    echo "cons=List any constraints that must be enforced."
    echo "reason=Outline the reasoning approach or checklist."
    echo "out=code"
    echo "topic=project-tag"
    echo "model=gpt-4o-mini"
    echo "temp=0.2"
    echo "# raw=Add raw directives (e.g. r:include tests)"
  }
}

write_config_template_file() {
  local target_path=$1
  local scope_label=$2
  local dir
  dir=$(dirname "$target_path")
  mkdir -p "$dir"
  render_config_template "$target_path" "$scope_label" false >"$target_path"
}

determine_config_editor() {
  local __result=$1
  local candidate="${CX_CONFIG_EDITOR:-}"
  if [[ -z $candidate && -n ${EDITOR:-} ]]; then
    candidate="$EDITOR"
  fi
  if [[ -z $candidate && -n ${VISUAL:-} ]]; then
    candidate="$VISUAL"
  fi
  if [[ -z $candidate ]]; then
    if command -v nano >/dev/null 2>&1; then
      candidate="nano"
    elif command -v vi >/dev/null 2>&1; then
      candidate="vi"
    elif command -v vim >/dev/null 2>&1; then
      candidate="vim"
    fi
  fi
  if [[ -z $candidate ]]; then
    return 1
  fi
  printf -v "$__result" '%s' "$candidate"
  return 0
}

split_command_line() {
  local raw=$1
  local __array_name=$2
  if command -v python3 >/dev/null 2>&1; then
    local parsed
    parsed=$(python3 - "$raw" <<'PY'
import shlex
import sys

cmd = sys.argv[1]
if not cmd.strip():
    print()
else:
    print('\n'.join(shlex.split(cmd)))
PY
)
    if [[ -z $parsed ]]; then
      eval "$__array_name=()"
      return 0
    fi
    mapfile -t "$__array_name" <<<"$parsed"
    return 0
  fi

  local -a fallback=()
  read -r -a fallback <<<"$raw"
  eval "$__array_name=(\"\${fallback[@]}\")"
}

invoke_editor_command() {
  local command_str=$1
  local target_path=$2
  local -a cmd_parts=()
  split_command_line "$command_str" cmd_parts
  if ((${#cmd_parts[@]} == 0)); then
    cmd_parts=("$command_str")
  fi
  cmd_parts+=("$target_path")
  "${cmd_parts[@]}"
}

show_config_report() {
  echo "# Configuration overview"
  echo "CX_HOME: $CX_HOME"
  echo "Project root: $PROJECT_ROOT"
  echo "Project config dir: $PROJECT_DOT_CX"
  echo
  echo "## Config search paths"
  local -a search_paths=()
  search_paths+=("$CX_HOME/config")
  search_paths+=("$PROJECT_DOT_CX/config")
  if [[ -n $CONFIG_CUSTOM_PATH ]]; then
    local resolved_path
    resolved_path=$(expand_path "$CONFIG_CUSTOM_PATH")
    if [[ -n $resolved_path ]]; then
      search_paths+=("$resolved_path")
    fi
  fi
  if [[ -n "${CX_CONFIG:-}" ]]; then
    local extra
    local extra_path
    IFS=':' read -ra extra <<<"${CX_CONFIG}"
    for extra_path in "${extra[@]}"; do
      [[ -n $extra_path ]] || continue
      search_paths+=("$extra_path")
    done
  fi
  if ((${#search_paths[@]} == 0)); then
    echo "(no config paths)"
  else
    local path
    for path in "${search_paths[@]}"; do
      [[ -n $path ]] || continue
      if [[ -f $path ]]; then
        echo "- $path (found)"
      else
        echo "- $path (missing)"
      fi
    done
  fi

  echo
  echo "## Layered defaults"
  if ((${#CONFIG_DETAILS[@]})); then
    local entry source key value
    for entry in "${CONFIG_DETAILS[@]}"; do
      IFS=$'\t' read -r source key value <<<"$entry"
      echo "- ${key}=${value} (source: ${source})"
    done
  else
    echo "(no layered defaults applied)"
  fi

  echo
  echo "## Effective defaults"
  if ((${#CONFIG_LAST_VALUE[@]})); then
    local key
    while IFS= read -r key; do
      local value=${CONFIG_LAST_VALUE[$key]}
      local src=${CONFIG_LAST_SOURCE[$key]:-(unknown)}
      echo "${key}=${value} (source: ${src})"
    done < <(printf '%s\n' "${!CONFIG_LAST_VALUE[@]}" | sort)
  else
    echo "(no effective defaults)"
  fi

  echo
  echo "## CLI overrides"
  if ((${#CLI_OVERRIDES[@]})); then
    local override
    for override in "${CLI_OVERRIDES[@]}"; do
      echo "$override"
    done
  else
    echo "(none)"
  fi

  echo
  echo "## Resolved values"
  printf 'role=%s\n' "$ROLE"
  printf 'goal=%s\n' "$GOAL"
  printf 'cons=%s\n' "$CONS"
  printf 'reason=%s\n' "$REASON"
  printf 'out=%s\n' "$OUT"
  printf 'raw=%s\n' "$RAW"
  printf 'topic=%s\n' "$TOPICS"
  printf 'model=%s\n' "$MODEL"
  printf 'temp=%s\n' "$TEMP"
}

ps_escape_single_quotes() {
  local value=$1
  value=${value//"'"/"''"}
  printf "%s" "$value"
}

show_config_env() {
  local format=${1:-shell}
  local timestamp
  timestamp=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
  local -a keys=(role goal cons reason out raw topic model temp)
  case "$format" in
    shell|bash)
      echo "# Shell exports for cx resolved configuration"
      echo "# Generated: $timestamp"
      local key value env_name literal
      for key in "${keys[@]}"; do
        case "$key" in
          role) value="$ROLE" ;;
          goal) value="$GOAL" ;;
          cons) value="$CONS" ;;
          reason) value="$REASON" ;;
          out) value="$OUT" ;;
          raw) value="$RAW" ;;
          topic) value="$TOPICS" ;;
          model) value="$MODEL" ;;
          temp) value="$TEMP" ;;
          *) value="" ;;
        esac
        env_name="CX_${key^^}"
        literal=$(printf '%q' "$value")
        printf 'export %s=%s\n' "$env_name" "$literal"
      done
      ;;
    powershell|ps)
      echo "# PowerShell environment assignments for cx resolved configuration"
      echo "# Generated: $timestamp"
      local key value env_name literal
      for key in "${keys[@]}"; do
        case "$key" in
          role) value="$ROLE" ;;
          goal) value="$GOAL" ;;
          cons) value="$CONS" ;;
          reason) value="$REASON" ;;
          out) value="$OUT" ;;
          raw) value="$RAW" ;;
          topic) value="$TOPICS" ;;
          model) value="$MODEL" ;;
          temp) value="$TEMP" ;;
          *) value="" ;;
        esac
        env_name="CX_${key^^}"
        if [[ -z $value ]]; then
          printf "Set-Item -Path Env:%s -Value ''\n" "$env_name"
        else
          literal=$(ps_escape_single_quotes "$value")
          printf "Set-Item -Path Env:%s -Value '%s'\n" "$env_name" "$literal"
        fi
      done
      ;;
    *)
      echo "Unknown config environment format '$format'. Supported formats: shell, powershell." >&2
      return 1
      ;;
  esac
  return 0
}

show_config_sources() {
  echo "# Config entries by source"
  if ((${#CONFIG_DETAILS[@]} == 0)); then
    echo "(no layered defaults applied)"
    return 0
  fi

  local -a source_order=()
  declare -A grouped=()
  local entry
  for entry in "${CONFIG_DETAILS[@]}"; do
    local source key value
    IFS=$'\t' read -r source key value <<<"$entry"
    if [[ -z $source ]]; then
      source="(unknown)"
    fi
    if [[ -z ${grouped[$source]+x} ]]; then
      source_order+=("$source")
      grouped["$source"]="$key=$value"
    else
      grouped["$source"]+=$'\n'"$key=$value"
    fi
  done

  local src
  for src in "${source_order[@]}"; do
    echo
    echo "## $src"
    local line
    while IFS= read -r line; do
      [[ -n $line ]] || continue
      printf '  - %s\n' "$line"
    done <<<"$(printf '%s\n' "${grouped[$src]}")"
  done
}

show_config_validation() {
  local scope_spec
  scope_spec=$(trim_whitespace "${1:-}")
  local scope_label="layered defaults"
  local target_path=""
  local -a entries=()
  local -a unknowns=()
  local -a errors=()
  local -a warnings=()

  if [[ -n $scope_spec ]]; then
    if ! resolve_config_spec "$scope_spec" target_path scope_label; then
      echo "Unable to resolve config scope '$scope_spec'." >&2
      return 1
    fi
    local entry
    for entry in "${CONFIG_DETAILS[@]}"; do
      local source key value
      IFS=$'\t' read -r source key value <<<"$entry"
      if [[ $source == "$target_path" ]]; then
        entries+=("$entry")
      fi
    done
    for entry in "${CONFIG_UNKNOWN_ENTRIES[@]}"; do
      local source key value
      IFS=$'\t' read -r source key value <<<"$entry"
      if [[ $source == "$target_path" ]]; then
        unknowns+=("$entry")
      fi
    done
    if [[ -n $target_path && ! -f $target_path ]]; then
      warnings+=("Config file $target_path does not exist.")
    fi
  else
    entries=("${CONFIG_DETAILS[@]}")
    unknowns=("${CONFIG_UNKNOWN_ENTRIES[@]}")
  fi

  echo "# Config validation ($scope_label)"

  if ((${#entries[@]} == 0 && ${#unknowns[@]} == 0)); then
    echo
    echo "No config entries were found for validation."
  fi

  if ((${#unknowns[@]})); then
    echo
    echo "## Unknown entries"
    local entry
    for entry in "${unknowns[@]}"; do
      local source key value
      IFS=$'\t' read -r source key value <<<"$entry"
      errors+=("Unknown config key '$key' in $source")
      printf '  - %s=%s (source: %s)\n' "$key" "$value" "$source"
    done
  fi

  local entry
  for entry in "${entries[@]}"; do
    local source key value
    IFS=$'\t' read -r source key value <<<"$entry"
    case "$key" in
      role|goal)
        if [[ -z $value ]]; then
          errors+=("Config key '$key' from $source is empty.")
        fi
        ;;
      model)
        if [[ -z $value ]]; then
          errors+=("Model value from $source is empty.")
        fi
        ;;
      temp)
        if [[ -z $value ]]; then
          errors+=("Temperature value from $source is empty.")
        elif [[ ! $value =~ ^-?[0-9]+(\.[0-9]+)?$ ]]; then
          errors+=("Temperature '$value' from $source is not numeric.")
        else
          if command -v python3 >/dev/null 2>&1; then
            local status
            if ! python3 - "$value" <<'PY'; then
import sys
try:
    val = float(sys.argv[1])
except ValueError:
    sys.exit(1)
if val < 0 or val > 2:
    sys.exit(2)
sys.exit(0)
PY
              status=$?
              if (( status == 1 )); then
                errors+=("Temperature '$value' from $source could not be parsed as a number.")
              else
                errors+=("Temperature '$value' from $source is outside the allowed 0-2 range.")
              fi
            fi
          else
            if ! awk -v v="$value" 'BEGIN{exit !(v >= 0 && v <= 2)}'; then
              errors+=("Temperature '$value' from $source is outside the allowed 0-2 range.")
            fi
          fi
        fi
        ;;
    esac
  done

  if ((${#errors[@]})); then
    echo
    echo "## Errors"
    local msg
    for msg in "${errors[@]}"; do
      printf '  - %s\n' "$msg"
    done
  fi

  if ((${#warnings[@]})); then
    echo
    echo "## Warnings"
    local warn
    for warn in "${warnings[@]}"; do
      printf '  - %s\n' "$warn"
    done
  fi

  if ((${#errors[@]} == 0 && ${#warnings[@]} == 0)); then
    echo
    echo "Validation passed with no issues."
  elif ((${#errors[@]} == 0)); then
    echo
    echo "Validation completed with warnings."
  fi

  if ((${#errors[@]})); then
    return 1
  fi
  return 0
}

config_value_for_key() {
  local key=$1
  case "$key" in
    role) printf '%s' "$ROLE" ;;
    goal) printf '%s' "$GOAL" ;;
    cons) printf '%s' "$CONS" ;;
    reason) printf '%s' "$REASON" ;;
    out) printf '%s' "$OUT" ;;
    raw) printf '%s' "$RAW" ;;
    topic) printf '%s' "$TOPICS" ;;
    model) printf '%s' "$MODEL" ;;
    temp) printf '%s' "$TEMP" ;;
    *) printf '%s' "" ;;
  esac
}

config_source_label() {
  local key=$1
  local value=$2
  if [[ -n ${CLI_OVERRIDE_MAP[$key]+_} ]]; then
    printf '%s' "CLI override"
    return 0
  fi
  if [[ -n ${CONFIG_LAST_SOURCE[$key]+_} ]]; then
    printf '%s' "${CONFIG_LAST_SOURCE[$key]}"
    return 0
  fi
  case "$key" in
    model)
      if [[ -n $ORIGINAL_CX_MODEL ]]; then
        printf '%s' "environment CX_MODEL"
        return 0
      fi
      ;;
    temp)
      if [[ -n $ORIGINAL_CX_TEMP ]]; then
        printf '%s' "environment CX_TEMP"
        return 0
      fi
      ;;
  esac
  if [[ -n $value ]]; then
    printf '%s' "script default"
  else
    printf '%s' "(not set)"
  fi
}

generate_config_snapshot() {
  local -a search_paths=()
  search_paths+=("$CX_HOME/config")
  search_paths+=("$PROJECT_DOT_CX/config")
  if [[ -n $CONFIG_CUSTOM_PATH ]]; then
    local resolved_path
    resolved_path=$(expand_path "$CONFIG_CUSTOM_PATH")
    if [[ -n $resolved_path ]]; then
      search_paths+=("$resolved_path")
    fi
  fi
  if [[ -n "${CX_CONFIG:-}" ]]; then
    local extra_path
    IFS=':' read -ra extra_path <<<"${CX_CONFIG}"
    search_paths+=("${extra_path[@]}")
  fi

  printf '# cx configuration snapshot\n'
  printf '# Generated: %s\n' "$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
  printf '# Project root: %s\n' "$PROJECT_ROOT"
  printf '# Config search paths:\n'
  if ((${#search_paths[@]})); then
    local path
    for path in "${search_paths[@]}"; do
      [[ -n $path ]] || continue
      if [[ -f $path ]]; then
        printf '#   - %s (found)\n' "$path"
      else
        printf '#   - %s (missing)\n' "$path"
      fi
    done
  else
    printf '#   (none)\n'
  fi
  printf '\n'

  local -a keys=(role goal cons reason out raw topic model temp)
  local key value source
  for key in "${keys[@]}"; do
    value=$(config_value_for_key "$key")
    source=$(config_source_label "$key" "$value")
    if [[ -n $source ]]; then
      printf '%s=%s  # source: %s\n' "$key" "$value" "$source"
    else
      printf '%s=%s\n' "$key" "$value"
    fi
  done
}

perform_config_export() {
  local destination=$1
  if [[ -z $destination ]]; then
    generate_config_snapshot
    return 0
  fi

  local resolved
  resolved=$(expand_path "$destination")
  if [[ -z $resolved ]]; then
    echo "Unable to resolve export path '$destination'." >&2
    exit 1
  fi
  local dir
  dir=$(dirname "$resolved")
  mkdir -p "$dir"
  generate_config_snapshot >"$resolved"
  echo "Exported config snapshot to $resolved" >&2
}

show_config_which() {
  local key_spec=${1:-}
  local -a requested=()
  if [[ -n $key_spec ]]; then
    IFS=',' read -r -a requested <<<"$key_spec"
  fi

  declare -A seen=()
  local -a keys=()

  if ((${#requested[@]} == 0)); then
    local default_keys=(role goal cons reason out raw topic model temp)
    local item canon
    for item in "${default_keys[@]}"; do
      canon=$(canonicalize_config_key "$item")
      [[ -n $canon ]] || continue
      if [[ -z ${seen[$canon]+x} ]]; then
        seen[$canon]=1
        keys+=("$canon")
      fi
    done
    for item in "${!CONFIG_LAST_VALUE[@]}"; do
      canon=$(canonicalize_config_key "$item")
      [[ -n $canon ]] || continue
      if [[ -z ${seen[$canon]+x} ]]; then
        seen[$canon]=1
        keys+=("$canon")
      fi
    done
    for item in "${CLI_OVERRIDES[@]}"; do
      canon=$(canonicalize_config_key "${item%%=*}")
      [[ -n $canon ]] || continue
      if [[ -z ${seen[$canon]+x} ]]; then
        seen[$canon]=1
        keys+=("$canon")
      fi
    done
  else
    local entry canon
    for entry in "${requested[@]}"; do
      canon=$(canonicalize_config_key "$entry")
      [[ -n $canon ]] || continue
      if [[ -z ${seen[$canon]+x} ]]; then
        seen[$canon]=1
        keys+=("$canon")
      fi
    done
  fi

  if ((${#keys[@]} == 0)); then
    echo "No config keys to inspect." >&2
    return 0
  fi

  IFS=$'\n' keys=($(printf '%s\n' "${keys[@]}" | sort))

  echo "# Config resolution"
  local key
  for key in "${keys[@]}"; do
    echo
    echo "## $key"

    local default_value=""
    local default_source=""
    if [[ -n ${CONFIG_LAST_VALUE[$key]+x} ]]; then
      default_value=${CONFIG_LAST_VALUE[$key]}
      default_source=${CONFIG_LAST_SOURCE[$key]:-(unknown)}
      printf -- "- default: %s (source: %s)\n" "$default_value" "$default_source"
    else
      echo "- default: (not set)"
    fi

    local cli_value=""
    local override
    for override in "${CLI_OVERRIDES[@]}"; do
      if [[ $override == "$key="* ]]; then
        cli_value=${override#*=}
        break
      fi
    done
    if [[ -n $cli_value ]]; then
      printf -- "- cli: %s\n" "$cli_value"
    else
      echo "- cli: (not set)"
    fi

    local env_label=""
    local env_value=""
    case "$key" in
      model)
        if [[ -n ${CX_MODEL:-} ]]; then
          env_label="CX_MODEL"
          env_value="$CX_MODEL"
        fi
        ;;
      temp)
        if [[ -n ${CX_TEMP:-} ]]; then
          env_label="CX_TEMP"
          env_value="$CX_TEMP"
        fi
        ;;
    esac
    if [[ -n $env_label ]]; then
      printf -- "- env: %s=%s\n" "$env_label" "$env_value"
    else
      echo "- env: (not set)"
    fi

    local resolved=""
    case "$key" in
      role) resolved="$ROLE" ;;
      goal) resolved="$GOAL" ;;
      cons) resolved="$CONS" ;;
      reason) resolved="$REASON" ;;
      out) resolved="$OUT" ;;
      raw) resolved="$RAW" ;;
      topic) resolved="$TOPICS" ;;
      model) resolved="$MODEL" ;;
      temp) resolved="$TEMP" ;;
    esac
    if [[ -n $resolved ]]; then
      printf -- "- resolved: %s\n" "$resolved"
    else
      echo "- resolved: (empty)"
    fi
  done
}

show_config_diff() {
  local pair=${1:-}
  local default_left="project"
  local default_right="user"
  local left_spec="$default_left"
  local right_spec="$default_right"

  if [[ -n $pair ]]; then
    if [[ $pair == *:* ]]; then
      left_spec=${pair%%:*}
      right_spec=${pair#*:}
    else
      right_spec=$pair
    fi
  fi

  left_spec=$(trim_whitespace "$left_spec")
  right_spec=$(trim_whitespace "$right_spec")
  [[ -n $left_spec ]] || left_spec="$default_left"
  [[ -n $right_spec ]] || right_spec="$default_right"

  local left_path="" left_label=""
  local right_path="" right_label=""

  if ! resolve_config_spec "$left_spec" left_path left_label; then
    echo "Unable to resolve config scope '$left_spec'." >&2
    exit 1
  fi
  if ! resolve_config_spec "$right_spec" right_path right_label; then
    echo "Unable to resolve config scope '$right_spec'." >&2
    exit 1
  fi

  local left_display="$left_path"
  local right_display="$right_path"
  if [[ -z $left_display ]]; then
    left_display="(unresolved)"
  elif [[ ! -f $left_path ]]; then
    left_display+=" (missing)"
  fi
  if [[ -z $right_display ]]; then
    right_display="(unresolved)"
  elif [[ ! -f $right_path ]]; then
    right_display+=" (missing)"
  fi

  declare -A left_map=()
  declare -A right_map=()
  read_config_into_map "$left_path" left_map
  read_config_into_map "$right_path" right_map

  echo "# Config diff"
  echo "Comparing ${left_label} (${left_display}) vs ${right_label} (${right_display})"

  declare -A keys=()
  local key
  for key in "${!left_map[@]}"; do
    keys["$key"]=1
  done
  for key in "${!right_map[@]}"; do
    keys["$key"]=1
  done

  if ((${#keys[@]} == 0)); then
    echo "(no entries to compare)"
    return 0
  fi

  local found=false
  while IFS= read -r key; do
    [[ -n $key ]] || continue
    local have_left=false
    local have_right=false
    if [[ -n ${left_map[$key]+_} ]]; then
      have_left=true
    fi
    if [[ -n ${right_map[$key]+_} ]]; then
      have_right=true
    fi

    if [[ $have_left == true && $have_right == true ]]; then
      if [[ "${left_map[$key]}" != "${right_map[$key]}" ]]; then
        printf -- "- %s: %s=\"%s\" vs %s=\"%s\"\n" \
          "$key" "$left_label" "${left_map[$key]}" "$right_label" "${right_map[$key]}"
        found=true
      fi
    elif [[ $have_left == true ]]; then
      printf -- "- %s: %s=\"%s\" (missing from %s)\n" \
        "$key" "$left_label" "${left_map[$key]}" "$right_label"
      found=true
    elif [[ $have_right == true ]]; then
      printf -- "- %s: %s=\"%s\" (missing from %s)\n" \
        "$key" "$right_label" "${right_map[$key]}" "$left_label"
      found=true
    fi
  done < <(printf '%s\n' "${!keys[@]}" | sort)

  if [[ $found == false ]]; then
    echo "No differences."
  fi
}

resolve_project_root() {
  local start=${1:-$PWD}
  local dir
  if dir=$(cd "$start" 2>/dev/null && pwd); then
    :
  else
    dir=$start
  fi
  if command -v git >/dev/null 2>&1; then
    if git -C "$dir" rev-parse --show-toplevel >/dev/null 2>&1; then
      git -C "$dir" rev-parse --show-toplevel
      return 0
    fi
  fi
  if command -v hg >/dev/null 2>&1; then
    if hg --cwd "$dir" root >/dev/null 2>&1; then
      hg --cwd "$dir" root
      return 0
    fi
  fi
  local -a markers=(
    .git .hg .svn
    package.json pnpm-workspace.yaml lerna.json nx.json
    flake.nix default.nix shell.nix
    pyproject.toml Pipfile poetry.lock requirements.in
    requirements.txt requirements-dev.txt dev-requirements.txt
    setup.py setup.cfg
    Taskfile.yml Taskfile.yaml taskfile.yml taskfile.yaml
    Justfile justfile
    .pre-commit-config.yaml .pre-commit-config.yml
    Cargo.toml
    go.mod
    Gemfile gems.rb
    mix.exs
    stack.yaml
    '*.cabal'
    Package.swift
    build.sbt
    project
    pubspec.yaml
    pom.xml
    build.gradle build.gradle.kts settings.gradle settings.gradle.kts gradlew
    CMakeLists.txt
    Makefile makefile
    Dockerfile docker-compose.yml docker-compose.yaml compose.yml compose.yaml
    .cx
    '*.sln' '*.csproj' '*.fsproj' '*.vbproj'
    WORKSPACE WORKSPACE.bazel MODULE.bazel
    pants.toml pants.ci.toml pants.ini pants
    Vagrantfile
    ansible.cfg
    Chart.yaml
    kustomization.yaml kustomization.yml
    terragrunt.hcl
    '*.tf' '*.tf.json'
  )
  local current=$dir
  while true; do
    local marker
    for marker in "${markers[@]}"; do
      if [[ $marker == *'*'* || $marker == *'?'* || $marker == *'['* ]]; then
        if compgen -G "$current/$marker" >/dev/null 2>&1; then
          printf '%s' "$current"
          return 0
        fi
      else
        if [[ -e "$current/$marker" ]]; then
          printf '%s' "$current"
          return 0
        fi
      fi
    done
    [[ $current == / ]] && break
    local parent
    parent=$(dirname "$current")
    [[ $parent == "$current" ]] && break
    current=$parent
  done
  printf '%s' "$dir"
}

derive_project_name() {
  local root=${1:-}
  local fallback=${2:-}
  local trimmed=${root%/}
  local name=${trimmed##*/}
  if [[ -z "$name" || "$name" == "." ]]; then
    local fb_trimmed=${fallback%/}
    name=${fb_trimmed##*/}
  fi
  if [[ -z "$name" || "$name" == "." ]]; then
    name="project"
  fi
  name=${name//[^A-Za-z0-9._-]/_}
  printf '%s' "$name"
}

enter_project_root() {
  ENTERED_PROJECT_ROOT=false
  local target=${1:-$PROJECT_ROOT}
  if [[ -z "$target" || ! -d "$target" ]]; then
    return 0
  fi
  if [[ "$target" == "$PWD" ]]; then
    return 0
  fi
  if pushd "$target" >/dev/null; then
    ENTERED_PROJECT_ROOT=true
  fi
}

leave_project_root() {
  if [[ ${ENTERED_PROJECT_ROOT:-false} == true ]]; then
    popd >/dev/null || true
  fi
  ENTERED_PROJECT_ROOT=false
}

run_baseline_step() {
  local label=$1
  shift
  echo >&2
  echo ">>> $label" >&2
  if "$@"; then
    echo ">>> $label completed" >&2
    return 0
  else
    local rc=$?
    echo ">>> $label failed (exit $rc)" >&2
    return $rc
  fi
}

run_baseline_suite() {
  local status=0
  echo "Starting baseline repository automation for $project" >&2
  local -a lint_cmd=("$0" "--lint")
  if $FIX; then
    lint_cmd+=("--fix")
  fi
  run_baseline_step "Lint checks" "${lint_cmd[@]}" || status=1
  run_baseline_step "Repository audit" "$0" "--audit" || status=1
  run_baseline_step "Repository inspection" "$0" "--inspect" || status=1
  if command -v git >/dev/null 2>&1 && git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    run_baseline_step "Hotspot analysis" "$0" "--hotspots" || status=1
    run_baseline_step "Stale file scan" "$0" "--stale" || status=1
  else
    echo ">>> Skipping git-based analyses (repository not detected)" >&2
  fi
  if (( status == 0 )); then
    echo "Baseline automation complete. Review the logs under $CX_HOME for details." >&2
  else
    echo "Baseline automation finished with issues. Review the output above." >&2
  fi
  return $status
}

run_custom_block() {
  local label=$1
  local commands=$2
  local status=0

  CUSTOM_BLOCK_LAST_RAN=false

  while IFS= read -r cmd; do
    if [[ $cmd =~ ^[[:space:]]*$ ]]; then
      continue
    fi
    if [[ $cmd =~ ^[[:space:]]*# ]]; then
      continue
    fi
    CUSTOM_BLOCK_LAST_RAN=true
    run_baseline_step "$label: $cmd" bash -lc "$cmd" || status=1
  done <<<"$commands"

  return $status
}

detect_node_manager() {
  if [[ ! -f package.json ]]; then
    return 1
  fi
  if [[ -f bun.lockb || -f bunfig.toml ]] && command -v bun >/dev/null 2>&1; then
    printf 'bun'
    return 0
  fi
  if [[ -f pnpm-lock.yaml ]] && command -v pnpm >/dev/null 2>&1; then
    printf 'pnpm'
    return 0
  fi
  if [[ -f yarn.lock ]] && command -v yarn >/dev/null 2>&1; then
    printf 'yarn'
    return 0
  fi
  if command -v npm >/dev/null 2>&1; then
    printf 'npm'
    return 0
  fi
  return 1
}

node_dependencies_ready() {
  [[ -d node_modules || -f .pnp.cjs || -f .pnp.js ]]
}

run_node_install() {
  local manager=$1
  case "$manager" in
    bun)
      bun install --frozen-lockfile
      ;;
    pnpm)
      pnpm install --frozen-lockfile
      ;;
    yarn)
      yarn install --silent --frozen-lockfile
      ;;
    npm)
      npm install --no-audit --no-fund
      ;;
    *)
      echo "Unknown Node package manager: $manager" >&2
      return 1
      ;;
  esac
}

npm_has_script() {
  local script=$1
  [[ -f package.json ]] || return 1
  command -v python3 >/dev/null 2>&1 || return 1
  python3 - "$script" <<'PY'
import json, sys
script = sys.argv[1]
try:
    with open('package.json', encoding='utf-8') as fh:
        data = json.load(fh)
except Exception:
    sys.exit(1)
scripts = data.get('scripts') or {}
cmd = scripts.get(script)
if isinstance(cmd, str) and cmd.strip():
    sys.exit(0)
sys.exit(1)
PY
}

run_node_script() {
  local manager=$1
  local script=$2
  case "$manager" in
    bun)
      bun run "$script"
      ;;
    pnpm)
      pnpm run "$script"
      ;;
    yarn)
      yarn run "$script"
      ;;
    npm)
      npm run "$script"
      ;;
    *)
      echo "Unknown Node package manager: $manager" >&2
      return 1
      ;;
  esac
}

