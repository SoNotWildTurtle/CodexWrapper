function Invoke-Codex {
    <#
      SYM-5 expander. Example:
      Invoke-Codex '::r @sec ::g threat model for self-hosted git ::c ^mm,^md,^st{5} ::s ^ts,^rg,^ck'
    #>

    param(
        [Parameter(Mandatory = $true, ValueFromRemainingArguments = $true)]
        [string[]] ${ArgsText}
    )

    ${raw} = [string]::Join(' ', ${ArgsText})

    # 1) Dictionary (extend freely)
    ${map} = [ordered]@{
        '@sec' = 'You are a senior security engineer and red/blue-team trainer.';
        '@ds'  = 'You are a data scientist and ML engineer.';
        '@dev' = 'You are a senior software engineer.';

        '^ts' = 'Think step-by-step and verify each step.';
        '^mm' = 'Use minimal tokens; compress phrasing, keep meaning.';
        '^ck' = 'List assumptions; call out unknowns explicitly.';
        '^rg' = 'Reason first, then answer.';
        '^fx' = 'If facts are uncertain, hedge and ask for the single most helpful follow-up.';
        '^md' = 'Format using concise Markdown.';
        '^ps' = 'Provide a short pseudocode outline.';
        '^cx' = 'Provide a compressed recap (≤ 2 lines) at the end.';
        '^qa' = 'Return Q→A pairs.';
    }

    # 2) Parametric expansion: ^st{N}
    ${out} = ${raw} -replace '\^st\{([0-9]+)\}', 'Return at most $1 bullet points.'

    # 3) Symbol replacements (longest-first)
    foreach (${k} in (${map}.Keys | Sort-Object { $_.Length } -Descending)) {
        ${v} = ${map}[${k}]
        # replace token when followed by space or end
        ${out} = [Regex]::Replace(${out}, [Regex]::Escape(${k}) + '(?=\s|$)', [System.Text.RegularExpressions.MatchEvaluator]{ param(${m}) ${v} })
    }

    function Get-Block {
        param(
            [string] ${Tag},
            [string] ${Label},
            [string] ${Text}
        )
        ${pattern} = '(?s)(?:::' + [Regex]::Escape(${Tag}) + ')(?:\s+)?(.*?)(?=(?:::r|:::g|:::c|:::s|:::e|:::o|$))'
        ${m} = [regex]::Match(${Text}, ${pattern})
        if (${m}.Success) {
            ${body} = (${m}.Groups[1].Value -replace '\s+', ' ').Trim()
            if (${body}.Length -gt 0) { return "${Label}: ${body}`n`n" }
        }
        return ""
    }

    ${prompt}  = "Follow these instructions exactly.`n`n"
    ${prompt} += (Get-Block -Tag 'r' -Label 'Role'            -Text ${out})
    ${prompt} += (Get-Block -Tag 'g' -Label 'Goal'            -Text ${out})
    ${prompt} += (Get-Block -Tag 'c' -Label 'Constraints'     -Text ${out})
    ${prompt} += (Get-Block -Tag 's' -Label 'Reasoning Hints' -Text ${out})
    ${prompt} += (Get-Block -Tag 'e' -Label 'Examples'        -Text ${out})
    ${prompt} += (Get-Block -Tag 'o' -Label 'Output Spec'     -Text ${out})

    ${result} = if ([string]::IsNullOrWhiteSpace(${prompt})) { ${out} } else { ${prompt} }
    ${result}
}
