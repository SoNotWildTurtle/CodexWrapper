# SYM-5 Bash expander and runner
cx() {
  # Usage:
  #   cx '::r @sec ::g harden sshd on ubuntu ::c prod; ^mm,^md,^st7 ::s ^ts,^rg' \
  #      | your_api_caller_here
  local in="$*"

  # 1) Dictionary
  local DICT
  DICT="$(cat <<'EOF'
@sec=>You are a senior security engineer and red/blue-team trainer.
@ds=>You are a data scientist and ML engineer.
@dev=>You are a senior software engineer.

^ts=>Think step-by-step and verify each step.
^mm=>Use minimal tokens; compress phrasing, keep meaning.
^ck=>List assumptions; call out unknowns explicitly.
^rg=>Reason first, then answer.
^fx=>If facts are uncertain, hedge and ask for the single most helpful follow-up.
^md=>Format using concise Markdown.
^ps=>Provide a short pseudocode outline.
^cx=>Provide a compressed recap (≤ 2 lines) at the end.
^qa=>Return Q→A pairs.
EOF
)"

  # 2) Expand {param} forms like ^st{5}
  #    Convert ^st{N} -> "Return at most N bullet points."
  local out="$in"
  out="$(printf '%s' "$out" | sed -E 's/\^st\{([0-9]+)\}/Return at most \1 bullet points./g')"

  # 3) Replace dictionary codes (short → long)
  #    We do longest-first to avoid partial overlaps.
  # shellcheck disable=SC2001
  while IFS= read -r line; do
    [[ -z "$line" ]] && continue
    local k="${line%%=>*}"
    local v="${line#*=>}"
    # escape sed special chars in key/value
    local kq vq
    kq=$(printf '%s' "$k" | sed -e 's/[.[\*^$\/]/\\&/g')
    vq=$(printf '%s' "$v" | sed -e 's/[&/]/\\&/g')
    out="$(printf '%s' "$out" | sed -E "s/${kq}( |$)/${vq} /g")"
  done <<<"$(printf '%s\n' "$DICT" | sed '/^\s*$/d')"

  # 4) Structure builder: parse ::r ::g ::c ::s ::e ::o blocks into a prompt
  #    Split tokens safely by recognizing ::tags; then assemble.
  build_block() {
    local tag="$1" label="$2"
    printf '%s' "$out" | awk -v t="::$tag" -v L="$label" '
      BEGIN{ RS="::"; FS="[ \n]"; found=0; }
      {
        if ($1==substr(t,3)) {
          $1=""; sub(/^[ \t\r\n]+/,"")
          txt=$0; gsub(/\n+/," ",txt)
          gsub(/[ \t]+/," ",txt)
          if (length(txt)>0) {
            printf "%s: %s\n\n", L, txt
          }
        }
      }'
  }

  # 5) Compose final expanded prompt
  {
    build_block "r" "Role"
    build_block "g" "Goal"
    build_block "c" "Constraints"
    build_block "s" "Reasoning Hints"
    build_block "e" "Examples"
    build_block "o" "Output Spec"
  } | awk '
    BEGIN{ has=0 }
    { buf=buf $0; has=1 }
    END{
      if (has) {
        print "Follow these instructions exactly.\n"
        print buf
      } else {
        print "Follow these instructions exactly.\n\n" $0
      }
    }'
}
