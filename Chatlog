# MINC — CX5-ALG v1 compressor (defensive/utility)
cx5() {
  # Usage: cx5 "role=@sec" "goal=harden sshd ubuntu" "constraints=prod only; ^mm,^md,^st7" "reason=^ts,^rg,^ck" "out=md,checklist"
  local role goal cons reason out raw
  for kv in "$@"; do
    k="${kv%%=*}"; v="${kv#*=}"
    case "$k" in
      role) role="$v" ;;
      goal) goal="$v" ;;
      constraints|cons) cons="$v" ;;
      reason|plan) reason="$v" ;;
      out|output) out="$v" ;;
      raw|R) raw="$v" ;;
    esac
  done

  # Normalize hints (turn commas into tokens)
  cons="${cons//, /,}"; reason="${reason//, /,}"

  # Build F: ∫( role ⊕ goal(...) ⊕ d[constraints] ⊕ Π{reason} )
  local F="∫(${role} ⊕ goal(${goal})"
  [[ -n "$cons"   ]] && F+=" ⊕ d[${cons}]"
  [[ -n "$reason" ]] && F+=" ⊕ Π{${reason}}"
  F+=")"

  # Assemble line
  printf 'CX5|v=1|Σ=|F=%s|R=%s|O=%s\n' "$F" "${raw:-}" "${out:-}"
}
